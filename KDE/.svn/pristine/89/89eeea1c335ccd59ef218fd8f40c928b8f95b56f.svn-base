"<personname> <firstname>Gary</firstname> <othername>R.</othername> "
"<surname>Cramblitt</surname> </personname> <email>garycramblitt@comcast.net</"
"email>"

#. Tag: trans_comment
#: index.docbook:50
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr ""
"<othercredit role=\"translator\"><firstname>İşbaran</"
"firstname><surname>Akçayır</"
"surname><affiliation><address><email>isbaran@gmail.com</email></address></"
