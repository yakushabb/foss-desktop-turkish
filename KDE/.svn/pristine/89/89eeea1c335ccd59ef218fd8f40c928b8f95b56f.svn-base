#. Tag: holder
#: index.docbook:63
#, no-c-format
msgid "Gary R. Cramblitt"
msgstr "Gary R. Cramblitt"

#. Tag: date
#: index.docbook:78
#, no-c-format
msgid "2016-11-29"
msgstr "2016-11-29"

#. Tag: releaseinfo
#: index.docbook:79
#, no-c-format
msgid "&konversation; 1.6"
msgstr "&konversation; 1.6"

#. Tag: para
#: index.docbook:84
#, no-c-format
msgid ""
"&konversation; is a user-friendly &irc; client built on &Qt; and &kf5-full;."
msgstr ""
"&konversation; &Qt; ve &kf5-full; üzerinde inşa edilmiş kullanıcı dostu bir "
"&irc; istemcisidir."

#. Tag: keyword
#: index.docbook:94
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:95
#, no-c-format
msgid "extragear"
msgstr "extragear"

#. Tag: keyword
#: index.docbook:96
#, no-c-format
msgid "Konversation"
msgstr "Konversation"

#. Tag: keyword
#: index.docbook:97
#, no-c-format
msgid "<keyword>irc</keyword>"
msgstr "<keyword>irc</keyword>"

#. Tag: keyword
#: index.docbook:98
#, no-c-format
msgid "internet relay chat"
msgstr "internet sohbet aracı"

#. Tag: keyword
#: index.docbook:99
#, no-c-format
msgid "chat"
msgstr "sohbet"

#. Tag: keyword
#: index.docbook:100
#, no-c-format
msgid "communications"
msgstr "bağlantılar"

#. Tag: title
#: index.docbook:153
#, no-c-format
msgid "Introduction"
msgstr "Giriş"

#. Tag: para
#: index.docbook:160
#, no-c-format
msgid ""
"&konversation; is an &irc; client built on &Qt; and &kf5-full;. It offers "
"the following features:"
msgstr ""
"&konversation;, &Qt; ve &kf5-full; üzerine kurulu bir &irc; istemcisidir. "
"Aşağıdaki özellikleri sunmaktadır."

#. Tag: para
#: index.docbook:166
#, no-c-format
msgid "SSL support."
msgstr "SSL desteği"

#. Tag: para
#: index.docbook:167
#, no-c-format
msgid "User-friendly tabbed interface."
msgstr "Kullanıcı dostu sekme arabirimi"

#. Tag: para
#: index.docbook:168
#, no-c-format
msgid "Customizable Quick Buttons for often-used commands."
msgstr "Sık kullanılan komutlar için özelleştirilebilir Hızlı Düğmeler."

#. Tag: para
#: index.docbook:169
#, no-c-format
msgid "Automatic reconnect and rejoin."
msgstr "Otomatik yeniden bağlanma ve yeniden katılma."

#. Tag: para
#: index.docbook:170
#, no-c-format
msgid "DCC send and receive."
msgstr "DCC gönderme ve alma."

#. Tag: para
#: index.docbook:171
#, no-c-format
msgid "&i18n-Nickname; watch list."
msgstr "&i18n-Nickname; izleme listesi"

#. Tag: para
#: index.docbook:172
#, no-c-format
msgid ""
"Visual and auditory notifications for a wide variety of events, such as "
"messages containing your &i18n-nickname;, or &i18n-nickname;s on your watch "
"list going online or offline."
msgstr ""
"&i18n-nickname; içeren iletiler veya izleme listenizdeki &i18n-nickname; "
"çevrimiçi veya çevrimdışı olacak gibi çok çeşitli etkinlikler için görsel ve "
"sesli bildirimler."

#. Tag: para
#: index.docbook:175
#, no-c-format
msgid ""
"Customizable highlighting of messages by &i18n-nickname; or regular "
"expression pattern."
msgstr ""
"&i18n-nickname; tarafından gelen iletilerin özelleştirilebilir vurgulanması "
"veya bir düzenli ifade deseni."

#. Tag: para
#: index.docbook:177
#, no-c-format
msgid "&i18n-Nickname; completion."
msgstr "&i18n-Nickname; tamamlama."

#. Tag: para
#: index.docbook:178
#, no-c-format
msgid "Capture and save all &URL;s appearing in messages."
msgstr "İletilerinizde görülen tüm &URL;lerin kapılıp saklanması."

#. Tag: para
#: index.docbook:179
#, no-c-format
msgid "On-screen display of messages, even when minimized."
msgstr "Küçültülmüş olsalar bile, iletilerinizin ekranda görünmesi."

#. Tag: para
#: index.docbook:180
#, no-c-format
msgid "&i18n-Nickname; ignore list."
msgstr "&i18n-Nickname; yoksay listesi."

#. Tag: para
#: index.docbook:181
#, no-c-format
msgid "Automatic logging and log management."
msgstr "Otomatik bağlanma ve bağlanma yönetimi."

#. Tag: para
#: index.docbook:182
#, no-c-format
msgid "Marking of lines in logs."
msgstr "Günlüklerden hatların işaretlenmesi."

#. Tag: para
#: index.docbook:183
#, no-c-format
msgid "Scripting."
msgstr "Betik yazma."

#. Tag: para
#: index.docbook:187
#, fuzzy, no-c-format
#| msgid ""
#| "The &konversation; website is <ulink url=\"&konviwebsite;\">&konviwebsite;"
#| "</ulink>. Further information like a FAQ and tips and tricks you find in "
#| "the <ulink url=\"http://userbase.kde.org/Konversation\">&konversation; "
#| "UserBase page</ulink>."
msgid ""
"The &konversation; website is <ulink url=\"&konviwebsite;\">&konviwebsite;</"
"ulink>. Further information like a FAQ and tips and tricks you find in the "
"<ulink url=\"https://userbase.kde.org/Konversation\">&konversation; UserBase "
"page</ulink>."
msgstr ""
"The &konversation; web sitesi, <ulink url=\"&konviwebsite;\">&konviwebsite;</"
"ulink>. SSS ve ipuçları hakkında daha fazla bilgi için <ulink url=\"http://"
"userbase.kde.org/Konversation\">&konversation; UserBase sayfası</ulink> "
"adresine gözatın."

#. Tag: para
#: index.docbook:193
#, fuzzy, no-c-format
#| msgid ""
#| "Developers for &konversation; can often be contacted via &irc; at <ulink "
#| "url=\"irc://chat.freenode.net/konversation\">irc.freenode.net channel "
#| "#konversation</ulink>."
msgid ""
"Developers for &konversation; can often be contacted via &irc; at <ulink url="
"\"irc://irc.libera.chat/konversation\">irc.libera.chat channel "
"#konversation</ulink>."
msgstr ""
"&konversation; geliştiricileri, genellikle &irc; ile <ulink url=\"irc://chat."
"freenode.net/konversation\">irc.freenode.net kanal #konversation</ulink> "
"üzerinden haberleşirler."

#. Tag: title
#: index.docbook:199
#, no-c-format
msgid "Using &konversation;"
msgstr "&konversation; Kullanımı"

#. Tag: title
#: index.docbook:204
#, no-c-format
msgid "If you haven't used &irc; before..."
msgstr "Eğer daha önce &irc; kullanmadıysanız..."

#. Tag: para
#: index.docbook:206
#, no-c-format
msgid ""
"Simply put, &irc; is a chat protocol, defined by official Internet "
"standards, and capable of stealing many hours of your life. To use &irc;, "
"you must connect to a server, and then join a channel (equivalent to a chat "
"room) or just engage in private conversations."
msgstr ""
"Basit olarak açıklamak gerekirse, &irc; resim bağlantı standartlarına sahip "
"bir internet protokolüdür ve hayatınızdan zaman çalma yetisine sahiptir. "
"&irc; uygulamasını kullanmak için bir sunucuya bağlanmanız gereklidir. "
"Bundan sonra bir kanala katılırsınız (kanal bir sohbet odası anlamındadır) "
"veya özel sohbet yapmak için düzenlemeler yapabilirsiniz."

#. Tag: para
#: index.docbook:211
#, no-c-format
msgid ""
"To connect to a server and channel, open &konversation;. The "
"<guilabel>Server List</guilabel> screen appears."
msgstr ""
"Bir sunucuya ve kanala bağlanmak için &konversation;'ı açın. "
"<guilabel>Sunucu Listesi</guilabel> ekranı görünecektir."

#. Tag: screeninfo
#: index.docbook:215 index.docbook:562
#, no-c-format
msgid "<screeninfo>Server List</screeninfo>"
msgstr "<screeninfo>Sunucu Listesi</screeninfo>"

#. Tag: phrase
#: index.docbook:228 index.docbook:576
#, no-c-format
msgid "<phrase>Server List</phrase>"
msgstr "<phrase>Sunucu Listesi</phrase>"

#. Tag: para
#: index.docbook:236
#, fuzzy, no-c-format
#| msgid ""
#| "The list of configured &irc; <guilabel>Networks</guilabel> are listed "
#| "here. An &irc; network is a collection of cooperating servers. You need "
#| "only connect to one of the servers in the network to be connected to the "
#| "entire &irc; network. Once connected, &konversation; will automatically "
#| "join the <guilabel>Channels</guilabel> shown. When &konversation; is "
#| "started for the first time, the <userinput><replaceable>Freenode</"
#| "replaceable></userinput> network and <userinput><replaceable>#kde</"
#| "replaceable></userinput> channel are already entered for you. Click on a "
#| "network to select it."
msgid ""
"The list of configured &irc; <guilabel>Networks</guilabel> are listed here. "
"An &irc; network is a collection of cooperating servers. You need only "
"connect to one of the servers in the network to be connected to the entire "
"&irc; network. Once connected, &konversation; will automatically join the "
"<guilabel>Channels</guilabel> shown. When &konversation; is started for the "
"first time, the <userinput><replaceable>Libera</replaceable></userinput> "
"network and <userinput><replaceable>#kde</replaceable></userinput> channel "
"are already entered for you. Click on a network to select it."
msgstr ""
"Yapılandırılmış &irc; listesi, <guilabel>Ağlar</guilabel> olarak listelenir. "
"Bir &irc; ağı, iş birliği yapan sunucuların bir koleksiyonudur. Tüm &irc; "
"ağına bağlanmak için yalnızca ağdaki sunuculardan birine bağlanmanız "
"yeterlidir. &konversation;'a bağlandıktan sonra, <guilabel>Kanallar</"
"guilabel> otomatik olarak görüntülenir. &konversation; ilk kez "
"başlatıldığında, <userinput><replaceable>Freenode</replaceable></userinput> "
"ağı ve <userinput><replaceable>#kde</replaceable></userinput> kanalına "
"otomatik olarak girilir. Seçmek istediğiniz ağın üstüne tıklayın."

#. Tag: para
#: index.docbook:243
#, no-c-format
msgid ""
"Click here to define a new <guilabel>Network</guilabel>, including the "
"server to connect to, and the <guilabel>Channels</guilabel> to automatically "
"join once connected. See <link linkend=\"serverlist\">Defining new networks, "
"servers, and auto join channels</link> for more information."
msgstr ""
"Bağlanmak istediğiniz sunucuyu içeren yeni bir Ağ <guilabel>tanımlamak</"
"guilabel> için buraya tıklayın ve <guilabel>Kanallardan</guilabel> birine "
"otomatik olarak katılın. Bakınız <link linkend=\"serverlist\">Yeni kanallar, "
"sunucular tanımlamak ve kanallara</link> otomatik olarak girmek için "
"yukarıdaki link size yardımcı olacaktır."

#. Tag: para
#: index.docbook:245
#, no-c-format
msgid "Click here to connect to the selected &irc; network and channel."
msgstr "Seçilmiş olan &irc; ağına bağlanmak için buraya tıklayınız."

#. Tag: para
#: index.docbook:250
#, no-c-format
msgid ""
"When you click the <guibutton>Connect</guibutton> button the first time you "
"open &konversation;, you may see the following message, telling you that "
"your default <guilabel>identity</guilabel> is not set up correctly."
msgstr ""
"&konversation;'ı ilk açtığınızda, <guibutton>Bağlan</guibutton> düğmesine "
"tıklarsanız, varsayılan <guilabel>kimlik</guilabel> bilginizin "
"ayarlanmadığını bildiren aşağıdaki ileti görünecektir."

#. Tag: screeninfo
#: index.docbook:256
#, no-c-format
msgid "<screeninfo>Check Identities</screeninfo>"
msgstr "<screeninfo>Kimlikleri Denetle</screeninfo>"

#. Tag: phrase
#: index.docbook:262
#, no-c-format
msgid "<phrase>Check Identities</phrase>"
msgstr "<phrase>Kimlikleri Denetle</phrase>"

#. Tag: para
#: index.docbook:268
#, no-c-format
msgid ""
"The first time you open &konversation; it obtains information about the "
"current user from the operating system and fills in defaults for the "
"Identity. If the operating system user information is not complete, for "
"example, no Full Name is defined, you may see the message above. To correct "
"this problem, click <guibutton>Edit Identity...</guibutton> and see <link "
"linkend=\"identity\">Setting your identity</link> for more information."
msgstr ""
"&konversation;'ı ilk açtığınızda, geçerli kullanıcı hakkında işletim "
"sisteminden bilgi alır ve Kimlik için varsayılanları doldurur. İşletim "
"sistemi kullanıcı bilgileri eksikse, örneğin Tam Adı tanımlanmadıysa, "
"yukarıdaki iletiyi görebilirsiniz. Bu sorunu gidermek için "
"<guibutton>Kimliği Düzenle...</guibutton> seçeneğine tıklayın ve daha fazla "
"bilgi için <link linkend=\"identity\">Kimliğinizi ayarlayın</link> konusuna "
"bakın."

#. Tag: para
#: index.docbook:277
#, no-c-format
msgid ""
"The <interface>Main</interface> screen will be displayed showing the "
"messages sent by the server to the client. (If &konversation; will not "
"connect to the server, see <link linkend=\"faq\">Questions and Answers</"
"link>.) When the server messages have finished scrolling past, "
"&konversation; will join the channel or channels chosen."
msgstr ""
"<interface>Ana</interface> ekran sunucu tarafından kullanıcıya gönderilen "
"iletileri görüntüleyecektir. (Eğer &konversation; sunucuya bağlanmazsa, "
"buraya <link linkend=\"faq\">Sorular ve Cevaplar</link> kısmına göz atın.) "
"Sunucu iletileri geçmişi taramayı bitirdiğinde, &konversation; kanala veya "
"seçilmiş kanala girecektir."

#. Tag: screeninfo
#: index.docbook:284
#, no-c-format
msgid "Channel."
msgstr "Kanal."

#. Tag: phrase
#: index.docbook:297
#, no-c-format
msgid "<phrase>Channel</phrase>"
msgstr "<phrase>Kanal</phrase>"

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid ""
"This is called the <interface>Input Line</interface>. To send a message to "
"everyone in the channel, type the message here and press &Enter;. Your "
"message, as well as everyone else's messages appear in the channel scroll "
"above. Each message is preceded by the time and user's &i18n-nickname;."
msgstr ""
"Bu <interface>Girdi Satırı</interface> olarak bilinir. Kanaldaki herkese "
"ileti göndermek için iletiyi buraya yazın ve &Enter; tuşuna basın. İletiniz, "
"diğerlenininki gibi yukarıdaki akan listede gözükecektir. Tüm iletilerin "
"yanında saat ve kullanıcının &i18n-nickname; vardır."

#. Tag: para
#: index.docbook:310
#, no-c-format
msgid ""
"You may join additional servers and channels. Each server, channel, channel "
"list, and other screen gets a separate tab here. To display a list of "
"available channels, see <link linkend=\"list-channels\">Listing available "
"channels</link>. To join a channel, type: <userinput><command>/join</"
"command> <replaceable>#channelname</replaceable></userinput> in the Input "
"Line. (The <userinput>#</userinput> is required.) You may also type "
"<userinput><command>/j</command></userinput> as a shorthand to "
"<userinput><command>/join</command></userinput>. To leave a channel, just "
"type <userinput><command>/part</command></userinput>. To switch the display "
"to a different server or channel, click the corresponding tab."
msgstr ""
"Başka sunucu ve kanallara katılabilirsiniz. Her sunucu kanalı, kanal listesi "
"ve öteki ekran burada farklı bir sekmede gözükür. Girilebilecek kanalların "
"listesisi görmek için tıklayacağımız adres <link linkend=\"list-channels"
"\">Uygun Kanalları Listeliyor</link>. Bir kanala katılmak için şunu yazın: "
"<userinput><command>/katıl</command> <replaceable>#kanaladı</replaceable></"
"userinput> bunu Girdi Satırına yazın. (Sizin <userinput>#</userinput> "
"gereklidir.) Kısayol olarak <userinput><command>/j</command></userinput> "
"bunu da yazabilirsiniz <userinput><command>/katıl</command></userinput>. "
"Kanalı terk etmek için şunu yazın <userinput><command>/part</command></"
"userinput>. Başka bir sunucu veya kanala geçmek için, ilgili sekmeye "
"tıklayınız."

#. Tag: para
#: index.docbook:317
#, no-c-format
msgid ""
"This is called the <interface>Nick Panel</interface>. It lists the &i18n-"
"nickname;s of all the users who have joined the channel, including yourself."
msgstr ""
"Bu, <interface>Rumuz Paneli</interface> olarak bilinir. Bu panel, kanala "
"katılmış olan siz dahil tüm kullanıcıların &i18n-nickname; gösterir."

#. Tag: para
#: index.docbook:322
#, no-c-format
msgid "That's the basics, for more detailed information, read on..."
msgstr "Bunlar temellerdir, daha detaylı bilgiler için okumaya devam edin."

#. Tag: title
#: index.docbook:329
#, no-c-format
msgid "Setting your identity"
msgstr "Kimliğinizi ayarlama"

#. Tag: para
#: index.docbook:331
#, no-c-format
msgid ""
"Before you start using &konversation; regularly, you should set how you will "
"be identified on the network."
msgstr ""
"&konversation; düzenli olarak kullanmaya başlamadan önce ağda nasıl "
"tanımlanacağınızı belirlemeniz gereklidir."

#. Tag: para
#: index.docbook:333
#, no-c-format
msgid ""
"Click <menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Identities</"
"guisubmenu> </menuchoice> on the main menu. <action>The "
"<guilabel>Identities</guilabel> screen will appear. You can also display the "
"<guilabel>Identities</guilabel> screen by clicking the <guibutton>Edit</"
"guibutton> button on the <guilabel>Edit Network</guilabel> or <guilabel>New "
"Network</guilabel> screen.</action>"
msgstr ""
"Menüden <menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Kimlikler</"
"guisubmenu> </menuchoice> tıklayın. <action><guilabel>Kimlikler</guilabel>  "
"ekranı gözükecektir. Ayrıca <guilabel>Kimlikler</guilabel> ekranını, "
"<guilabel>Ağı Düzenle</guilabel> veya <guilabel>Yeni Ağ</guilabel> "
"ekranındaki <guibutton>Düzenle</guibutton> düğmesiyle de yapabilirsiniz.</"
"action>"

#. Tag: screeninfo
#: index.docbook:344
#, no-c-format
msgid "<screeninfo>Identities (General tab)</screeninfo>"
msgstr "<screeninfo>Kimlikler (Genel sekme)</screeninfo>"

#. Tag: phrase
#: index.docbook:361
#, no-c-format
msgid "<phrase>Identities (General tab)</phrase>"
msgstr "<phrase>Kimlikler (Genel sekme)</phrase>"

#. Tag: para
#: index.docbook:369
#, no-c-format
msgid "Click here to select an <guilabel>Identity</guilabel> to edit."
msgstr "Bir <guilabel>Kimliği</guilabel> düzenlemek için buraya tıklayın."

#. Tag: para
#: index.docbook:370
#, no-c-format
msgid ""
"Use these buttons to <guibutton>Add</guibutton>, <guibutton>Duplicate</"
"guibutton>, <guibutton>Rename</guibutton>, or <guibutton>Remove</guibutton> "
"an <guilabel>Identity</guilabel>."
msgstr ""
"Bir <guilabel>Kimlik</guilabel> için,<guibutton>Ekle</guibutton>, "
"<guibutton>Çoğalt</guibutton>, <guibutton>Yeniden Adlandır</guibutton>, veya "
"<guibutton>Kaldır</guibutton> yapmak için bu düğmeleri kullanın."

#. Tag: para
#: index.docbook:372
#, no-c-format
msgid ""
"Enter your real name here. &irc; is not intended to keep you hidden from "
"your friends or enemies. Keep this in mind if you are tempted to behave "
"maliciously. A fake \"real name\" can be a good way to mask your gender from "
"all the nerds out there, but the PC you use can always be traced so you will "
"never be truly anonymous."
msgstr ""
"Gerçek isminizi buraya girin. &irc; sizi dost veya düşmanlarınızdan gizlemek "
"niyetinde değildir. Eğer niyetiniz kötü ise bunu aklınızdan çıkarmayın. "
"Sahte bir isim sizi dışarıdaki kişilerden gizlemek için iyi bir yol "
"olabilir, fakat kullandığınız bilgisayar daima izleniyor olabilir bu yüzden "
"siz hiçbir zaman gerçekten anonim bir kullanıcı olamazsınız."

#. Tag: para
#: index.docbook:373
#, no-c-format
msgid ""
"Use these buttons to <guibutton>Add</guibutton> or <guibutton>Remove</"
"guibutton> a &i18n-nickname;."
msgstr ""
"&i18n-nickname; <guibutton>Ekle</guibutton> veya <guibutton>Kaldır</"
"guibutton> için bu düğmeleri kullanın."

#. Tag: para
#: index.docbook:375
#, no-c-format
msgid ""
"This is your list of &i18n-nickname;s. A &i18n-nickname; is the name that "
"other users will know you by. You may use any name you desire. The first "
"character must be a letter. Other characters may be letters, numbers, or the "
"special characters <literal>-[]\\`_^{}|</literal>."
msgstr ""
"Bu sizin &i18n-nickname; listenizdir. Bir &i18n-nickname; sizi diğer "
"kullanıcıların tanıdığı isminizdir. İstediğiniz bir ismi kullanabilirsiniz.  "
"İlk karakter bir harf olmak zorundadır. Diğer karakterler harfler, numaralar "
"veya özel karakterlerden oluşabilir  <literal>-[]\\`_^{}|</literal>."

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"Since &i18n-nickname;s must be unique across an entire &irc; network, your "
"desired name may be rejected by the server because someone else is already "
"using that &i18n-nickname;. Enter alternate &i18n-nickname;s for yourself. "
"If your first choice is rejected by the server, &konversation; will try the "
"alternate &i18n-nickname;s."
msgstr ""
"&i18n-nickname;lar tüm &irc; ağı kapsamında tek ve biricik olduğun için, "
"sizin seçtiğiniz ismi sunucu, bir başkası da  kullandığı için reddetmiş "
"olabilir. Kendinize farklı &i18n-nickname;lar giriniz. İlk seçtiğiniz sunucu "
"tarafından geri çevrildiyse, &konversation; alternatif &i18n-nickname;lar "
"deneyecektir."

#. Tag: para
#: index.docbook:382
#, no-c-format
msgid ""
"According to RFC 2812, the maximum &i18n-nickname; length is 9, but this is "
"actually determined by the server. To determine the maximum for a server, "
"connect to the server. In the <interface>Server Messages</interface> tab, "
"look for a <computeroutput>[Support]</computeroutput> message. For example:"
msgstr ""
"RFC 2812’e göre, en fazla &i18n-nickname; uzunluğu 9’dur, fakat bu aslında "
"sunucu tarafından belirlenmiştir. Bir sunucu için en uzunu belirlemek için, "
"sunucuya bağlanın. Bu  <interface>Sunucu İletileri</interface> sekmesinde, "
"arayacağınız ileti <computeroutput>[Destek]</computeroutput> olmalıdır. "
"Örneğin"

#. Tag: computeroutput
#: index.docbook:389
#, no-c-format
msgid ""
"[18:51] *Eisfuchs* [21:45] [Support] Eisfuchs MODES=4 MAXCHANNELS=20 "
"NICKLEN=16 USERLEN=10 HOSTLEN=63 TOPICLEN=450 KICKLEN=450 CHANNELLEN=30 "
"KEYLEN=23 CHANTYPES=# PREFIX=@+ CASEMAPPING=ascii CAPAB IRCD=dancer"
msgstr ""
"[18:51] *Eisfuchs* [21:45] [Support] Eisfuchs MODES=4 MAXCHANNELS=20 "
"NICKLEN=16 USERLEN=10 HOSTLEN=63 TOPICLEN=450 KICKLEN=450 CHANNELLEN=30 "
"KEYLEN=23 CHANTYPES=# PREFIX=@+ CASEMAPPING=ascii CAPAB IRCD=dancer"

#. Tag: para
#: index.docbook:394
#, no-c-format
msgid ""
"The <computeroutput>NICKLEN</computeroutput> parameter specifies the maximum "
"&i18n-nickname; length."
msgstr ""
"<computeroutput>NICKLEN</computeroutput> parametresi  en fazla yazılacak "
"&i18n-nickname; uzunluğunu belirtir."

#. Tag: para
#: index.docbook:399
#, no-c-format
msgid ""
"Use these buttons to change the order of the &i18n-nickname;s. The top &i18n-"
"nickname; is tried first, then the next &i18n-nickname;, and so on."
msgstr ""
"Bu düğmeleri &i18n-nickname;ların sıralanışını değiştirmek için kullanın. En "
"üstteki &i18n-nickname; ilk denenendir, daha sonra gelen &i18n-nickname; "
"daha sonradır ve bu böyle devam eder."

#. Tag: para
#: index.docbook:402
#, no-c-format
msgid ""
"If you have registered your &i18n-nickname; with the &irc; network, enter "
"the service and password to authenticate your &i18n-nickname;. When "
"&konversation; connects, it will automatically send <userinput><command>/"
"msg</command> <replaceable>service</replaceable> <command>IDENTIFY</command> "
"<replaceable>password</replaceable></userinput> to the server. If you don't "
"know what this is, leave these boxes blank."
msgstr ""
"Eğer &i18n-nickname;nızı &irc; ağına kaydettirdiyseniz, &i18n-nickname;nızı "
"onaylamak için hizmet ve parolanızı girin. &konversation; ağa bağlandığında, "
"o otomatik olarak sunucuya şunları görnderir: <userinput><command>/msg</"
"command> <replaceable>hizmet</replaceable> <command>IDENTIFY</command> "
"<replaceable>parola</replaceable></userinput>. Eğer bunun ne olduğunu "
"bilmiyorsanız, bu kutuları boş bırakın."

#. Tag: para
#: index.docbook:411
#, no-c-format
msgid "Click the <guilabel>Away</guilabel> tab."
msgstr "Şuraya <guilabel>Uzakta</guilabel> sekmesine tıklayın."

#. Tag: screeninfo
#: index.docbook:415
#, no-c-format
msgid "<screeninfo>Identities (Away tab)</screeninfo>"
msgstr "<screeninfo>Kimlikler (Uzakta Sekmesi)</screeninfo>"

#. Tag: phrase
#: index.docbook:428
#, no-c-format
msgid "<phrase>Identities (Away tab)</phrase>"
msgstr "<phrase>Kimlikler (Uzakta Sekmesi)</phrase>"

#. Tag: para
#: index.docbook:440
#, no-c-format
msgid ""
"Enter a &i18n-nickname; that indicates you are away. Whenever you perform an "
"<userinput><command>/away </command><replaceable>msg</replaceable></"
"userinput> command in any channel joined with this <guilabel>Identity</"
"guilabel>, &konversation; will automatically change your &i18n-nickname; to "
"the <guilabel>Away nickname</guilabel>. Other users will be able to tell you "
"are away from your computer. Whenever you perform an <userinput><command>/"
"away</command></userinput> command in any channel in which you are away, "
"&konversation; will automatically change your &i18n-nickname; back to the "
"original. If you do not wish to automatically change your &i18n-nickname; "
"when going away, leave blank."
msgstr ""
"Uzakta olduğunuzu belirten bir &i18n-nickname; giriniz. Herhangi bir kanada "
"<userinput><command>/uzakta </command><replaceable>msg</replaceable></"
"userinput> komutu yazdığınızda bu <guilabel>Kimlik</guilabel>ile, "
"&kmyapplication; sizin &i18n-nickname;nızı <guilabel>Uzakta takma adı</"
"guilabel> kipine dönüştürecektir. Diğer kullanıcılar sizin bilgisayarınızdan "
"uzakta olduğunuzu düşünüceklerdir. Siz ne zaman ki bir "
"kanalda<userinput><command>/uzakta</command></userinput> komutunu "
"verirseniz, &konversation; sizin &i18n-nickname;ınızı otomatik olarak eski "
"haline dönüştürecektir. Eğer uzakta olduğunuzda otomatik olarak &i18n-"
"nickname; değişmesini istemiyorsanız, boş bırakın."

#. Tag: para
#: index.docbook:451
#, no-c-format
msgid ""
"If you check this box, whenever you perform an <userinput><command>/away</"
"command></userinput> command, a horizontal line will appear in the channel, "
"marking the point where you went away. Other &irc; users do not see this "
"horizontal line."
msgstr ""
"Eger bu kutuyu tiklerseniz, siz her ne zaman bir<userinput><command>/uzakta</"
"command></userinput> komutu uyguladığınızda kanalda sizin uzakta olduğunuzu "
"belirten yatay bir çizgi gözükecektir. Diğer &irc; kullanıcıları bu yatay "
"çizgiyi görmezler."

#. Tag: para
#: index.docbook:455
#, no-c-format
msgid ""
"If you check this box, &konversation; will automatically send the "
"<guilabel>Away command</guilabel> to all channels joined with this "
"<guilabel>Identity</guilabel>. <userinput><replaceable>%s</replaceable></"
"userinput> is replaced with <userinput><replaceable>msg</replaceable></"
"userinput>. Whenever you perform an <userinput><command>/away</command></"
"userinput> command, the <guilabel>Return command</guilabel> will be "
"displayed in all channels joined with this <guilabel>Identity</guilabel>."
msgstr ""
"Eger bu kutuyu tiklerseniz, &konversation; otomatik olarak <guilabel>Uzakta "
"iletisi</guilabel>ni bu<guilabel>Kimlik</guilabel> ile kanala yer "
"değiştirmiş <userinput><replaceable>%s</replaceable></userinput> herkese "
"gönderecektir. <userinput><replaceable>msg</replaceable></userinput>Siz her "
"ne zaman <userinput><command>/uzakta</command></userinput> komutu "
"yazarsanız, bu <guilabel>Giriş iletisi</guilabel> bu <guilabel>Kimlik</"
"guilabel>ile kanala katılmış herkese gönderilecektir."

#. Tag: para
#: index.docbook:462
#, no-c-format
msgid ""
"Away messages are often considered annoying by other users. Use this option "
"carefully, with consideration for your fellow &irc; users."
msgstr ""
"Uzakta iletisi diğer kullanıcılar tarafından can sıkıcı olarak "
"değerlendirilir genellikle. Bu seçeneği dikkatle kullanın, özellikle sizin "
"gibi &irc; kullanıcılarını gözetiniz."

#. Tag: para
#: index.docbook:471
#, no-c-format
msgid "Click the <guilabel>Advanced</guilabel> tab."
msgstr "Bu <guilabel>Gelişmiş</guilabel> sekmesine tıklayınız."

#. Tag: screeninfo
#: index.docbook:475
#, no-c-format
msgid "<screeninfo>Identities (Advanced tab)</screeninfo>"
msgstr "<screeninfo>Kimlikler (Gelişmiş sekmesi)</screeninfo>"

#. Tag: phrase
#: index.docbook:491
#, no-c-format
msgid "<phrase>Identities (Advanced tab)</phrase>"
msgstr "<phrase>Kimlikler (Gelişmiş sekmesi)</phrase>"

#. Tag: para
#: index.docbook:499
#, no-c-format
msgid ""
"You can enter a command here that will be executed before connecting to the "
"server. If this identity is used for more than one server, the command will "
"be executed for each server."
msgstr ""
"Buraya sunucuya bağlanmadan önce çalıştırılacak olan bir komut giriniz. Eğer "
"bir kimlik bir sunucu için bir kezden daha fazla kullanılmış ise, komut her "
"sunucu için ayrı ayrı çalıştırılacaktır."

#. Tag: para
#: index.docbook:503
#, no-c-format
msgid ""
"This setting affects how characters you type are encoded for sending to the "
"server. It also affects how messages are displayed. When you first open "
"&konversation;, it automatically retrieves this setting from the operating "
"system. If you seem to be having trouble seeing other user's messages "
"correctly, try changing this setting."
msgstr ""
"Bu ayar sunucuya gönderdiğiniz karakter kodlamalarına etki edecektir. Bu "
"ayrıca iletilerin görünümünü de etkiler. &konversation; ilk açtığınızda bu "
"ayarlar işletim sisteminde içe aktarılır. Eğer diğer kullanıcıların "
"iletilerini düzgün görüntülemekte problem yaşarsanız, bu ayarı değiştirmeyi "
"deneyin."

#. Tag: para
#: index.docbook:509
#, no-c-format
msgid ""
"When you connect, many servers query your computer for an IDENT response. If "
"you computer is not running an IDENT server, this response is sent by "
"&konversation;. No spaces are allowed. Your first name is suggested."
msgstr ""
"Bağlandığınızda birçok sunucu bilgisayarınızı IDENT çağrısı ile sorgular. "
"Eğer bilgisayarınızda IDENT sunucu çalışmıyorsa, bu çağrı &konversation; "
"tarafından yollanır. Cevap boşluk karakteri içermemelidir."

#. Tag: para
#: index.docbook:513
#, no-c-format
msgid "Whenever you leave a channel, this message is sent to the channel."
msgstr "Bir kanalı her terk edişinizde, bu ileti kanala gönderilir."

#. Tag: para
#: index.docbook:515
#, no-c-format
msgid ""
"Whenever you are kicked from a channel (usually by an &irc; operator), this "
"message is sent to the channel."
msgstr ""
"Bir kanal tarafından tekmelendiğinizde (genellikle bir &irc; servisi "
"tarafından), bu ileti kanala gönderilir."

#. Tag: para
#: index.docbook:518
#, no-c-format
msgid ""
"Click to apply your changes. In order for all the changes to take effect, "
"you must disconnect from the server and re-connect. The easiest way to do "
"that is to quit &konversation; and restart."
msgstr ""
"Değişikliklerinizin uygulanması için tıklayın. Tüm değişikliklerinizin "
"etkinleştirilmesi için sunucudan kopmalı ve tekrar bağlanmalısınız. Bunu "
"yapmanın en kolay yolu &konversation;'ı kapatmak ve yeniden başlamaktır."

#. Tag: title
#: index.docbook:543
#, no-c-format
msgid "Defining new networks, servers and auto join channels"
msgstr "Yeni ağlar, sunucular ve kanallara otomatik katılımlar belirleme"

#. Tag: para
#: index.docbook:545
#, fuzzy, no-c-format
#| msgid ""
#| "The <guilabel>Server List</guilabel> screen appears when you open the "
#| "&konversation; program. It also appears when you choose <menuchoice> "
#| "<guisubmenu>File</guisubmenu> <guisubmenu>Server List</guisubmenu> </"
#| "menuchoice> on the main menu. <action>The <guilabel>Server List</"
#| "guilabel></action> screen lists your existing defined &irc; "
#| "<guilabel>Network</guilabel>s, listed by group. An &irc; network is a "
#| "collection of cooperating servers. When you connect to any server in a "
#| "network, you have access to all the channels of the network. Examples of "
#| "&irc; networks are <userinput><replaceable>Freenode</replaceable></"
#| "userinput> and <userinput><replaceable>Undernet</replaceable></userinput>."
msgid ""
"The <guilabel>Server List</guilabel> screen appears when you open the "
"&konversation; program. It also appears when you choose <menuchoice> "
"<guisubmenu>File</guisubmenu> <guisubmenu>Server List</guisubmenu> </"
"menuchoice> on the main menu. <action>The <guilabel>Server List</guilabel></"
"action> screen lists your existing defined &irc; <guilabel>Network</"
"guilabel>s, listed by group. An &irc; network is a collection of cooperating "
"servers. When you connect to any server in a network, you have access to all "
"the channels of the network. Examples of &irc; networks are "
"<userinput><replaceable>Libera</replaceable></userinput> and "
"<userinput><replaceable>Undernet</replaceable></userinput>."
msgstr ""
"<guilabel>Sunucu Listesi</guilabel> ekranı &konversation; programını "
"açtığınızda karşınıza çıkar. Bu işlem ana menüde<menuchoice> "
"<guisubmenu>Dosya</guisubmenu> <guisubmenu>Sunucu Listesi</guisubmenu> </"
"menuchoice> seçtiğinizde de tekrarlanır. <action>Bu <guilabel>Sunucu "
"Listesi</guilabel></action> ekranı sizin varolan ve grupta da listenen &irc; "
"<guilabel>Ağ</guilabel>larınızı listeler. Bir &irc; ağı, işbirliği içindeki "
"ağların toplamından oluşur. Bir ağdaki herhangi bir sunucya bağlandığınızda, "
"ağdaki tüm kanalları kabul etmelisiniz. Örnek &irc kanalları "
"<userinput><replaceable>Freenode</replaceable></userinput> ve "
"<userinput><replaceable>Undernet</replaceable></userinput>dir."

#. Tag: para
#: index.docbook:584
#, no-c-format
msgid ""
"Your existing defined <guilabel>Network</guilabel>s are listed here along "
"with the <guilabel>Identity</guilabel> used to connect to the network, and "
"the <guilabel>Channels</guilabel> automatically joined when connected. If "
"you have specified a group for your networks, networks are listed indented "
"under the group. Click on a network to select it."
msgstr ""
"Bağlandığınızda sizi ağa ve <guilabel>Kanallar</guilabel>a <guilabel>Kimlik</"
"guilabel> boyunca otomatik olarak bağlayan sizin var olan  <guilabel>Ağ</"
"guilabel>larınız burada  listelenmiştir. Eğer ağlarınız için öze bir durum "
"belirlemiş iseniz, belirli ağlarınız grup altında listelenmiştir. Bir ağı "
"seçmek için ona tıklayın."

#. Tag: para
#: index.docbook:591
#, no-c-format
msgid ""
"Use these buttons to <guibutton>Add</guibutton> a new network, "
"<guibutton>Edit</guibutton> a highlighted network, or <guibutton>Delete</"
"guibutton> a highlighted network."
msgstr ""
"Bu düğmeleri yeni bir ağ <guibutton>Ekle</guibutton>mek için kullanın, bir "
"seçilmiş ağı <guibutton>Düzenle</guibutton>mek veya  <guibutton>Sil</"
"guibutton>mek için kullanın."

#. Tag: para
#: index.docbook:595
#, no-c-format
msgid ""
"Click this button to connect to the highlighted <guilabel>Network</guilabel> "
"and close the <guilabel>Server List</guilabel> screen. You may highlight "
"more than one network if you wish, which will connect to all the highlighted "
"networks."
msgstr ""
"Seçilmiş<guilabel>Ağ</guilabel> a bağlanmak için bu düğmeye tıklayın. ve  "
"<guilabel>Sunucu Listesi</guilabel> ekranını kapatın. Eğer isterseniz, sizi "
"tüm ağa bağlayacak olan birden fazla ağı seçebilirsiniz."

#. Tag: para
#: index.docbook:600
#, no-c-format
msgid ""
"Clicking this button does not discard the changes you have made. It merely "
"means you do not wish to connect to any networks at this time."
msgstr ""
"Bu düğmeye tıklamak yaptığınız değişiklikleri devre dışı bırakmaz. Bu sizin "
"pek de şu anda herhangi bir ağa bağlanmak arzusunda olmadığınız anlamına "
"gelir."

#. Tag: para
#: index.docbook:608
#, no-c-format
msgid ""
"When you click the <guibutton>New</guibutton> button, the <guilabel>New "
"Network</guilabel> screen appears."
msgstr ""
"<guibutton>Ekle</guibutton> düğmesine tıkladığınızda,  <guilabel>Yeni Ağ</"
"guilabel> ekranı görünür."

#. Tag: screeninfo
#: index.docbook:613
#, no-c-format
msgid "<screeninfo>New Network</screeninfo>"
msgstr "<screeninfo>Yeni Ağ</screeninfo>"

#. Tag: phrase
#: index.docbook:631
#, no-c-format
msgid "<phrase>New Network</phrase>"
msgstr "<phrase>Yeni Ağ</phrase>"

#. Tag: para
#: index.docbook:639
#, no-c-format
msgid ""
"Enter the <guilabel>Network name</guilabel> here. You may create as many "
"entries in the <guilabel>Server List</guilabel> screen with the same "
"<guilabel>Network</guilabel> as you like."
msgstr ""
"<guilabel>Ağ adı</guilabel> buraya giriniz. <guilabel>Sunucu Listesi</"
"guilabel> ekranında aynı <guilabel>Ağ</guilabel> ile pek çok giriş "
"yaratabilirsiniz."

#. Tag: para
#: index.docbook:647
#, no-c-format
msgid ""
"Choose an existing <guilabel>Identity</guilabel> or click the "
"<guibutton>Edit</guibutton> button to add a new Identity or edit an existing "
"one. The <guilabel>Identity</guilabel> will identify you and determine your "
"&i18n-nickname; when you connect to the network."
msgstr ""
"Mevcut olan bir <guilabel>Kimlik</guilabel> seçin veya yeni bir Kimlik "
"eklemek, varolan bir tanesini düzenlemek için <guibutton>Düzenle</guibutton> "
"düğmesine tıklayın. Bu <guilabel>Kimlik</guilabel> sizi ve sizin &i18n-"
"nickname; ağa bağlandığınızda tanımlayacaktır."

#. Tag: para
#: index.docbook:652
#, fuzzy, no-c-format
#| msgid ""
#| "Optional. This command will be sent to the server after connecting. "
#| "Example: <userinput>/msg NickServ IDENTIFY <replaceable>konvirocks</"
#| "replaceable></userinput>. This example is for the freenode network, which "
#| "requires users to register their &i18n-nickname; with a password and "
#| "login when connecting. <userinput><replaceable>konvirocks</replaceable></"
#| "userinput> is the password for the &i18n-nickname; given in "
#| "<guilabel>Identity</guilabel>. You may enter more than one command by "
#| "separating them with semicolons."
msgid ""
"Optional. This command will be sent to the server after connecting. Example: "
"<userinput>/msg NickServ IDENTIFY <replaceable>konvirocks</replaceable></"
"userinput>. This example is for the Libera network, which requires users to "
"register their &i18n-nickname; with a password and login when connecting. "
"<userinput><replaceable>konvirocks</replaceable></userinput> is the password "
"for the &i18n-nickname; given in <guilabel>Identity</guilabel>. You may "
"enter more than one command by separating them with semicolons."
msgstr ""
"Opsiyonel. Bu komut bağlandıktan sonra sunucuya gönderilecektir. Örneğin: "
"<userinput>/msg NickServ IDENTIFY <replaceable>konvirocks</replaceable></"
"userinput>. Bu örnek , kullanıcıların kendi &i18n-nickname; bir parola ile "
"onaylanmasından sonra ağa bağlanıp oturum açmalarını gerektiren freenode ağı "
"içindir <userinput><replaceable>konvirocks</replaceable></userinput> "
"<guilabel>Identity</guilabel> ile verilen &i18n-nickname; da kullanacağınız "
"paroladır. Bu işlem için aralarına noktalı virgül koyarak birden fazla komut "
"girebilirsiniz."

#. Tag: para
#: index.docbook:657
#, no-c-format
msgid ""
"Check here if you want &konversation; to automatically connect to this "
"network whenever you open &konversation;."
msgstr ""
"Eğer &konversation; uygulamasının her açıldığında otomatik olarak bu ağa "
"bağlanmasını istiyorsanız burayı işaretleyin."

#. Tag: para
#: index.docbook:660
#, no-c-format
msgid ""
"This is a list of &irc; <guilabel>Servers</guilabel> in the network. When "
"connecting to the network, &konversation; will attempt to connect to the top "
"server first. If this fails, it will attempt the second server. If this "
"fails, it will attempt the third, and so on. At least one server must be "
"specified. Click a server to highlight it."
msgstr ""
"Bu ağdaki &irc; <guilabel>Sunucular</guilabel> listesidir. Ağa "
"bağlandığınızda, &konversation; ilk olarak en üstteki sunucuya bağlanmayı "
"deneyecektir. Bu deneme başarısız olursa, ikinci sıradaki sunucuyu "
"deneyecektir. Eğer bu da başarısız olursa üçüncüyü deneyecek ve bu böyle "
"devam edecektir. En az bir sunucu seçilmelidir. Onu seçmek için bir sunucuya "
"tıklayın."

#. Tag: para
#: index.docbook:667
#, no-c-format
msgid ""
"Use these buttons to <guibutton>Add</guibutton> a server, <guibutton>Edit</"
"guibutton> a highlighted server, or <guibutton>Delete</guibutton> a "
"highlighted server. You can also adjust the order of the server list and "
"therefore the order of connection attempts."
msgstr ""
"Bu düğmeleri bir sunucu <guibutton>Ekle</guibutton> mek, seçilmiş bir "
"sunucuyu <guibutton> Düzenle</guibutton> mek, veya <guibutton>Sil</"
"guibutton> mek için kullanın. Ayrıca, sunucu listelerini ve bağlantı "
"denemelerini sıraya koyabilirsiniz."

#. Tag: para
#: index.docbook:672
#, no-c-format
msgid ""
"Optional. This is a list of the channels that will be automatically joined "
"once &konversation; has connected to a server. You may leave this blank if "
"you wish to not automatically join any channels."
msgstr ""
"İsteğe bağlı. Bu &konversation; uygulaması bir kez sunucuya bağlandıktan "
"sonra kanalların otomatik olarak listelenmesini sağlar. Eğer herhangi bir "
"kanala otomatik olarak bağlanmak istemiyorsanız burayı boş bırakabilirsiniz."

#. Tag: para
#: index.docbook:676
#, no-c-format
msgid ""
"Use these buttons to <guibutton>Add</guibutton> a channel, <guibutton>Edit</"
"guibutton> a highlighted channel, or <guibutton>Delete</guibutton> a "
"highlighted channel. You may also change the order the channels are joined."
msgstr ""
"Bu düğmeleri bir kanal <guibutton>Ekle</guibutton> mek için, seçilmiş bir "
"kanalı <guibutton>Düzenle</guibutton> mek için veya  seçilmiş bir kanalı "
"<guibutton>Sil</guibutton> mek için kullanın. Ayrıca, girilmiş kanalların "
"sıralamasını değiştirebilirsiniz."

#. Tag: para
#: index.docbook:684
#, no-c-format
msgid ""
"Avoid mixing servers on different &irc; networks under the same "
"<guilabel>Network</guilabel>. Avoid entering the same server under two "
"different <guilabel>Network</guilabel>s. Otherwise, <link linkend="
"\"nicksonline\">monitoring of online &i18n-nickname;s</link> will not "
"function correctly."
msgstr ""
"Aynı <guilabel>Ağ</guilabel> içinde farklı &irc; ağların sunucusunu "
"karıştırmaktan uzak durunuz. Aynı sunucu içinde iki farklı <guilabel>Ağ</"
"guilabel>ı girmekten kaçınınız. Aksi taktirde, <link linkend=\"nicksonline"
"\">bağlı olan &i18n-nickname;'leri görüntelemeniz</link> doğru "
"çalışmayacaktır."

#. Tag: para
#: index.docbook:692
#, no-c-format
msgid ""
"When you click the <guibutton>Add</guibutton> button in the "
"<guilabel>Servers</guilabel> frame, the <guilabel>Add Server</guilabel> "
"screen appears."
msgstr ""
"<guilabel>Sunucular</guilabel> çerçevesinde <guibutton>Ekle</guibutton> "
"düğmesine tıkladığınızda, <guilabel>Sunucu Ekle</guilabel> ekranı gözükür."

#. Tag: screeninfo
#: index.docbook:696
#, no-c-format
msgid "<screeninfo>Add Server</screeninfo>"
msgstr "<screeninfo>Sunucu Ekle</screeninfo>"

#. Tag: phrase
#: index.docbook:710
#, no-c-format
msgid "<phrase>Add Server</phrase>"
msgstr "<phrase>Sunucu Ekle</phrase>"

#. Tag: para
#: index.docbook:718
#, fuzzy, no-c-format
#| msgid ""
#| "The name or IP number of the server. irchelp.org maintains a <ulink url="
#| "\"http://www.irchelp.org/irchelp/networks/\">list</ulink> of servers."
msgid ""
"The name or IP number of the server. irchelp.org maintains a <ulink url="
"\"https://www.irchelp.org/networks/\">list</ulink> of servers."
msgstr ""
"Sunucudaki IP numarasının ismi. irchelp.org sunucuların bir <ulink url="
"\"http://www.irchelp.org/irchelp/networks/\">liste</ulink> sini sağlar."

#. Tag: para
#: index.docbook:720
#, no-c-format
msgid ""
"Enter the port number required to connect to the server. For most servers, "
"this should be <userinput>6667</userinput>."
msgstr ""
"Sunucuya bağlanmak için gerekli olan port numarasını girin. Sunucların çoğu "
"için, bu numara <userinput>6667</userinput> olmalıdır."

#. Tag: para
#: index.docbook:721
#, no-c-format
msgid ""
"If the server requires a password in order to connect, enter it here, "
"otherwise leave blank."
msgstr ""
"Eğer bir sunucu bağlanmak için bir parola isterse, onu buraya girin, yoksa "
"boş bırakın."

#. Tag: para
#: index.docbook:723
#, no-c-format
msgid ""
"Check if you want to use Secure Socket Layer (SSL) protocol to communicate "
"with the server. This protects the privacy of your communications between "
"your computer and the &irc; server. The server must support SSL protocol for "
"this to work. In most cases, if the server does not support SSL, the "
"connection will fail."
msgstr ""
"Eğer sunucu ile iletişim kururken Güvenli Yuva Katmanı (SSL) protokolünü "
"kullanmak istiyorsanız seçin. Bu bilgisayarınız ile &irc; sunucusu "
"arasındaki bağlantıların güvenliğini korur. Sunucunun bunun için SSL "
"protokolünü desteklemesi gerekir. Çoğu durumda, eğer sunucu SSL desteği "
"vermiyor ise, bağlantı başarısız olacaktır."

#. Tag: para
#: index.docbook:734
#, no-c-format
msgid ""
"When you click the <guibutton>Add</guibutton> button in the <guilabel>Auto "
"Join Channels</guilabel> frame, the <guilabel>Add Channel</guilabel> screen "
"appears."
msgstr ""
"<guibutton>Ekle</guibutton> düğmesini  <guilabel>Kanallara Otomatik Katıl</"
"guilabel> pencerinden tıkladığınızda, <guilabel>Kanal Ekle</guilabel> ekranı "
"gözükür."

#. Tag: screeninfo
#: index.docbook:740
#, no-c-format
msgid "<screeninfo>Add Channel</screeninfo>"
msgstr "<screeninfo>Kanal Ekle</screeninfo>"

#. Tag: phrase
#: index.docbook:746
#, no-c-format
msgid "<phrase>Add Channel</phrase>"
msgstr "<phrase>Kanal Ekle</phrase>"

#. Tag: para
#: index.docbook:752
#, no-c-format
msgid ""
"Enter a channel name. Do not forget leading <userinput><replaceable>#</"
"replaceable></userinput>. If the channel requires a password in order to "
"join, enter it, otherwise leave blank."
msgstr ""
"Bir kanal ismi girin. İlk harfi büyük girmeyi unutmayın. "
"<userinput><replaceable>#</replaceable></userinput>. Eğer katılırken kanal "
"bir parola gerektirirse girin, ya da boş bırakın."

#. Tag: title
#: index.docbook:761
#, no-c-format
msgid "Listing available channels"
msgstr "Uygun kanalları listeliyor"

# u#, no-c-format
#. Tag: para
#: index.docbook:763
#, no-c-format
msgid ""
"To display a list of available channels, choose <menuchoice> "
"<guisubmenu>Window</guisubmenu> <guisubmenu>Channel List</guisubmenu> </"
"menuchoice> on the main menu. <action>After a warning screen, a new tab is "
"created called the <guilabel>Channel List</guilabel>.</action>"
msgstr ""
"Uygun kanalları görüntülemek için, ana menüdeki <menuchoice> "
"<guisubmenu>Pencere</guisubmenu> <guisubmenu>Kanal Listesi</guisubmenu> </"
"menuchoice> ögesini seçin. <action>Bir uyarı ekranından sonra, "
"<guilabel>Kanal Listesi</guilabel>.</action>adını taşıyan yeni bir sekme "
"oluşturulur."

#. Tag: screeninfo
#: index.docbook:773
#, no-c-format
msgid "<screeninfo>The Channel List tab.</screeninfo>"
msgstr "<screeninfo>Kanal Listesi sekmesi.</screeninfo>"

#. Tag: phrase
#: index.docbook:789
#, no-c-format
msgid "<phrase>The Channel List tab.</phrase>"
msgstr "<phrase>Kanal Listesi sekmesi.</phrase>"

#. Tag: para
#: index.docbook:798
#, no-c-format
msgid "Enter a filter string here."
msgstr "Buraya bir süzgeç dizgesi girin."

#. Tag: para
#: index.docbook:800
#, no-c-format
msgid ""
"You can limit the channel list to those channels with a minimum or maximum "
"number of users here. Choosing <guilabel>No Limit</guilabel> disables the "
"respective criteria."
msgstr ""
"Kanal listesini en az veya en çok kullanıcı sayısıyla bu kanallarla "
"sınırlayabilirsiniz. <guilabel>Sınır Yok</guilabel> seçildiğinde, ilgili "
"kıstaslar devre dışı bırakılır."

#. Tag: para
#: index.docbook:802
#, no-c-format
msgid ""
"Click here to retrieve the list of channels from the server and apply the "
"filter."
msgstr ""
"Sunucudan kanallara erişmek ve süzgeci uygulamak amacıyla kanallara erişmek "
"için buraya tıklayın."

#. Tag: para
#: index.docbook:804
#, no-c-format
msgid ""
"The filtered list of channels is displayed here. Notice that if you don't "
"use regular expressions, &konversation; lists any channel whose name "
"contains the filter string you entered. The channel name does not have to "
"start with the string you entered."
msgstr ""
"Sınırlanmış kanallar listesi burada görüntülenmiştir. Düzenli ifadeler "
"kullanmazsanız, &konversation; girdiğiniz sınırlandığınız dizgeleri içeren "
"isimlerin listelendiği dikkatinizi çekecektir. Kanal ismi girdiğiniz dizge "
"ile başlamak zorunda değildir."

#. Tag: para
#: index.docbook:806
#, no-c-format
msgid ""
"Select a channel you want to join by clicking on it. Right click on the "
"channel to get a list of all web addresses mentioned in the channel's topic."
msgstr ""
"Katılmak istediğiniz kanalı üzerine tıklayarak seçin. Kanalların özetlerinde "
"belirtilen tüm web adreslerinin listesini görmek için kanala sağ tıklayın."

#. Tag: para
#: index.docbook:808
#, no-c-format
msgid "Click here to join the channel. A new tab is created for the channel."
msgstr ""
"Bir kanala katılmak için buraya tıklayın. Kanal için yeni bir sekme "
"oluşturulur."

#. Tag: para
#: index.docbook:818
#, no-c-format
msgid ""
"Sometimes there are \"secret\" channels on servers. Such channels are not "
"listed in the <guilabel>Channel List</guilabel>. You can still join these "
"channels if you know their name. In any <interface>Input Line</interface>, "
"type: <userinput><command>/join</command> <replaceable>#channelname</"
"replaceable></userinput>. (The <userinput>#</userinput> is required.) A new "
"tab is created for the channel. If you join a channel and the Nick Panel "
"lists only your &i18n-nickname;, it means that the channel did not exist "
"before. The server created the channel and you are the operator. In this "
"case, you probably want to close the channel by typing: <userinput><command>/"
"part</command></userinput>."
msgstr ""
"Bazen sunucularda \"gizli\" kanallar yer alır. Bu tür kanallar "
"<guilabel>Kanal Listesi</guilabel> nde yer almazlar. Yine de eğer isimlerini "
"biliyorsanız bu tür kanallara katılabilirsiniz. Herhangi bir  "
"<interface>Girdi Satırı</interface> noktasında,  <userinput><command>/gir</"
"command> <replaceable>#kanal ismi</replaceable></userinput> yazın. "
"<userinput>#</userinput> gereklidir.) Kanal için yeni bir sekme oluşturulur. "
"Eğer bir kanala katılırsanız ve Takma Ad Paneli sizin &i18n-nickname; "
"görüntülerse, bu kanalın daha önce var olmadığını gösterir. Sunucu bu kanalı "
"yaratmış ve sizde bu kanalın kurucusu olmuşsunuz demektir. Bu durumda, bu "
"durumda büyük ihtimalle <userinput><command>/part</command></userinput> "
"yazarak kanalı kapatmak isteyebilirsiniz."

#. Tag: title
#: index.docbook:828
#, no-c-format
msgid "A tour of the main screen"
msgstr "Ana pencerede bir gezinti"

#. Tag: para
#: index.docbook:830
#, no-c-format
msgid ""
"Let's learn more about the <interface>Main</interface> screen. The screen is "
"shown below with a channel tab selected."
msgstr ""
"<interface>Ana</interface> ekran hakkında daha fazla bilgi edinelim. Seçili "
"bir kanal sekmesi ile birlikte ekran aşağıda görüntülenir."

#. Tag: screeninfo
#: index.docbook:835
#, no-c-format
msgid "The Main screen."
msgstr "Ana ekran."

#. Tag: phrase
#: index.docbook:854
#, no-c-format
msgid "The Main screen"
msgstr "Ana ekran."

#. Tag: para
#: index.docbook:863
#, no-c-format
msgid ""
"This is called the <interface>Input Line</interface>. It appears only when "
"the current tab is a channel. To send a message to everyone in the channel, "
"type the message here and press &Enter;. Your message, as well as everyone "
"else's messages appear in the channel scroll above. Each message is preceded "
"by the time and user's &i18n-nickname;."
msgstr ""
"Buna <interface>Girdi Satırı</interface> denmektedir. Bu sadece şu anki "
"sekme bir kanal ise görüntülenir. Kanaldaki herkese ileti göndermek için, "
"buraya bir ileti girin ve &Enter; tuşuna basın. İletiniz diğerlerinin "
"iletileriyle birlikte yukarıdaki kayan iletiler penceresinde görünür. Her "
"bir ileti, zaman ve kullanıcının &i18n-nickname; bazında sıralanır."

#. Tag: para
#: index.docbook:869
#, no-c-format
msgid ""
"You can also paste text from the clipboard. If the pasted text has more than "
"one line (newlines), a dialog box appears. Edit the text as desired and "
"click <guibutton>OK</guibutton>."
msgstr ""
"Ayrıca, pano’dan metin yapıştırabilirsiniz. Eğer yapıştırılmış metin birden "
"fazla satır içeriorsa, bir ileti kutusu görünür. Metni istenilen şekilde "
"düzenleyin ve <guibutton>OK</guibutton> düğmesini tıklayın."

#. Tag: para
#: index.docbook:873
#, no-c-format
msgid ""
"If the pasted text is longer than 256 characters, or it contains more than "
"one line, a warning message appears advising you that large postings can "
"cause connection resets and flooding. You can still proceed with the input, "
"but doing so is a bad idea, as flooding will annoy other users in the "
"channel, or you may be disconnected from the server. It is better to send "
"the message in shorter chunks."
msgstr ""
"Eğer yapıştırılmış metin 256 karakterden daha uzun ise veya birden fazla "
"satır içeriyorsa, uzun postaların bağlantı yenilenmelerine yol açacağını "
"anımsatan bir uyarı iletisi karşısına çıkar. Siz giriş yapmaya hala devam "
"edebilirsiniz fakat bu kötü bir fikirdir. bu yaptıklarınız kanaldaki diğer "
"kullanıcıları olumsuz etkiler veya sunucu bağlantınız kesilir. Kısa kısa "
"iletiler göndermek daha iyidir."

#. Tag: para
#: index.docbook:883
#, no-c-format
msgid ""
"A convention used in many channels is to precede messages directed at one "
"user with their &i18n-nickname;. &konversation; provides a convenient &i18n-"
"nickname; completion feature. Start typing the user's &i18n-nickname;, then "
"press &Tab;. &konversation; will complete the rest of the user's &i18n-"
"nickname; followed by a colon. To customize the completion feature, choose "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"Konversation</guisubmenu> </menuchoice> from the main menu, expand "
"<guilabel>Behavior</guilabel>, click on <guilabel>General</guilabel>, and "
"select a <guilabel>Completion mode</guilabel>."
msgstr ""
"Birçok kanalda kullanılan bir gelenek, bir kullanıcıya yöneltilen iletilerin "
"&i18n-nickname;'lerinden önce gelmesidir. &konversation;, uygun bir &i18n-"
"nickname; tamamlama özelliği sağlar. Kullanıcının &i18n-nickname;'ini "
"yazmaya başlayın, ardından &Tab; tuşuna basın. &konversation, kullanıcının "
"&i18n-nickname; geri kalanını iki nokta üst üste yazarak tamamlayacaktır. "
"Tamamlama özelliğini özelleştirmek için, ana menüden <menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation Yapılandır</"
"guisubmenu> </menuchoice> ögesini seçin, <guilabel>Davranış</guilabel> "
"ögesini genişletin, <guilabel>Genel</guilabel> ögesine tıklayın ve "
"<guilabel>Tamamlama kipini</guilabel> seçin."

#. Tag: para
#: index.docbook:894
#, no-c-format
msgid ""
"You can also enter an &irc; command here by first typing "
"<userinput><command>/</command></userinput> followed by a valid &irc; "
"command. See <link linkend=\"irc-cmds\">Frequently-used &irc; commands</"
"link>. On some servers, you can type <userinput><command>/help</command></"
"userinput> for a list of available commands, or type <userinput><command>/"
"help </command><replaceable>command</replaceable></userinput> for help on a "
"specific command."
msgstr ""
"<userinput><command>/</command></userinput> yazıp, ardından geçerli bir "
"&irc; komutu yazın. <link linkend=\"irc-cmds\">Sıkça kullanılan &irc; "
"komutları</link> sayfasına gözatabilirsiniz. Bazı sunucularda, "
"kullanılabilir komutları görmek için <userinput><command>/help</command></"
"userinput> yazın veya o komuta özgü yardım almak için <userinput><command>/"
"help </command><replaceable>command</replaceable></userinput> "
"kullanabilirsiniz."

#. Tag: para
#: index.docbook:902
#, no-c-format
msgid ""
"You may join additional servers and channels. Each server and each channel "
"gets a separate tab here. To display a list of available channels, see <link "
"linkend=\"list-channels\">Listing available channels</link>. To join a "
"channel, type: <userinput><command>/join</command> "
"<replaceable>#channelname</replaceable></userinput> in the Input Line. (The "
"<userinput>#</userinput> is required.) To leave a channel, just type "
"<userinput><command>/part</command></userinput>. Tabs also appear here if "
"you open a <link linkend=\"list-channels\">Channel List</link>, participate "
"in a <link linkend=\"query\">private conversation (query)</link>, open the "
"<link linkend=\"urlcatcher\">&URL; Catcher</link>, or open one or more "
"<guilabel>Konsole</guilabel>s. To switch the display to a different screen, "
"click the corresponding tab, or use the mouse wheel to cycle through the "
"tabs."
msgstr ""
"Ek sunuculara ve kanallara üye olabilirsiniz. Her sunucu ve her kanal ayrı "
"bir sekme alır. Kullanılabilir kanalların bir listesini görüntülemek için, "
"<link linkend=\"list-channels\">Kullanılabilir kanalları listelemek</link> "
"bölümüne gözatın. Kanala girmek için Giriş Satırı’na: <userinput><command>/"
"join</command> <replaceable>#kanalismi</replaceable></userinput> (The "
"<userinput>#</userinput> gereklidir.) yazın. Kanaldan çıkmak için, "
"<userinput><command>/part</command></userinput> yazın. <link linkend=\"list-"
"channels\">Kanal Listesi</link> </link> sekmesi etkinleşecektir, <link "
"linkend=\"query\">özel sohbet</link>e katılmak için <link linkend="
"\"urlcatcher\">&URL; Yakalayıcı</link> veya birtane daha  <guilabel>Konsole</"
"guilabel> açın. Ekranı farklı bir ekrana geçirmek için ilgili sekmeye "
"tıklayın veya sekmeleri dolaşmak için fare tekerleğini kullanın."

# u#, no-c-format
#. Tag: para
#: index.docbook:910
#, no-c-format
msgid ""
"To set other options for tabs, choose <menuchoice> <guisubmenu>Settings</"
"guisubmenu> <guisubmenu>Configure Konversation</guisubmenu> </menuchoice> "
"from the main menu, expand <guilabel>Interface</guilabel>, click on "
"<guilabel>Tabs</guilabel> or expand <guilabel>Notifications</guilabel> and "
"click on <guilabel>Tabs</guilabel>."
msgstr ""
"Sekmelerin diğer seçeneklerini ayarlamak için, ana menüden <menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation Yapılandır</"
"guisubmenu> </menuchoice> seçin, <guilabel>Arayüz</guilabel> genişletin, "
"<guilabel>Sekmeler</guilabel> veya <guilabel>Bildirimler</guilabel> menüsüne "
"girin ve <guilabel>Sekmeler</guilabel> bölümüne tıklayın."

#. Tag: para
#: index.docbook:923
#, no-c-format
msgid ""
"These &led;s will blink when there is something you haven't seen in that "
"tab. The &led; will blink slower when the only unseen messages are "
"<command>join</command>, <command>part</command>, <command>quit</command>, "
"or &i18n-nickname; changes. They blink faster if there are unseen regular "
"messages. The colors are as follows:"
msgstr ""
"Bu sekmelerde görmediğiniz bir şey olduğunda bu &led;ler yanıp sönecektir. "
"Yalnızca görünmeyen iletiler <command>join</command>, <command>part</"
"command>, <command>quit</command> veya &i18n-nickname; değişiklikler "
"olduğunda &led; daha yavaş yanıp sönecektir. Görünen düzenli iletiler varsa "
"daha hızlı yanıp söner. Renkler aşağıdaki gibidir:"

#. Tag: para
#: index.docbook:928
#, no-c-format
msgid "<para>Channel</para>"
msgstr "<para>Kanal</para>"

#. Tag: para
#: index.docbook:933
#, no-c-format
msgid ""
"<interface>Server Messages</interface>, <link linkend=\"list-channels"
"\">Channel List</link>, or <link linkend=\"urlcatcher\">&URL; catcher</link>."
msgstr ""
"<interface>Sunucu İletileri</interface>, <link linkend=\"list-channels"
"\">Kanal Listesi</link>, veya <link linkend=\"urlcatcher\">&URL; yakalayıcı</"
"link>."

#. Tag: para
#: index.docbook:939
#, no-c-format
msgid ""
"<guilabel>Konsole</guilabel> or <link linkend=\"dcc\">DCC Status</link>."
msgstr ""
"<guilabel>Konsole</guilabel> veya <link linkend=\"dcc\">DCC Durumu</link>."

#. Tag: para
#: index.docbook:944
#, no-c-format
msgid "<link linkend=\"query\">Private Message (Query)</link>."
msgstr "<link linkend=\"query\">Özel İleti (Sorgu)</link>."

#. Tag: para
#: index.docbook:951
#, no-c-format
msgid ""
"Click here to close the current tab. Closing a <interface>Channel</"
"interface> tab will leave the channel. Closing a <interface>Server Messages</"
"interface> tab will leave all channels you've joined, close all open queries "
"at that server and disconnect from the server."
msgstr ""
"Geçerli sekmeyi kapatmak için buraya tıklayın. <interface>Kanal</interface> "
"sekmesini kapatmak, kanaldan çıkmak demektir. <interface>Sunucu İletileri</"
"interface> sekmesi kapatılınca, katıldığınız tüm kanallardan çıkılacak, "
"sunucudaki tüm açık sorgularınız kapatılacak ve sunucudan bağlantı "
"kesilecektir."

# u#, no-c-format
#. Tag: para
#: index.docbook:953
#, no-c-format
msgid ""
"Click this button to change your own &i18n-nickname;. It appears only when "
"the current tab is a channel. To hide this button, choose <menuchoice> "
"<guisubmenu>Settings</guisubmenu> <guisubmenu>Configure Konversation</"
"guisubmenu> </menuchoice> from the main menu, expand <guilabel>Interface</"
"guilabel>, click on <guilabel>Chat Window</guilabel>, and uncheck "
"<guilabel>Show box to change own nickname</guilabel> box."
msgstr ""
"Kendi &i18n-nickname; adınızı değiştirmek için bu düğmeye tıklayın. Yalnızca "
"geçerli sekme, bir kanal olduğunda görünür. Bu düğmeyi gizlemek için, ana "
"menüden <menuchoice> <guisubmenu>Ayarlar</guisubmenu> "
"<guisubmenu>Konversation Yapılandır</guisubmenu> </menuchoice> seçin, "
"<guilabel>Arayüz</guilabel> menüsünü genişletin, <guilabel>Sohbet Penceresi</"
"guilabel> tıklayın ve <guilabel>Rumuzu değiştirmek için kutuyu göster</"
"guilabel> kutusundaki seçeneği kaldırın."

#. Tag: para
#: index.docbook:961
#, no-c-format
msgid ""
"The channel topic is displayed here. Hover the mouse over the topic to see "
"long topics. You can change the topic by clicking the button to the left of "
"the topic. To hide channel topics, choose <menuchoice> <guisubmenu>Settings</"
"guisubmenu> <guisubmenu>Configure Konversation</guisubmenu> </menuchoice> "
"from the main menu, expand <guilabel>Interface</guilabel>, click on "
"<guilabel>Chat Window</guilabel>, and uncheck the <guilabel>Show channel "
"topic</guilabel> box."
msgstr ""
"Kanal konusu burada görüntülenir. Uzun konuları görmek için fareyi konunun "
"üzerine getirin. Konunun solundaki düğmeye tıklayarak konuyu "
"değiştirebilirsiniz. Kanal konularını gizlemek için ana menüden, "
"<menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation "
"Yapılandır</guisubmenu> </menuchoice> seçin, <guilabel>Arayüz</guilabel> "
"menüsünü genişletin, <guilabel>Sohbet Penceresi</guilabel> tıklayın ve "
"<guilabel>Kanal konusunu göster</guilabel> kutusundaki seçeneği kaldırın."

#. Tag: para
#: index.docbook:972
#, no-c-format
msgid ""
"These buttons display the current state of channel modes. A button is down "
"if that mode is on. If you have the correct privileges, you can also change "
"channel modes by clicking on these buttons, or click the button to the left "
"of the topic. To hide channel mode buttons, choose <menuchoice> "
"<guisubmenu>Settings</guisubmenu> <guisubmenu>Configure Konversation</"
"guisubmenu> </menuchoice> from the main menu, expand <guilabel>Interface</"
"guilabel>, click on <guilabel>Chat Window</guilabel>, and uncheck the "
"<guilabel>Show channel mode buttons</guilabel> box."
msgstr ""
"Bu düğmeler, kanal kiplerinin geçerli durumunu görüntüler. Bu kip açıksa bir "
"düğme kapalıdır. Doğru haklarınız varsa, bu düğmelere tıklayarak kanal "
"kiplerini değiştirebilir veya konunun solundaki düğmeye tıklayabilirsiniz. "
"Kanal kipi düğmelerini gizlemek için, <menuchoice> <guisubmenu>Ayarlar</"
"guisubmenu> <guisubmenu>Konversation Yapılandır</guisubmenu> </menuchoice> "
"seçin, <guilabel>Arayüz</guilabel> menüsünü genişletin, <guilabel>Sohbet "
"Penceresi</guilabel> tıklayın ve <guilabel>Kanal kipi düğmelerini göster</"
"guilabel> kutusundaki seçeneği kaldırın."

#. Tag: para
#: index.docbook:983
#, no-c-format
msgid ""
"This is called the <interface>Nick Panel</interface>. It is displayed "
"whenever the current tab is a channel. It lists the &i18n-nickname;s of all "
"the users who have joined the channel, including yourself. Hover the mouse "
"pointer over a &i18n-nickname; to display additional information about the "
"user. You may change how the icons are displayed next to each &i18n-"
"nickname; by changing the &i18n-nickname; icon theme. See <link linkend="
"\"nickthemes\">Configuring &i18n-nickname; themes</link> for more "
"information. The <guilabel>Default Theme</guilabel>, as shown in the screen "
"above, uses the following icons:"
msgstr ""
"Buna, <interface>Rumuz Paneli</interface> adı verilir. Geçerli sekme bir "
"kanal olduğunda görüntülenecektir. Kanalınıza kendiniz de dahil olmak üzere "
"katılan tüm kullanıcıların &i18n-nickname; listeler. Kullanıcı hakkında ek "
"bilgileri görüntülemek için fare işaretçisini bir &i18n-nickname; üzerine "
"getirin. Simgelerin, &i18n-nickname; simgesi temasını değiştirerek, her bir "
"&i18n-nickname; yanında nasıl gösterileceğini değiştirebilirsiniz. Daha "
"fazla bilgi için <link linkend=\"nickthemes\">&i18n-nickname; temalarını "
"yapılandırma</link> konusuna bakın. Yukarıdaki ekranda gösterildiği gibi "
"<guilabel>Varsayılan Tema</guilabel>, aşağıdaki simgeleri kullanır:"

#. Tag: para
#: index.docbook:992
#, no-c-format
msgid "normal user"
msgstr "normal user"

#. Tag: para
#: index.docbook:998
#, no-c-format
msgid "voiced user. User may talk in a moderated channel."
msgstr "voiced user. Kullanıcı moderatörlü bir kanalda konuşabilir."

#. Tag: para
#: index.docbook:1004
#, no-c-format
msgid "channel halfop"
msgstr "channel halfop"

#. Tag: para
#: index.docbook:1010
#, no-c-format
msgid "channel operator"
msgstr "channel operator"

#. Tag: para
#: index.docbook:1016
#, no-c-format
msgid "channel owner"
msgstr "channel owner"

#. Tag: para
#: index.docbook:1022
#, no-c-format
msgid "channel admin"
msgstr "channel admin"

#. Tag: para
#: index.docbook:1030
#, no-c-format
msgid ""
"In addition, if a user is away, a small clock will be drawn in the corner of "
"the icon."
msgstr ""
"Buna ek olarak, bir kullanıcı uzaktaysa, simgenin köşesinde küçük bir saat "
"çizilir."

#. Tag: para
#: index.docbook:1033
#, no-c-format
msgid ""
"Click with the &RMB; on any &i18n-nickname; to display a context menu of "
"operations you can perform with that &i18n-nickname;. For example, you can "
"<link linkend=\"dcc\">send a file</link> to the &i18n-nickname;."
msgstr ""
"Bu &i18n-nickname; ile gerçekleştirebileceğiniz işlemlerin bir bağlam menüsü "
"görüntülemek için herhangi bir &i18n-nickname; üzerine &RMB; tıklayın. "
"Örneğin, &i18n-nickname; <link linkend=\"dcc\">dosya gönder</link> "
"yapabilirsiniz."

# u#, no-c-format
#. Tag: para
#: index.docbook:1038
#, no-c-format
msgid ""
"To hide the <interface>Nick Panel</interface>, choose <menuchoice> "
"<guisubmenu>Settings</guisubmenu> <guisubmenu>Show Nicklist</guisubmenu> </"
"menuchoice> from the main menu."
msgstr ""
"<interface>Rumuz Paneli</interface>ni gizlemek için, ana menüden "
"<menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Rumuz Listesini "
"Göster</guisubmenu> </menuchoice> ögesini seçin."

#. Tag: para
#: index.docbook:1047
#, no-c-format
msgid ""
"These are called the <interface>Quick Buttons</interface>. By default, they "
"are not shown. To display them, see <link linkend=\"quick-buttons"
"\">Configuring Quick Buttons</link>. You can customize their definitions to "
"whatever commands you wish."
msgstr ""
"Bunlara <interface>Hızlı Düğmeler</interface> adı verilir. Varsayılan "
"olarak, gösterilmezler. Bunları görüntülemek için <link linkend=\"quick-"
"buttons\">Hızlı Düğmeleri Yapılandırma</link> konusuna bakın. Tanımlarını "
"istediklerinize göre özelleştirebilirsiniz."

#. Tag: para
#: index.docbook:1056
#, no-c-format
msgid ""
"You can control how messages are displayed in the message scroll of channel "
"and query tabs. For example, you can change the color of messages, play a "
"sound when a message containing a string is received, or automatically reply "
"to messages. See <link linkend=\"highlighting\"> Message highlighting</link> "
"for more information."
msgstr ""
"İletilerin kanal ve sorgu sekmelerinin ileti kaydırmasında nasıl "
"gösterileceğini kontrol edebilirsiniz. Örneğin, bir dizge içeren ileti "
"alındığında iletileri rengini değiştirebilir, ses çalabilir veya iletileri "
"otomatik olarak cevaplayabilirsiniz. Daha fazla bilgi için <link linkend="
"\"highlighting\">İleti vurgulama</link> bölümüne bakın."

#. Tag: para
#: index.docbook:1067
#, no-c-format
msgid ""
"Channel names sometimes begin with <userinput>&amp;</userinput>, "
"<userinput>&plus;</userinput>, or <userinput>!</userinput>. The first "
"character of a channel name determines the type of channel (RFC 2811) as "
"follows: <itemizedlist> <listitem><para> <userinput>#</userinput> - Regular "
"channels. </para></listitem> <listitem><para> <userinput>!</userinput> - "
"Regular channels. </para></listitem> <listitem><para> <userinput>&amp;</"
"userinput> - Local. Channels that can only be joined from the server hosting "
"the channel. All other channels can be joined from any server in the "
"network. </para></listitem> <listitem><para> <userinput>&plus;</userinput> - "
"Channels that do not support channel modes. This means that all the modes "
"are unset, with the exception of the 't' channel flag which is set. </para></"
"listitem> </itemizedlist> Channel names are up to 50 characters long and may "
"contain any characters except for space, comma, and Ctrl-G (^G or ASCII 7)."
msgstr ""
"Kanal isimleri bazen <userinput>&amp;</userinput>, <userinput>&plus;</"
"userinput>, veya <userinput>!</userinput> ile başlarlar. Kanal isminin ilk "
"karakteri, aşağıda belirtilen kanal türlerini (RFC 2811) tanımlar. "
"<itemizedlist> <listitem><para> <userinput>#</userinput> - Normal kanallar. "
"</para></listitem> <listitem><para> <userinput>!</userinput> - Normal "
"kanallar. </para></listitem> <listitem><para> <userinput>&amp;</userinput> - "
"Yerel. Kanalı barındıran sunucudan yalnızca girilen kanallar. Diğer tüm "
"kanallar ağdaki herhangi bir sunucudan girilebilir. </para></listitem> "
"<listitem><para> <userinput>&plus;</userinput> - Kanal kiplerini "
"desteklemeyen kanallar. Bu, ayarlanan 't' kanal bayrağı hariç, tüm kiplerin "
"ayarlanmadığı anlamına gelir. </para> </listitem> </itemizedlist> Kanal "
"isimleri en fazla 50 karakter uzunluğunda ve boşluk, virgül ve Ctrl-G (^G ya "
"da ADCII 7) haricinde herhangi bir karakter içerebilir."

#. Tag: title
#: index.docbook:1095
#, no-c-format
msgid "Quick Connect"
msgstr "Hızlı Bağlan"

#. Tag: para
#: index.docbook:1097
#, no-c-format
msgid ""
"Sometimes you want to connect to a server without going through the trouble "
"of creating a new server in the <link linkend=\"serverlist\">Server List</"
"link>."
msgstr ""
"Bazen, <link linkend=\"serverlist\">Sunucu Listesi</link> içinde yeni bir "
"sunucu oluşturmada sorun yaşanmadan bir sunucuya bağlanmak istersiniz"

#. Tag: para
#: index.docbook:1101
#, no-c-format
msgid ""
"Choose <menuchoice> <guisubmenu>File</guisubmenu> <guisubmenu>Quick Connect</"
"guisubmenu> </menuchoice> on the main menu. <action>The <guilabel>Quick "
"Connect</guilabel> screen will appear.</action>"
msgstr ""
"Ana menüden <menuchoice> <guisubmenu>Dosya</guisubmenu> <guisubmenu>Hızlı "
"Bağlan</guisubmenu> </menuchoice> ögesini seçin. <action>The <guilabel>Hızlı "
"Bağlan</guilabel> ekranı gözükecektir.</action>"

#. Tag: screeninfo
#: index.docbook:1111
#, no-c-format
msgid "The Quick Connect screen."
msgstr "Hızlı Bağlan ekranı."

#. Tag: phrase
#: index.docbook:1117
#, no-c-format
msgid "The Quick Connect screen"
msgstr "Hızlı Bağlan ekranı"

#. Tag: para
#: index.docbook:1123
#, no-c-format
msgid ""
"Enter the server address in the <guilabel>Server host</guilabel> box, your "
"desired &i18n-nickname; in the <guilabel>Nick</guilabel> box, and click the "
"<guibutton>Connect</guibutton> button. When &konversation; has connected to "
"the server, enter command <userinput><command>/join</command> "
"<replaceable>#channelname</replaceable></userinput> to join a channel."
msgstr ""
"Sunucu adresini <guilabel>Sunucu makinesi</guilabel> kutusuna girin, "
"istediğiniz &i18n-nickname; <guilabel>Rumuz</guilabel> kutusuna yazın ve "
"<guibutton>Bağlan</guibutton> düğmesine tıklayın. &konversation; sunucuya "
"bağlandığında, kanala girmek için <userinput><command>/join</command> "
"<replaceable>#kanalismi</replaceable></userinput> komutunu kullanın."

#. Tag: title
#: index.docbook:1135
#, no-c-format
msgid "Frequently-used &irc; commands"
msgstr "Sıklıkla kullanılan &irc; komutları"

#. Tag: para
#: index.docbook:1137
#, fuzzy, no-c-format
#| msgid ""
#| "The following is a short list of frequently-used &irc; commands. See "
#| "<ulink url=\"http://www.faqs.org/rfcs/rfc2812.html\">RFC 2812</ulink> for "
#| "a complete list of all commands, or visit <ulink url=\"http://www.irchelp."
#| "org/\">irchelp.org</ulink>. For a list of commands treated specially by "
#| "&konversation;, see <link linkend=\"konvi-cmds\">&konversation; commands</"
#| "link>."
msgid ""
"The following is a short list of frequently-used &irc; commands. See <ulink "
"url=\"http://www.faqs.org/rfcs/rfc2812.html\">RFC 2812</ulink> for a "
"complete list of all commands, or visit <ulink url=\"https://www.irchelp.org/"
"\">irchelp.org</ulink>. For a list of commands treated specially by "
"&konversation;, see <link linkend=\"konvi-cmds\">&konversation; commands</"
"link>."
msgstr ""
"Aşağıda sıklıkla kullanılan &irc; komutlarının ufak bir listesi vardır. Tüm "
"komutların listesini görmek için <ulink url=\"http://www.faqs.org/rfcs/"
"rfc2812.html\">RFC 2812</ulink> adresine bakın veya <ulink url=\"http://www."
"irchelp.org/\">irchelp.org</ulink> adresine gözatın. &konversation; için "
"özel olarak işlenen komutları <link linkend=\"konvi-cmds\">&konversation; "
"komutları</link> bölümünde bulabilirsiniz."

#. Tag: para
#: index.docbook:1147
#, no-c-format
msgid ""
"Lists commands available on the current server. Not supported by all servers."
msgstr ""
"Geçerli sunucuda bulunan komutları listeler. Tüm sunucular tarafından "
"desteklenmez."

#. Tag: userinput
#: index.docbook:1151
#, no-c-format
msgid "<command>/help </command><replaceable>cmd</replaceable>"
msgstr "<command>/help </command><replaceable>komut</replaceable>"

#. Tag: para
#: index.docbook:1152
#, no-c-format
msgid ""
"Provides help for <userinput><replaceable>cmd</replaceable></userinput>. Not "
"supported by all servers."
msgstr ""
"<userinput><replaceable>komut</replaceable></userinput> için yardım sağlar. "
"Tüm sunucularda desteklenmez."

#. Tag: command
#: index.docbook:1156
#, no-c-format
msgid "/join <replaceable>#channel</replaceable>"
msgstr "/join <replaceable>#kanal</replaceable>"

#. Tag: para
#: index.docbook:1157
#, no-c-format
msgid ""
"Joins <userinput><replaceable>#channel</replaceable></userinput>. If the "
"channel does not already exist, it is created and you are the channel "
"operator."
msgstr ""
"<userinput><replaceable>#kanal</replaceable></userinput> katılır. Kanal "
"mevcut değilse, yaratır ve sizi kanalın operatörü yapar."

#. Tag: para
#: index.docbook:1162
#, no-c-format
msgid ""
"Leaves the current channel and closes the <interface>channel</interface> tab."
msgstr ""
"<interface>kanal</interface> sekmesini kapatır ve geçerli kanaldan çıkar."

#. Tag: userinput
#: index.docbook:1166
#, no-c-format
msgid "<command>/part </command> <replaceable>#channel</replaceable>"
msgstr "<command>/part </command> <replaceable>#kanal</replaceable>"

#. Tag: para
#: index.docbook:1167
#, no-c-format
msgid ""
"Leaves <userinput><replaceable>#channel</replaceable></userinput> and closes "
"the corresponding <interface>channel</interface> tab. Synonym for "
"<userinput><command>/leave</command></userinput>"
msgstr ""
"<userinput><replaceable>#kanal</replaceable></userinput> üzerinden çıkar ve "
"ilgili sekmeyi kapatır. <userinput><command>/leave</command></userinput> ile "
"aynı işi yapmaktadır."

#. Tag: userinput
#: index.docbook:1172
#, no-c-format
msgid "<command>/me </command><replaceable>msg</replaceable>"
msgstr "<command>/me </command><replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:1173 index.docbook:2251
#, no-c-format
msgid ""
"Sends <userinput><replaceable>msg</replaceable></userinput> to the channel "
"preceded by your &i18n-nickname;. For example, if your &i18n-nickname; were "
"<userinput><replaceable>Tux</replaceable></userinput>, typing "
"<userinput><replaceable>/me brews a cup a tea.</replaceable></userinput> "
"displays the message <interface>Tux brews a cup of tea.</interface> Unless "
"they've filtered against these types of messages, all users see it. This "
"kind of message is typically used to convey non-verbal information, such as "
"your current emotional state, or what you are physically doing. If you are "
"leaving your workstation for a short time, use the <userinput><command>/"
"away</command></userinput> command instead."
msgstr ""
"&i18n-nickname; önündeki kanala <userinput><replaceable>ileti</replaceable></"
"userinput> gönderir. Örneğin, &i18n-nickname; <userinput><replaceable>Tux</"
"replaceable></userinput> olsun, <userinput><replaceable>/me bir bardak çay "
"getir.</replaceable></userinput>, <interface>Tux bir bardak çay getir.</"
"interface> olarak görüntülencektir. Bu tür iletilere karşı süzgeç "
"yapmadıkça, tüm kullanıcılar bunu görür. Bu tür bir ileti tipik olarak şu "
"anki duygusal durumunuz ya da fiziksel olarak ne yaptığınız gibi sözsüz "
"bilgileri aktarmak için kullanılır. İş istasyonunuzu kısa süre terk "
"ederseniz, <userinput><command>/away</command></userinput> komutunu kullanın."

#. Tag: userinput
#: index.docbook:1178
#, no-c-format
msgid "<command>/away </command> <replaceable>msg</replaceable>"
msgstr "<command>/away </command> <replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:1179
#, no-c-format
msgid ""
"If anyone tries to send you a private message or invite you to a channel, "
"they will be told that you are away from your workstation with "
"<userinput><replaceable>msg</replaceable></userinput>."
msgstr ""
"Herkes size özel bir ileti göndermeye çalışırsa veya sizi bir kanala davet "
"ettiyse, size iş istasyonunuzdan uzak olduğunuzu "
"<userinput><replaceable>ileti</replaceable></userinput> ile bildirirler."

#. Tag: para
#: index.docbook:1185
#, no-c-format
msgid ""
"Cancels an <userinput><command>/away </command> <replaceable>msg</"
"replaceable></userinput> command."
msgstr ""
"<userinput><command>/away </command> <replaceable>ileti</replaceable></"
"userinput>komutunu iptal eder."

#. Tag: userinput
#: index.docbook:1189 index.docbook:2301
#, no-c-format
msgid "<command>/query </command><replaceable>nick</replaceable>"
msgstr "<command>/query </command><replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:1190
#, no-c-format
msgid ""
"Creates a new tab with the user's <userinput><replaceable>nick</"
"replaceable></userinput> for private conversation, commonly known on &irc; "
"as a <link linkend=\"query\">Query</link>. Everything written here is only "
"visible to you and your query partner."
msgstr ""
"Özel görüşme için, kullanılan <userinput><replaceable>rumuz</replaceable></"
"userinput> ile yeni bir sekme oluşturur. &irc; üzerinde genellikle <link "
"linkend=\"query\">Sorgu</link> olarak bilinir. Burada yazılan her şey "
"yalnızca siz ve sorgu iş ortağınız tarafından görülebilir."

#. Tag: userinput
#: index.docbook:1194
#, no-c-format
msgid ""
"<command>/msg </command><replaceable>nick</replaceable> <replaceable>msg</"
"replaceable>"
msgstr ""
"<command>/msg </command><replaceable>rumuz</replaceable> <replaceable>ileti</"
"replaceable>"

#. Tag: para
#: index.docbook:1195
#, no-c-format
msgid ""
"Sends <userinput><replaceable>msg</replaceable></userinput> to the user with "
"&i18n-nickname; <userinput><replaceable>nick</replaceable></userinput>. Only "
"<userinput><replaceable>nick</replaceable></userinput> sees the message. Use "
"<userinput><command>/query</command></userinput> for longer conversations."
msgstr ""
"&i18n-nickname; <userinput><replaceable>rumuz</replaceable></userinput> "
"kullanan kullanıcıya, <userinput><replaceable>ileti</replaceable></"
"userinput> gönderir."

#. Tag: userinput
#: index.docbook:1201
#, no-c-format
msgid "<command>/invite </command><replaceable>nick</replaceable>"
msgstr "<command>/invite </command><replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:1202
#, no-c-format
msgid ""
"Invites the user with &i18n-nickname; <userinput><replaceable>nick</"
"replaceable></userinput> to join a channel. This command is especially "
"useful if the channel is invite-only."
msgstr ""
"&i18n-nickname; <userinput><replaceable>rumuz</replaceable></userinput> "
"kullanıcına, bir kanal daveti gönderir. Bu komut, özellikle davetle çalışan "
"kanallar içindir."

#. Tag: title
#: index.docbook:1213
#, no-c-format
msgid "Private conversations (queries)"
msgstr "Özel Sohbetler (sorgular)"

#. Tag: para
#: index.docbook:1215
#, no-c-format
msgid ""
"A private conversation is one that only you and one other person can see. "
"Private conversations are called \"queries\" in &konversation;. To initiate "
"a private conversation, type <userinput><command>/query </"
"command><replaceable>nick</replaceable></userinput> in any input line, where "
"<replaceable>nick</replaceable> is the &i18n-nickname; of the person you "
"want to talk with. You can also click with the &RMB; on the person's &i18n-"
"nickname; in the <interface>Nick Panel</interface> and choose <menuchoice> "
"<guisubmenu>Open Query</guisubmenu> </menuchoice>. <action>A new tab will be "
"created.</action> Announce yourself by sending a message."
msgstr ""
"Özel bir konuşma, yalnızca sizin ve bir kişinin görebileceği konuşmalardır. "
"Özel görüşmelere &konversasyon;'da \"sorgular\" denmektedir. Özel sohbet "
"başlatmak için konuşmak istedğiniz &i18n-nickname; kişisi için giriş "
"satırına <userinput><command>/query </command><replaceable>rumuz</"
"replaceable></userinput> girin. Ayrıca <interface>Rumuz Paneli</interface> "
"üzerinde kullanıcın &i18n-nickname; üzerine &RMB; ile tıklayabilirsiniz ve "
"<menuchoice> <guisubmenu>Sorgu Aç</guisubmenu> </menuchoice> seçebilirsiniz. "
"<action>Yeni bir sekme oluşturuldu</action> olarak kendinize bir ileti "
"gönderin."

#. Tag: para
#: index.docbook:1226
#, no-c-format
msgid ""
"Queries are just like channels, except that only you and the other person "
"can participate in the channel."
msgstr ""
"Sorgular kanallar gibidir, yalnızca siz ve diğer kişi kanalda yer alabilir."

#. Tag: para
#: index.docbook:1229
#, no-c-format
msgid ""
"To leave the query, just close the tab. Note however, that if the other "
"person sends you another message in the query, the tab will open again."
msgstr ""
"Sorgudan çıkmak için, sekmeyi kapatmanız yeterlidir. Bununla birlikte, diğer "
"kişi size sorguda başka bir ileti gönderirse, sekme tekrar açılacaktır."

# u#, no-c-format
#. Tag: para
#: index.docbook:1232
#, no-c-format
msgid ""
"To leave all queries, choose <menuchoice> <guisubmenu>Window</guisubmenu> "
"<guisubmenu>Close All Open Queries</guisubmenu> </menuchoice> on the main "
"menu, or press <keycap>F11</keycap> key."
msgstr ""
"Sorgulardan çıkmak için ana menüden <menuchoice> <guisubmenu>Pencere</"
"guisubmenu> <guisubmenu>Tüm Açık Sorguları Kapat</guisubmenu> </menuchoice> "
"ögesini seçebilir veya <keycap>F11</keycap> tuşuna basabilirsiniz."

#. Tag: para
#: index.docbook:1239
#, no-c-format
msgid ""
"When someone else initiates a query with you, &konversation; creates a new "
"tab with their &i18n-nickname;. If you don't wish to talk with the person, "
"close the tab."
msgstr ""
"Bir başkası sizinle bir sorgu başlattığında, &konversation; &i18n-nickname; "
"olarak yeni bir sekme oluşturur. Kişiyle konuşmak istemiyorsanız, sekmeyi "
"kapatın."

#. Tag: title
#: index.docbook:1249
#, no-c-format
msgid "Setting notifications"
msgstr "Bildirim ayarları"

#. Tag: para
#: index.docbook:1251
#, no-c-format
msgid ""
"<guilabel>Notifications</guilabel> are actions that &konversation; will "
"perform whenever an event occurs. Suppose you have &konversation; running, "
"but minimized or hidden behind other application windows on your desktop. If "
"someone wants to communicate with you, or your buddy joins a channel, you'd "
"like to be alerted. Notifications will accomplish this."
msgstr ""
"<guilabel>Bildirimler</guilabel>, bir olay oluştuğunda &konversation;'ın "
"gerçekleştireceği işlemlerdir. &konversation; çalışıyor, ancak simge "
"durumuna küçültülmüş halde veya masaüstünüzdeki diğer uygulama "
"pencerelerinin arkasında gizlendiğini varsayalım. Birisi sizinle iletişim "
"kurmak isterse veya arkadaşınız bir kanala katılırsa, sizi uyarmasını "
"istersiniz. Bildirimler bunu başaracaktır."

#. Tag: para
#: index.docbook:1255
#, no-c-format
msgid ""
"To configure notifications, choose <menuchoice> <guisubmenu>Settings</"
"guisubmenu> <guisubmenu>Configure Notifications</guisubmenu> </menuchoice> "
"on the main menu. <action>The <guilabel>Notification Settings</guilabel> "
"screen will appear.</action>"
msgstr ""
"Bildirimleri yapılandırmak için, ana menüden <menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Bildirimleri Yapılandır</"
"guisubmenu> </menuchoice> ögesini seçin. <action><guilabel>Bildirim "
"Ayarları</guilabel> ekranı görünecektir.</action>"

#. Tag: screeninfo
#: index.docbook:1266
#, no-c-format
msgid "The Notification Settings screen."
msgstr "Bildirim Ayarları ekranı."

#. Tag: phrase
#: index.docbook:1278
#, no-c-format
msgid "The Notification Settings screen"
msgstr "Bildirim Ayarları ekranı"

#. Tag: para
#: index.docbook:1287
#, no-c-format
msgid "Click here to select an event."
msgstr "Bir etkinlik seçmek için buraya tıklayın."

#. Tag: para
#: index.docbook:1289
#, no-c-format
msgid ""
"Check the types of notifications you'd like to happen when the event occurs. "
"(<guilabel>Mark taskbar entry</guilabel> causes the entry in the taskbar to "
"flash when the event occurs.)"
msgstr ""
"Etkinlik meydana geldiğinde gerçekleşmesini istediğiniz bildirim türlerini "
"kontrol edin. (<guilabel>Görev çubuğu girdisini işaretlemek</guilabel>, olay "
"meydana geldiğinde görev çubuğundaki girdinin yanıp sönmesine neden olur.)"

#. Tag: para
#: index.docbook:1294
#, no-c-format
msgid ""
"Repeat by selecting another event and checking the notifications desired. "
"When you've configured all the desired notifications, click the "
"<guibutton>OK</guibutton> button."
msgstr ""
"Başka bir etkinlik seçerek ve istenen bildirimleri kontrol ederek "
"tekrarlayın. İstediğiniz tüm bildirimleri yapılandırdıktan sonra, "
"<guibutton>Tamam</guibutton> düğmesine tıklayın."

# u#, no-c-format
#. Tag: para
#: index.docbook:1296
#, no-c-format
msgid ""
"Once you've set up your notifications, you can enable or disable all "
"notifications using <menuchoice> <guisubmenu>Window</guisubmenu> "
"<guisubmenu>Enable Notifications</guisubmenu> </menuchoice> on the main menu."
msgstr ""
"Bildirimleri ayarladıktan sonra, ana menüdeki <menuchoice> "
"<guisubmenu>Pencere</guisubmenu> <guisubmenu>Bildirimleri Etkinleştir</"
"guisubmenu> </menuchoice> ögesini kullanarak, açıp kapatabilirsiniz."

#. Tag: para
#: index.docbook:1304
#, no-c-format
msgid ""
"You can also alert yourself when someone mentions your &i18n-nickname; in a "
"message using &konversation;'s <link linkend=\"highlighting\">highlighting "
"feature</link>."
msgstr ""
"Birisi, bir iletide &konversation; <link linkend=\"highlighting\">vurgulama "
"özelliği</link> kullanarak &i18n-nickname; bahsederken kendinizi de "
"uyarabilirsiniz."

#. Tag: title
#: index.docbook:1313
#, no-c-format
msgid "Monitoring who is online"
msgstr "Kimin çevrimiçi olduğunu izleme"

#. Tag: para
#: index.docbook:1315
#, no-c-format
msgid ""
"&konversation; will keep you informed when your buddies are connected to the "
"&irc; network or not."
msgstr ""
"&konversation; arkadaşlarınız &irc; ağına bağlandığında sizi haberdar "
"edecektir."

#. Tag: para
#: index.docbook:1320
#, no-c-format
msgid ""
"The &irc; network is recorded because &i18n-nickname;s are unique across a "
"single &irc; network. The &i18n-nickname; in two different &irc; networks is "
"not necessarily the same person, but the same &i18n-nickname; on two "
"different servers within the same &irc; network generally is the same person."
msgstr ""
"&irc; ağı kaydedilir, çünkü &i18n-nickname;'leri tek bir &irc; ağı boyunca "
"tekillerdir. İki farklı &irc; ağında bulunan &i18n-nickname; aynı kişi "
"olmayabilir, ancak aynı &irc; ağında bulunan iki farklı sunucudaki aynı "
"&i18n-nickname; genellikle aynı kişidir."

#. Tag: para
#: index.docbook:1325
#, no-c-format
msgid ""
"This is why it is important to use the same <guilabel>Network</guilabel> for "
"all servers in the same &irc; network, when <link linkend=\"serverlist\"> "
"defining networks, servers, and auto join channels</link>."
msgstr ""
"Bu nedenle, aynı &irc; ağındaki tüm sunucular için, <link linkend="
"\"serverlist\">ağları, sunucuları ve otomatik kanalları birleştirmeyi "
"tanımlayan</link> kullanıldığında aynı <guilabel> Ağ</guilabel> kullanmak "
"önemlidir."

# u#, no-c-format
#. Tag: para
#: index.docbook:1329
#, no-c-format
msgid ""
"To activate the &i18n-nickname; watching feature, choose <menuchoice> "
"<guisubmenu>Window</guisubmenu> <guisubmenu>Watched Nicks</guisubmenu> </"
"menuchoice> on the main menu. <action>The <guilabel>Watched Nicks</guilabel> "
"screen will appear.</action>"
msgstr ""
"&i18n-nickname; izleme özelliğini etkinleştirmek için, ana menüden "
"<menuchoice> <guisubmenu>Pencere</guisubmenu> <guisubmenu>İzlenen Rumuzlar</"
"guisubmenu> </menuchoice> ögesini seçin. <action><guilabel>İzlenen Rumuzlar</"
"guilabel> ekranı gözükecektir.</action>"

#. Tag: screeninfo
#: index.docbook:1339
#, no-c-format
msgid "Watched Nicks."
msgstr "İzlenen Rumuzlar."

#. Tag: phrase
#: index.docbook:1355
#, no-c-format
msgid "Watched Nicks"
msgstr "İzlenen Rumuzlar"

#. Tag: para
#: index.docbook:1363
#, no-c-format
msgid ""
"The &i18n-nickname;s in your watch list are listed here. They are listed "
"under their associated &irc; network. If no &i18n-nickname;s are listed, "
"either you haven't specified any &i18n-nickname;s to watch, or you need to "
"activate the &i18n-nickname; watching feature (see below). Expand each "
"online &i18n-nickname; to see a list of channels the &i18n-nickname; has "
"joined. The icons next to each channel are the same as the icons that appear "
"in the <interface>Nick Panel</interface> in the <link linkend=\"channel-"
"screen-tour\">channel</link> screens."
msgstr ""
"İzleme listenizdeki &i18n-nickname;'ler burada listelenmiştir. İlişkili "
"&irc; ağı altında listelenirler. Listelenmemiş bir &i18n-nickname; varsa, "
"izlemek için herhangi bir öge belirtmediyseniz veya &i18n-nickname; izleme "
"özelliğini etkinleştirmeniz gerekir (aşağıya bakın). &i18n-nickname; "
"katıldığı kanalların bir listesini görmek için her bir çevrimiçi &i18n-"
"nickname; genişletin. Her bir kanalın yanındaki simgeler, <link linkend="
"\"channel-screen-tour\">kanal</link> ekranlarındaki <interface>Rumuz Paneli</"
"interface> içinde görünen simgelerle aynıdır."

#. Tag: para
#: index.docbook:1371
#, no-c-format
msgid ""
"The information known about the &i18n-nickname; is displayed here. When the "
"<guilabel>Watched Nicks</guilabel> screen is first displayed, this "
"information is sparse. Every 20 seconds, one <userinput><command>WHOIS</"
"command></userinput> command is automatically sent to the server to request "
"information for &i18n-nickname;s that do not have any information. This "
"continues until all &i18n-nickname;s have information."
msgstr ""
"Burada, &i18n-nickname; ile ilgili bilinen bilgiler görüntülenir. "
"<guilabel>İzlenen Rumuzlar</guilabel> ekranı ilk kez gösterildiğinde, bu "
"bilgi az olacaktır. Hiçbir bilgi içermeyen &i18n-nickname;'leri hakkında "
"bilgi istemek için her 20 saniyede bir <userinput><command>WHOIS</command></"
"userinput> komutu otomatik olarak sunucuya gönderilir. Bu, tüm &i18n-"
"nickname;'leri bilgi sahibi olana kadar devam eder."

# u#, no-c-format
#. Tag: para
#: index.docbook:1385
#, no-c-format
msgid ""
"To add a single &i18n-nickname; to watch, open the context menu in the "
"<guilabel>Nick List</guilabel> by clicking with the &RMB; on a &i18n-"
"nickname; and select <guilabel>Add to Watched Nicks</guilabel>. If you want "
"to add several &i18n-nickname;s choose <menuchoice> <guisubmenu>Settings</"
"guisubmenu> <guisubmenu>Configure Konversation</guisubmenu> </menuchoice> "
"from the main menu, expand <guilabel>Notifications</guilabel> and click on "
"<guilabel>Watched Nicknames</guilabel>. The <guilabel>Watched Nicknames</"
"guilabel> screen appears."
msgstr ""
"İzlenecek tek bir &i18n-nickname; eklemek için, &i18n-nickname; üzerine "
"&RMB; tıklandığında açılan <guilabel>Rumuz Listesi</guilabel> içindeki "
"bağlam menüsünü açın ve <guilabel>İzlenen Rumuzlara Ekle</guilabel> ögesini "
"seçin. Birden çok &i18n-nickname; eklemek için ana menüden, <menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation Yapılandırma</"
"guisubmenu> seçin , <guilabel>Bildirimler</guilabel> ögesini genişletin ve "
"<guilabel>İzlenen Rumuzlar</guilabel> üzerine tıklayın. <guilabel>İzlenen "
"Rumuzlar</guilabel> ekranı görünecektir."

#. Tag: screeninfo
#: index.docbook:1399
#, no-c-format
msgid "<screeninfo>Watched Nicknames</screeninfo>"
msgstr "<screeninfo>İzlenen Rumuzlar</screeninfo>"

#. Tag: phrase
#: index.docbook:1413
#, no-c-format
msgid "<phrase>Watched Nicknames</phrase>"
msgstr "<phrase>İzlenen Rumuzlar</phrase>"

#. Tag: para
#: index.docbook:1422
#, no-c-format
msgid "Check this box to activate the &i18n-nickname; watcher feature."
msgstr ""
"&i18n-nickname; izleme özelliğini etkinleştirmek için bu kutuyu işaretleyin."

#. Tag: para
#: index.docbook:1424
#, no-c-format
msgid ""
"If you want the <guilabel>Watched Nicks</guilabel> screen to automatically "
"display when you open &konversation;, check this box."
msgstr ""
"&konversation; açıldığında, <guilabel>İzlenen Rumuzlar</guilabel> ekranının "
"otomatik olarak görünmesi ni istiyorsanız, bu kutuyu işaretleyin."

#. Tag: para
#: index.docbook:1428
#, no-c-format
msgid ""
"In the <guilabel>Watched Nicks</guilabel> screen, you may double click on "
"any &i18n-nickname; and this command will be sent to the server. "
"<userinput><command>%u</command></userinput> will be replaced with the &i18n-"
"nickname;. The <userinput><command>%n</command></userinput> is required at "
"the end of the command."
msgstr ""
"<guilabel>İzlenen Rumuzlar</guilabel> ekranında, herhangi bir &i18n-"
"nickname; üzerine tıklayabilir ve bu komutu sunucuya gönderebilirsiniz. "
"<userinput><command>%u</command></userinput> komutu &i18n-nickname; ile yer "
"değişecektir. Komutun sonunda <userinput><command>%n</command></userinput> "
"kullanmak zorunludur."

#. Tag: para
#: index.docbook:1434
#, no-c-format
msgid ""
"The <guilabel>Watched Nicks</guilabel> feature works by periodically polling "
"the server. This box sets how often that occurs. Avoid numbers less than 20 "
"seconds because it places excessive load on the server."
msgstr ""
"<guilabel>İzlenen Rumuzlar</guilabel> özelliği periyodik olarak sunucuyu "
"yoklar. Bu kutu, bunun ne sıklıkta meydana gelmesi gerektiğini belirler. "
"Sunucuya aşırı yük bindiği için sayıları 20 saniyeden kısa tutun."

#. Tag: para
#: index.docbook:1439
#, no-c-format
msgid ""
"Click the <guibutton>OK</guibutton> button when you have finished adding or "
"removing &i18n-nickname;s."
msgstr ""
"&i18n-nickname; ekleme ve çıkarma işleminiz bittiğinde, <guibutton>Tamam</"
"guibutton> tuşuna basın."

#. Tag: para
#: index.docbook:1441
#, no-c-format
msgid ""
"<emphasis>Note: </emphasis>Whenever you display the <guilabel>Watched Nicks</"
"guilabel> screen, it may take a while before any &i18n-nickname;s are "
"displayed until &konversation; has polled the server. Normally, you leave "
"the <guilabel>Watched Nicks</guilabel> screen running."
msgstr ""
"<emphasis>Not: </emphasis><guilabel>İzlenen Rumuzlar</guilabel> ekranını her "
"görüntülediğinizde, &i18n-nicknames; görünmesi için, &konversation;'ın "
"sunucudan bilgileri çekmesi biraz zaman alacaktır. Normalde, "
"<guilabel>İzlenen Rumuzlar</guilabel> ekranı çalışmaya devam edecektir."

#. Tag: para
#: index.docbook:1444
#, no-c-format
msgid ""
"&konversation; also displays a message in all the <link linkend=\"channel-"
"screen-tour\">channels</link> whenever a user in your <guilabel>Watched "
"Nicknames</guilabel> list connects or disconnects from the server. The "
"message looks like this:"
msgstr ""
"&konversation;, <guilabel>İzlenen Rumuzlar</guilabel> listesinden bulunan "
"kullanıcılar her bağlantı yapıp kapattığında, bir ileti gösterecektir. Bu "
"ileti şu şekildedir:"

#. Tag: computeroutput
#: index.docbook:1448
#, no-c-format
msgid "[17:52] [Notify] psn is online (irc.kde.org)."
msgstr "[17:52] [Notify] psn çevrim içi (irc.kde.org)."

#. Tag: title
#: index.docbook:1455
#, no-c-format
msgid "Message highlighting"
msgstr "İleti vurgulama"

#. Tag: para
#: index.docbook:1457
#, no-c-format
msgid ""
"You can control how messages are displayed in channel and query screens."
msgstr ""
"İletilerin kanal ve sorgu ekranlarında nasıl görüntüleneceğini kontrol "
"edebilirsiniz."

# u#, no-c-format
#. Tag: para
#: index.docbook:1459
#, no-c-format
msgid ""
"To activate the highlighting feature, choose <menuchoice> "
"<guisubmenu>Settings</guisubmenu> <guisubmenu>Configure &konversation;</"
"guisubmenu> </menuchoice> on the main menu. <action>The <guilabel>Configure</"
"guilabel> screen will appear.</action>"
msgstr ""
"Vurgulama özelliğini etkinleştirmek için, ana menüden <guisubmenu>Ayarlar</"
"guisubmenu> <guisubmenu>&konversation; Yapılandır</guisubmenu> ögesini "
"seçin. <action><guilabel>Yapılandır</guilabel> ekranı görünecektir.</action>"

#. Tag: screeninfo
#: index.docbook:1469
#, no-c-format
msgid "The Highlighting screen."
msgstr "Vurgulama ekranı."

#. Tag: phrase
#: index.docbook:1489
#, no-c-format
msgid "The Highlighting screen"
msgstr "Vurgulama ekranı"

#. Tag: para
#: index.docbook:1498
#, no-c-format
msgid "Click here to select the <guilabel>Highlight</guilabel> screen."
msgstr "<guilabel>Vurgulama</guilabel> ekranını seçmek için buraya tıklayın."

#. Tag: para
#: index.docbook:1499
#, no-c-format
msgid ""
"Click here to add a new item to the <guilabel>Highlight list</guilabel>. "
"When an item in the list is selected, you may edit it in the panel below."
msgstr ""
"Yeni bi ögeyi <guilabel>Vurgulama listesi</guilabel> içine eklemek için "
"buraya tıklayın. Listedeki bir öge seçildiğinde, alttaki panelden ögeyi "
"düzenleyebilirsiniz."

#. Tag: para
#: index.docbook:1502
#, no-c-format
msgid ""
"Enter a string pattern here. Any message received that matches this pattern, "
"anywhere in the message, will activate the highlighting for the message."
msgstr ""
"Buraya bir dizge deseni girin. İletinin herhangi bir yerinde bu desenle "
"eşleşen herhangi bir iletinin vurgulamasını etkinleştirir."

#. Tag: para
#: index.docbook:1510
#, no-c-format
msgid ""
"If the pattern is found in a message, the entire message will be displayed "
"in the color you select here."
msgstr ""
"Desen bir iletide bulunursa, iletinin tamamı burada seçtiğiniz rengin içinde "
"görüntülenir."

#. Tag: para
#: index.docbook:1513
#, no-c-format
msgid ""
"If you wish, &konversation; will play a sound when the pattern is matched. "
"Click the button to choose an audio file to be played. Click the test button "
"to hear the sound."
msgstr ""
"İsterseniz, desen eşleştiğinde &konversation; bir ses çıkartabilir. "
"Çalınacak bir ses dosyası seçmek için düğmeye tıklayın. Sesi duymak için "
"test düğmesine tıklayın."

#. Tag: para
#: index.docbook:1516
#, no-c-format
msgid ""
"If you'd like for &konversation; to automatically send a reply message when "
"the pattern is matched, enter the message here. Use this feature with "
"caution, as you may annoy &irc; users with too much chatter if not careful. "
"You can also enter &irc; or &konversation; commands here."
msgstr ""
"Desen eşleştiğinde, &konversation; otomatik olarak bir cevap göndermesini "
"isterseniz, iletiyi buraya girin. Bu özelliği dikkatli kullanın, çünkü "
"dikkatli değilseniz &irc; kullanıcılarını çok fazla sohbetle rahatsız "
"edebilirsiniz. Burada &irc; veya &konversation; komutlarını da "
"girebilirsiniz."

#. Tag: para
#: index.docbook:1521
#, no-c-format
msgid ""
"If you have configured sounds for any of your highlights, you can disable "
"all of them by unchecking this box."
msgstr ""
"Vurgulamalarınızdan herhangi biri için sesler yapılandırdıysanız, bu kutunun "
"işaretini kaldırarak tümünü devre dışı bırakabilirsiniz."

#. Tag: para
#: index.docbook:1524
#, no-c-format
msgid ""
"This highlight will only be searched for in chat windows listed here by "
"name, or in all chat windows if the field is left empty. Multiple names have "
"to be separated by commas."
msgstr ""
"Bu vurgu yalnızca burada ismi listelenen sohbet pencerelerinde veya alan boş "
"bırakılırsa tüm sohbet pencerelerinde aranır. Birden fazla isim virgülle "
"ayrılmalıdır."

#. Tag: para
#: index.docbook:1527
#, no-c-format
msgid ""
"If you check this box, whenever someone mentions your &i18n-nickname; in a "
"message, the message will be displayed in the color you choose at the right."
msgstr ""
"Bu kutuyu işaretlerseniz, birisi bir iletide &i18n-nickname; bahsedince, "
"ileti sağda seçtiğiniz renkte görüntülenir."

#. Tag: para
#: index.docbook:1530
#, no-c-format
msgid ""
"Normally, highlighting does not apply to messages you type. If you wish to "
"highlight the messages you type, check this box and choose a color at the "
"right."
msgstr ""
"Normalde, vurgulama, yazdığınız iletiler için geçerli değildir. Yazdığınız "
"iletileri vurgulamak istiyorsanız, bu kutuyu işaretleyin ve sağdan bir renk "
"seçin."

#. Tag: title
#: index.docbook:1542
#, no-c-format
msgid "Configuring On Screen Display (&osd;)"
msgstr "Ekran Üstü Görüntüsünü Yapılandırma (&osd;)"

#. Tag: para
#: index.docbook:1544
#, no-c-format
msgid ""
"<acronym>On Screen Display</acronym> (&osd;) is a unique feature of "
"&konversation;. With &osd; turned on, channel messages will appear on your "
"desktop screen, even if &konversation; is minimized. Here's an example of "
"&osd; in action. The message in the upper lefthand part of the screen is "
"from &konversation;, which is running minimized in the system tray."
msgstr ""
"<acronym>Ekran Üstü Görüntüsü</acronym> (&osd;), &konversation;'a özgün bir "
"özelliktir. &osd; açıldığında, &konversation; simge durumundaysa, kanal "
"iletileri masaüstü ekranınızda görünür olur. Bir &osd; eylemi örneği. "
"Ekranın sol üst kısmındaki ileti, sistem tepsisinde simge durumuna "
"küçülülmüş olarak çalışan &konversation; üzerinden gelmektedir."

#. Tag: screeninfo
#: index.docbook:1551
#, no-c-format
msgid "<screeninfo>Example of On Screen Display</screeninfo>"
msgstr "<screeninfo>Ekran Üstü Görüntüsü Örneği</screeninfo>"

#. Tag: phrase
#: index.docbook:1557
#, no-c-format
msgid "<phrase>Example of On Screen Display</phrase>"
msgstr "<phrase>Ekran Üstü Görüntüsü Örneği</phrase>"

# u#, no-c-format
#. Tag: para
#: index.docbook:1563
#, no-c-format
msgid ""
"To activate &osd;, choose <menuchoice> <guisubmenu>Settings</guisubmenu> "
"<guisubmenu>Configure &konversation;</guisubmenu> </menuchoice> on the main "
"menu. <action>The <guilabel>Configure</guilabel> screen will appear.</action>"
msgstr ""
"&osd; etkinleştirmek için, ana menüden <guisubmenu>Ayarlar</guisubmenu> "
"<guisubmenu>&konversation; Yapılandır</guisubmenu> </menuchoice> ögesini "
"seçin. <action><guilabel>Yapılandır</guilabel> ekranı görünecektir.</action>"

#. Tag: screeninfo
#: index.docbook:1573
#, no-c-format
msgid "The On Screen Display screen."
msgstr "Ekran Üstü Görüntüsü ekranı."

#. Tag: phrase
#: index.docbook:1589
#, no-c-format
msgid "The On Screen Display screen"
msgstr "Ekran Üstü Görüntüsü ekranı"

#. Tag: para
#: index.docbook:1598
#, no-c-format
msgid "Click here to expand the <guilabel>Notification</guilabel> item."
msgstr ""
"<guilabel>Bildirim</guilabel> ögesini genişletmek için buraya tıklayın."

#. Tag: para
#: index.docbook:1600
#, no-c-format
msgid "Click here to select the <guilabel>On Screen Display</guilabel> screen."
msgstr ""
"<guilabel>Ekran Üstü Görüntüsü</guilabel> ekranını seçmek için buraya "
"tıklayın."

#. Tag: para
#: index.docbook:1602
#, no-c-format
msgid "Check this box to activate &osd;."
msgstr "&osd; etkinleştirmek için bu kutuyu işaretleyin."

#. Tag: para
#: index.docbook:1604
#, no-c-format
msgid ""
"Click this button to choose a font for &osd;. (<emphasis>Note: </emphasis> "
"Not all fonts work. Luxi Sans 22 and Impact 22 are known to work.)"
msgstr ""
"&osd; için bir yazı tipi seçmek istiyorsanız bu düğmeye tıklayın. "
"(<emphasis>Not: </emphasis> Tüm yazı tipleri çalışmaz. Luxi Sans 22 ve "
"Impact 22 çalışanlardandır.)"

#. Tag: para
#: index.docbook:1606
#, no-c-format
msgid ""
"Check the boxes here to select the types of messages you'd like to appear on "
"screen."
msgstr ""
"Ekranda görünmesini istediğiniz ileti türlerini seçmek için buradaki "
"kutuları işaretleyin."

#. Tag: para
#: index.docbook:1608
#, no-c-format
msgid ""
"Drag the <interface>&osd; Preview</interface> to your desired position, then "
"click the <guibutton>Apply</guibutton> button."
msgstr ""
"<interface>&osd; Önzileme</interface> ögesini istedğiniz konuma sürükleyin, "
"ardıkdan <guibutton>Uygula</guibutton> düğmesine basın."

#. Tag: title
#: index.docbook:1618
#, no-c-format
msgid "Sending colorful messages"
msgstr "Renkli iletiler gönderme"

#. Tag: para
#: index.docbook:1620
#, no-c-format
msgid ""
"You can add color to the messages you send in any channel. In the "
"<interface>Input Line</interface> of any channel, start typing your message. "
"Click the <inlinemediaobject> <imageobject> <imagedata fileref=\"format-text-"
"color.png\" format=\"PNG\"/> </imageobject> <textobject> <phrase>Insert "
"&irc; Color Button</phrase> </textobject> </inlinemediaobject> "
"<guibutton>&irc; Color</guibutton> button or choose <menuchoice> "
"<guisubmenu>Insert</guisubmenu> <guisubmenu>&irc; Color</guisubmenu> </"
"menuchoice> on the main menu. <action>The <guilabel>&irc; Color Chooser</"
"guilabel> screen will appear.</action>"
msgstr ""
"Herhangi bir kanalda gönderdiğiniz iletilere renk ekleyebilirsiniz. Herhangi "
"bir kanalın <interface>Giriş Satırı</interface> bölümünde iletinizi yazmaya "
"başlayın. <inlinemediaobject> <imageobject> <imagedata fileref=\"format-text-"
"color.png\" format=\"PNG\"/> </imageobject> <textobject> <phrase>&irc; Renk "
"Düğmesi Ekle</phrase> </textobject> </inlinemediaobject> <guibutton>&irc; "
"Renk</guibutton> düğmesine basın veya ana menüden menuchoice> "
"<guisubmenu>Ekle</guisubmenu> <guisubmenu>&irc; Renk</guisubmenu> </"
"menuchoice> ögesini seçin. <action><guilabel>&irc; Renk Seçici</guilabel> "
"ekranı görünecektir."

#. Tag: screeninfo
#: index.docbook:1640
#, no-c-format
msgid "The &irc; Color Chooser screen."
msgstr "&irc; Renk Seçici ekranı."

#. Tag: phrase
#: index.docbook:1646
#, no-c-format
msgid "The &irc; Color Chooser screen"
msgstr "&irc; Renk Seçici ekranı"

#. Tag: para
#: index.docbook:1652
#, no-c-format
msgid ""
"Choose a color and click <guibutton>OK</guibutton>. Continue typing your "
"message in the <interface>Input Line</interface>. To change the color again, "
"click the <guibutton>&irc; Color</guibutton> button. Choose a different "
"color and click <guibutton>OK</guibutton>."
msgstr ""
"Bir renk seçin ve <guibutton>Tamam</guibutton> düğmesine tıklayın. "
"<interface>Giriş Satırı</interface> üzerine iletinizi yazmaya devam edin. "
"Renkgi yeniden değiştirmek için, <guibutton>&irc; Renk</guibutton> düğmesine "
"basın. Farklı bir renk seçin ve <guibutton>Tamam</guibutton> düğmesine basın."

#. Tag: title
#: index.docbook:1663
#, no-c-format
msgid "Configuring &i18n-nickname; themes"
msgstr "&i18n-nickname; temalarını yapılandırma"

#. Tag: para
#: index.docbook:1665
#, no-c-format
msgid ""
"You can change the icons displayed next to &i18n-nickname;s in the "
"<interface>Nick Panel</interface> of channel tabs. To change the &i18n-"
"nickname; theme, choose <menuchoice> <guisubmenu>Settings</guisubmenu> "
"<guisubmenu>Configure Konversation</guisubmenu> </menuchoice> on the main "
"menu. <action>The <guilabel>Configure</guilabel> screen will appear.</"
"action> Click <guilabel>Interface</guilabel> to expand it, then click "
"<guilabel>Nicklist Themes</guilabel> to display the <guilabel>Nicklist "
"Themes</guilabel> screen."
msgstr ""
"Kanal sekmelerinde bulunan, <interface>Rumuzu Paneli</interface> içindeki "
"&i18n-nickname; yanında çıkan simgeleri değiştirebilirsiniz. Ana menüden "
"<menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation "
"Yapılandır</guisubmenu> </menuchoice> ögesini seçin. "
"<action><guilabel>Yapılandır</guilabel></action> ekranı görünecektir.  "
"Genişletmek için <guilabel>Arayüz</guilabel> ögesine tıklayın, ardından "
"<guilabel>Rumuz Listesi Temaları</guilabel> ekranını görüntülemek için "
"<guilabel>Rumuz Listesi Temaları</guilabel> ögesine tıklayın."

#. Tag: screeninfo
#: index.docbook:1679
#, no-c-format
msgid "The Themes screen."
msgstr "Temalar ekranı."

#. Tag: phrase
#: index.docbook:1693
#, no-c-format
msgid "The Themes screen"
msgstr "Temalar ekranı"

#. Tag: para
#: index.docbook:1702
#, no-c-format
msgid "Click here to select the <guilabel>Nicklist Themes</guilabel> screen."
msgstr ""
"<guilabel>Rumuz Listesi Temaları</guilabel> ekranını seçmek için buraya "
"tıklayın."

#. Tag: para
#: index.docbook:1703
#, no-c-format
msgid "Select a theme."
msgstr "Bir tema seç."

#. Tag: para
#: index.docbook:1704
#, no-c-format
msgid "Sample icons are displayed here in the chosen theme."
msgstr "Örnek simgeler burada seçilen temada görüntülenir."

#. Tag: para
#: index.docbook:1705
#, no-c-format
msgid ""
"If you have downloaded a nick theme from elsewhere, click to install it."
msgstr ""
"Başka bir yerden bir rumuz teması indirdiyseniz, yüklemek için tıklayın."

#. Tag: title
#: index.docbook:1716
#, no-c-format
msgid "Configuring Quick Buttons"
msgstr "Hızlı Düğmeleri Yapılandırma"

#. Tag: para
#: index.docbook:1718
#, no-c-format
msgid ""
"You can enable a feature to display <interface>Quick Buttons</interface> on "
"the <link linkend=\"channel-screen-tour\">Main</link> screen, eight "
"<interface>Quick Buttons</interface> appear. To display the Quick Buttons, "
"choose <menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"Konversation</guisubmenu> </menuchoice> on the main menu. <action>The "
"<guilabel>Configure</guilabel> screen will appear.</action> Click "
"<guilabel>Interface</guilabel> to expand it, then click <guilabel>Chat "
"Window</guilabel>. Check the <guilabel>Show quick buttons</guilabel> box and "
"click <guibutton>OK</guibutton>."
msgstr ""
"<link linkend=\"channel-screen-tour\">Ana</link> ekran üzerinde, "
"<interface>Hızlı Düğmeler</interface> ögesini görüntülemek için bir özelliği "
"etkinleştirebilirsiniz, böylece sekiz <interface>Hızlı Düğmeler</interface> "
"görünecektir. Hızlı Düğmeleri görüntülemek için, ana menüden menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation Yapılandır</"
"guisubmenu> </menuchoice> ögesini seçin. <action><guilabel>Yapılandır</"
"guilabel> penceresi görünecektir.</action> Genişletmek için "
"<guilabel>Arayüz</guilabel> ögesine tıklayın, ardıkdan <guilabel>Sohbet "
"Penceresi</guilabel> üzerine basın. <guilabel>Hızlı düğmeler göster</"
"guilabel> kutusunu işaretleyin ve <guibutton>Tamam</guibutton> düğmesine "
"basın."

#. Tag: para
#: index.docbook:1728
#, no-c-format
msgid ""
"The buttons may be customized to your liking for performing often-used &irc; "
"commands. To customize the <interface>Quick Buttons</interface>, choose "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"Konversation</guisubmenu> </menuchoice> on the main menu. <action>The "
"<guilabel>Configure</guilabel> screen will appear.</action> Click "
"<guilabel>Interface</guilabel> to expand it, then click <guilabel>Quick "
"Buttons</guilabel> to display the <guilabel>Quick Buttons</guilabel> screen."
msgstr ""
"Düğmeler sıklıkla kullanılan &irc; komutlarını çalıştırmak için beğeninize "
"göre uyarlanabilir. <interface>Hızlı Düğmeler</interface> ögelerini "
"özelleştirmek için, ana menüden <guisubmenu>Ayarlar</guisubmenu> "
"<guisubmenu>Konversation Yapılandır</guisubmenu> </menuchoice> ögesini "
"seçin. <guilabel>Yapılandır</guilabel> penceresi görünecektir.</action> "
"Geniletmek için <guilabel>Arayüz</guilabel> ögesine tıklayın, ardından, "
"<guilabel>Hızlı Düğmeler</guilabel> ekranının görünmesi için, "
"<guilabel>Hızlı Düğmeler</guilabel> ögesine tıklayın."

#. Tag: screeninfo
#: index.docbook:1742
#, no-c-format
msgid "<screeninfo>The Quick Buttons screen</screeninfo>"
msgstr "<screeninfo>Hızlı Düğmeler ekranı</screeninfo>"

#. Tag: phrase
#: index.docbook:1748
#, no-c-format
msgid "<phrase>The Quick Buttons screen</phrase>"
msgstr "<phrase>Hızlı Düğmeler ekranı</phrase>"

#. Tag: para
#: index.docbook:1754
#, no-c-format
msgid ""
"There are 8 default <interface>Quick Button</interface>s. Click on an entry "
"to change it or use the buttons at the right side of the list to add or "
"remove <interface>Quick Button</interface>s. The <guilabel>Button Name</"
"guilabel> column is the name that will appear on the button in the <link "
"linkend=\"channel-screen-tour\">Main</link> screen. Keep the names short. "
"The <guilabel>Button Action</guilabel> column is the action that will be "
"performed when you click the <interface>Quick Button</interface>. Tips for "
"creating actions are given on the screen."
msgstr ""
"Varsayılan olarak 8 <interface>Hızlı Düğme</interface> vardır. Değiştirmek "
"için bir girdiye tıklayın veya <interface>Hızlı Düğme</interface> eklemek "
"veya kaldırmak için listenin sağ tarafındaki düğmeleri kullanın. "
"<guilabel>Düğme Adı</guilabel> sütunu, <link linkend=\"channel-screen-tour"
"\">Ana</link> ekranda görünecek olan isimdir. İsimleri kısa tutun. "
"<guilabel>Düğme Eylemi</guilabel> sütunu ise, <interface>Hızlı Düğme</"
"interface> üzerine basıldığında yapılacak olan eylemdir. Eylem oluşturma "
"ipuçları ekranda verilir."

#. Tag: para
#: index.docbook:1763
#, no-c-format
msgid "Click <guibutton>OK</guibutton> to complete the changes."
msgstr ""
"Değişiklikleri kaydetmek için <guibutton>Tamam</guibutton> düğmesine basın."

#. Tag: para
#: index.docbook:1767
#, no-c-format
msgid "Example:"
msgstr "Örnek:"

#. Tag: term
#: index.docbook:1772
#, no-c-format
msgid ""
"<guilabel>Button Name</guilabel>: <userinput><replaceable>Msg</replaceable></"
"userinput>"
msgstr ""
"<guilabel>Düğme Adı</guilabel>: <userinput><replaceable>İleti</replaceable></"
"userinput>"

#. Tag: para
#: index.docbook:1776
#, no-c-format
msgid ""
"<guilabel>Button Action</guilabel>: <userinput><replaceable>Msg %u </"
"replaceable></userinput> (there is a space after <userinput><replaceable>%u</"
"replaceable></userinput>)"
msgstr ""
"<guilabel>Düğme Eylemi</guilabel>: <userinput><replaceable>İleti %u </"
"replaceable></userinput> (<userinput><replaceable>%u</replaceable></"
"userinput> sonrası bir boşluk var)"

#. Tag: para
#: index.docbook:1784
#, no-c-format
msgid ""
"To use this button in the <link linkend=\"channel-screen-tour\">Main</link> "
"screen, click on a &i18n-nickname; in the <interface>Nick Panel</interface>, "
"then click the button. <computeroutput>/MSG </computeroutput> will appear in "
"the <interface>Input Line</interface> followed by the chosen &i18n-"
"nickname;. Type a message you want to send to that person and press &Enter;. "
"The message will be sent to the user. Only that user will see the message."
msgstr ""
"<link linkend=\"channel-screen-tour\">Ana</link> ekrandaki düğmeyi kullanmak "
"için, <interface>Rumuz Paneli</interface> üzerindeki &i18n-nickname; "
"ögesine, ardından düğmeye tıklayın <computeroutput>/MSG </computeroutput>, "
"<interface>Giriş Satırı</interface> üzerinde, &i18n-nickname; ögesi sonrası "
"görünecektir. İlgili kişiye göndermek istediğiniz bir ileti yazın ve &Enter; "
"tuşuna basın. İleti kullanıcıya gönderilecektir. Sadece o kullanıcı ileti "
"görür."

#. Tag: title
#: index.docbook:1797
#, no-c-format
msgid "Sending and receiving files"
msgstr "Dosya gönderme ve alma"

#. Tag: para
#: index.docbook:1799
#, no-c-format
msgid ""
"You may send files via &irc; to other users online, or they may send you "
"files."
msgstr ""
"Dosyaları &irc; ile gönderebilirsiniz, çevrimiçi diğer kullanıcılara veya "
"size dosya gönderebilir."

#. Tag: emphasis
#: index.docbook:1804
#, no-c-format
msgid ""
"WARNING: Never open a file someone sends you unless they are a trusted "
"source. It could be a virus."
msgstr ""
"UYARI: Güvenilir bir kaynak olmadığı sürece birisinin sizi gönderdiği bir "
"dosyayı asla açmayın. Bir virüs olabilir."

#. Tag: para
#: index.docbook:1807
#, no-c-format
msgid ""
"To send a file to someone in a channel, click with the &RMB; on the &i18n-"
"nickname; of the person in the <interface>Nick Panel</interface> of the "
"<link linkend=\"channel-screen-tour\">Main</link> screen. Choose "
"<menuchoice> <guisubmenu>Send File</guisubmenu> </menuchoice> <action>. A "
"dialog appears for you to choose a file to send.</action> Next, a new "
"<guilabel>DCC Status</guilabel> tab appears."
msgstr ""
"Bir kanalda birisine dosya göndermek için, <link linkend=\"channel-screen-"
"tour\">Ana</link> ekrandaki <interface>Rumuz Paneli</interface> içindeki "
"kişinin &i18n-nickname; üzerine &RMB; ile tıklayın. <menuchoice> "
"<guisubmenu>Dosya Gönder</guisubmenu> </menuchoice> <action> ögesini seçin. "
"<action>Bir dosya seçip göndermeniz için bir pencere açılılr.</action> "
"Ardından yeni bir <guilabel>DCC Durumu</guilabel> sekmesi görünecektir."

#. Tag: screeninfo
#: index.docbook:1819
#, no-c-format
msgid "<screeninfo>DCC Status tab</screeninfo>"
msgstr "<screeninfo>DCC Durum sekmesi</screeninfo>"

#. Tag: phrase
#: index.docbook:1832
#, no-c-format
msgid "<phrase>DCC Status tab</phrase>"
msgstr "<phrase>DCC Durum sekmesi</phrase>"

#. Tag: para
#: index.docbook:1841
#, no-c-format
msgid "The &i18n-nickname; of the recipient and file name appear here."
msgstr "Alıcının &i18n-nickname; ve dosyanın adı burada görünür."

#. Tag: para
#: index.docbook:1844
#, no-c-format
msgid ""
"The <guilabel>Status</guilabel> column indicates the status of the file send "
"or receive as follows:"
msgstr ""
"<guilabel>Durum</guilabel> sütunu, gönderilen veya alınan dosyanın durumunu "
"aşağıdaki gibi gösterir:"

#. Tag: guilabel
#: index.docbook:1850
#, no-c-format
msgid "Preparing"
msgstr "Hazırlanıyor"

#. Tag: para
#: index.docbook:1853
#, no-c-format
msgid ""
"A receiving transfer is checking for resumable files or a sending transfer "
"is acquiring the data to send."
msgstr ""
"Alınan bir aktarım, devam ettirilebilen dosyalar için kontrol ya da "
"gönderilecek olan verileri alacak bir gönderim transferi."

#. Tag: guilabel
#: index.docbook:1860
#, no-c-format
msgid "Connecting"
msgstr "Bağlanılıyor"

#. Tag: para
#: index.docbook:1863
#, no-c-format
msgid "&konversation; is trying to establish a connection with the other end."
msgstr "&konversation, diğer tarafla bağlantı kurmaya çalışıyor."

#. Tag: guilabel
#: index.docbook:1869
#, no-c-format
msgid "Sending"
msgstr "Gönderiliyor"

#. Tag: para
#: index.docbook:1872
#, no-c-format
msgid "&konversation; is sending the file to the other end."
msgstr "&konversation; diğer tarafa dosyayı gönderiyor."

#. Tag: guilabel
#: index.docbook:1878
#, no-c-format
msgid "Receiving"
msgstr "Alınıyor"

#. Tag: para
#: index.docbook:1881
#, no-c-format
msgid "&konversation; is receiving the file from the other end."
msgstr "&konversation; diğer taraftan dosyayı alıyor."

#. Tag: guilabel
#: index.docbook:1887
#, no-c-format
msgid "Done"
msgstr "Tamamlandı"

#. Tag: para
#: index.docbook:1890
#, no-c-format
msgid "The file has been successfully transferred."
msgstr "Dosya aktarımı tamamlanmış."

#. Tag: guilabel
#: index.docbook:1896
#, no-c-format
msgid "Pending"
msgstr "Bekleniyor"

#. Tag: para
#: index.docbook:1899
#, no-c-format
msgid "The transfer is waiting for the partner to accept or reject it."
msgstr "Aktarım için karşı tarafın kabul ve red etmesini bekliyor."

#. Tag: guilabel
#: index.docbook:1905
#, no-c-format
msgid "Aborted"
msgstr "İptal Edildi"

#. Tag: para
#: index.docbook:1908
#, no-c-format
msgid ""
"Either you clicked the <guibutton>Abort</guibutton> button, or the other "
"person aborted the transfer."
msgstr ""
"Ya <guibutton>İptal Et</guibutton> düğmesini bastınız ya da diğer kişi "
"aktarımı durdurdu."

#. Tag: guilabel
#: index.docbook:1914
#, no-c-format
msgid "Failed"
msgstr "Başarısız Oldu"

#. Tag: para
#: index.docbook:1917
#, no-c-format
msgid "An error occurred and the transfer was not successful."
msgstr "Aktarım sırasında bir hata oluştu ve başarısız oldu."

#. Tag: guilabel
#: index.docbook:1923
#, no-c-format
msgid "Queued"
msgstr "Kuyrukta"

#. Tag: para
#: index.docbook:1926
#, no-c-format
msgid "Transfer is waiting for you to accept or reject it."
msgstr "Aktarım, sizin kabul veya red etmenizi bekliyor."

#. Tag: guilabel
#: index.docbook:1941
#, no-c-format
msgid "Resuming"
msgstr "Devam Ediliyor"

#. Tag: para
#: index.docbook:1944
#, no-c-format
msgid ""
"When a transfer begins but the file already exists on the user's system, the "
"user will be prompted <interface>File already exists. Resume transfer?</"
"interface> This status indicates the user resumed the transfer."
msgstr ""
"Bir aktarım başlar ancak dosya, kullanıcının sistemi üzerinde zaten "
"mevcutsa, kullanıcıdan <interface>Dosya zaten mevcut. Aktarıma devam "
"edilsinmi?</Interface> sorulur, bu durum, kullanıcının aktarımı sürdürdüğüne "
"işaret eder."

#. Tag: para
#: index.docbook:1954
#, no-c-format
msgid ""
"When someone wants to send you a file, the <guilabel>DCC Status</guilabel> "
"tab will be created (if not already created). Click the <guilabel>DCC "
"Status</guilabel> tab to display it. Click the file to select it, then click "
"this button to accept the file and the transfer will begin. <emphasis>Note: "
"</emphasis>You may configure &konversation; to automatically accept sends "
"from other people by choosing <menuchoice> <guisubmenu>Settings</guisubmenu> "
"<guisubmenu>Configure Konversation</guisubmenu> </menuchoice> on the main "
"menu. Click <guilabel>Behavior</guilabel> to expand it, then click "
"<guilabel>DCC</guilabel> to display the <guilabel>DCC</guilabel> screen."
msgstr ""
"Bir kişi size dosya göndermek istediğinde, <guilabel>DCC Durumu</guilabel> "
"sekmesi oluşuturulur (hali hazırda yoksa). Görüntülemek için <guilabel>DCC "
"Durumu</guilabel> sekmesine tıklayın. Seçmek için dosyaya tıklayın, ardından "
"dosyayı kabul etmek için bu düğmeya tıklayın ve aktarım başlayacaktır. "
"<emphasis>Not: </emphasis>Diğer kişilerden gelen dosyaları otomatik olarak "
"kabul etmek için, &konversation;'ı, ana menüden <menuchoice> "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation Yapılandır</"
"guisubmenu> </menuchoice> seçerek yapılandırabilirsiniz. Genişletmek için "
"<guilabel>Davranış</guilabel> ögesine tıklayın, ardından <guilabel>DCC</"
"guilabel> ekranını görüntülemek için <guilabel>DCC</guilabel> ögesine "
"tıklayın."

#. Tag: para
#: index.docbook:1967
#, no-c-format
msgid ""
"If you have trouble sending or receiving files, your firewall or router may "
"be blocking DCC ports. See <link linkend=\"faq\">Questions and Answers</"
"link>."
msgstr ""
"Dosya alıp göndermede sorun yaşıyorsanız, güvenlik duvarınız veya "
"yönlendiriciniz DCC portunu engelliyor olabilir. <link linkend=\"faq"
"\">Sorular ve Cevaplar</link> bölümüne gözatın."

#. Tag: title
#: index.docbook:1977
#, no-c-format
msgid "Capturing &URL;s from messages"
msgstr "İletilerdeki &URL;leri yakalamak"

#. Tag: para
#: index.docbook:1979
#, no-c-format
msgid ""
"In any <link linkend=\"channel-screen-tour\">channel</link>, users sometimes "
"post the &URL;s of interesting websites or other resources on the web. You "
"can double-click any such &URL; and &konversation; will launch the "
"application associated with the &URL;. The application launched depends upon "
"the &MIME; type of the &URL;. For example, a &URL; beginning with "
"<interface>http:</interface> will activate your default web browser and "
"display the web page. (You can also specify the <link linkend=\"webbrowser"
"\">web browser</link> to use.) If the &URL; scrolls off the screen, you "
"might have trouble finding it again. &konversation; can keep a convenient "
"list of all &URL;s for you. To activate this feature, choose <menuchoice> "
"<guisubmenu>Window</guisubmenu> <guisubmenu>&URL; Catcher</guisubmenu> </"
"menuchoice> on the main menu. <action>A new tab called <guilabel>&URL; "
"Catcher</guilabel> is created.</action>"
msgstr ""
"Herhangi bir kanalda, ilgili websiteler veya web üzerindeki diğer "
"kaynaklarla ilgili &URL; gönderilebilir. Herhangi bir &URL; üzerine çift "
"tıklanabilir ve &konversation;, &URL; ile ilişkili olan uygulamayı "
"açacaktır. &MIME; türü ya da &URL;'ye bağlı olarak ugulama başlatılacaktır. "
"Örneğin, &URL; <interface>http:</interface> ile başlıyorsa, varsayılan web "
"tarayıcısı açılır ve web sayfası görüntülenir (ayrıca kullanılcak olan <link "
"linkend=\"webbrowser\">web tarayıcısı</link> seçilebilir). Eğer &URL; "
"ekranın üstlerinde kalırsa, bulmakta sorun yaşayabilirsiniz. &konversation; "
"&URL; listesini sizin için tutabilir. Bu özelliği etkinleştirmek için, ana "
"menüden <menuchoice> <guisubmenu>Pencere</guisubmenu> <guisubmenu>&URL; "
"Yakalayıcı</guisubmenu> </menuchoice> ögesini seçin. <action><guilabel>&URL; "
"Yakalayıcı</guilabel> olarak bilinen yeni bir sekme oluşturulacaktır.</"
"action>"

#. Tag: screeninfo
#: index.docbook:1997
#, no-c-format
msgid "<screeninfo>The &URL; Catcher tab.</screeninfo>"
msgstr "<screeninfo>&URL; Yakalayıcı sekmesi.</screeninfo>"

#. Tag: phrase
#: index.docbook:2013
#, no-c-format
msgid "<phrase>The &URL; Catcher tab.</phrase>"
msgstr "<phrase>&URL; Yakalayıcı sekmesi.</phrase>"

#. Tag: para
#: index.docbook:2022
#, no-c-format
msgid ""
"This is the list of &URL;s seen since you started &konversation;. The "
"<guilabel>From</guilabel> column is the &i18n-nickname; of the person who "
"posted the &URL; or the name of the channel or server, where the &URL; was "
"posted. (&URL;s appearing in join and leave messages are not listed.) Click "
"on a &URL; to select it."
msgstr ""
"Bu, &konversation; başlatıldığından beri görünen &URL; listesidir. "
"<guilabel>Kimden</guilabel> sütunu, &URL;'yi gönderen kişinin &i18n-"
"nickname; ögesidir ya da &URL;'nin gönderildiği kanal veya sunucunun "
"ismidir. (giriş ve çıkış iletilerindeki &URL;'ler listelenmez.) Seçmek için "
"&URL; üstüne tıklayın."

#. Tag: para
#: index.docbook:2025
#, no-c-format
msgid ""
"Click here to activate the application associated with the selected &URL;. "
"The application launched depends upon the &MIME; type of the &URL;. For "
"example, a &URL; beginning with <interface>http:</interface> will activate "
"your default web browser and display the web page. For web pages, you can "
"also specify the <link linkend=\"webbrowser\">web browser</link> to use."
msgstr ""
"Seçili olan &URL; ile ilişkili olan uygulamayı etkinleştirmek için buraya "
"tıklayın. &MIME; türü ya da &URL;'ye bağlı olarak ugulama başlatılacaktır. "
"Örneğin, &URL; <interface>http:</interface> ile başlıyorsa, varsayılan web "
"tarayıcısı açılır ve web sayfası görüntülenir. Ayrıca kullanılcak olan <link "
"linkend=\"webbrowser\">web tarayıcısı</link> seçilebilir."

#. Tag: para
#: index.docbook:2030
#, no-c-format
msgid "Click here to copy the selected &URL; to the clipboard."
msgstr "Seçili &URL;'yi panoya kopyalamak için buraya tıklayın."

#. Tag: para
#: index.docbook:2032
#, no-c-format
msgid "Click here to delete the selected &URL; from the list."
msgstr "Seçili &URL;'yi listeden silmek için buraya tıklayın."

#. Tag: para
#: index.docbook:2034
#, no-c-format
msgid "Click here to save the list of &URL;s to a file."
msgstr "&URL; listesini dosyaya kaydetmek için buraya tıklayın."

#. Tag: para
#: index.docbook:2036
#, no-c-format
msgid "Click here to clear the list."
msgstr "Listeyi temizlemek için buraya tıklayın."

#. Tag: title
#: index.docbook:2046
#, no-c-format
msgid "Setting your preferred web browser"
msgstr "Tercih ettiğiniz web tarayıcısını ayarlama"

#. Tag: para
#: index.docbook:2048
#, no-c-format
msgid ""
"When you click on a highlighted &URL; anywhere in &konversation;, it will "
"launch the default application associated with the &MIME; type of the &URL;. "
"For example, when clicking on a &URL; beginning with <interface>http</"
"interface>, &konqueror; is launched to display the web page. You can specify "
"an application different from the <guilabel>Default Applications</guilabel> "
"module of the &systemsettings;. For example, you can use "
"<application>Firefox</application> instead."
msgstr ""
"&konversation; üzerinde herhangi bir yerde vurgulanmış olan &URL;'ye "
"tıkladığınızda, &URL; &MIME; türü ile ilişkili olan uygulama açılacaktır. "
"Örneğin, <interface>http</interface> ile başlayan bir &URL; tıklandığında, "
"web sayfasının görüntülenmesi için &konqueror; çalışacaktır. "
"&systemsettings; içindeki <guilabel>Varsayılan Uygulamalar</guilabel> "
"ögesini kullanarak başka bir uygulama belirtebilirsiniz. Örneğin, "
"<application>Firefox</application> kullanabilirsiniz."

# u#, no-c-format
#. Tag: para
#: index.docbook:2055
#, no-c-format
msgid ""
"To choose a different web browser from &konversation; app, choose "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"&konversation;</guisubmenu> </menuchoice> on the main menu. <action>The "
"<guilabel>Configure</guilabel> screen will appear.</action>"
msgstr ""
"&konversation; dışında başka bir web tarayıcısı seçmek için, ana menüden "
"<menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>&konversation; "
"Yapılandır</guisubmenu> </menuchoice> ögesini seçin. "
"<action><guilabel>Yapılandır</guilabel> ekranı görünecektir.</action>"

#. Tag: screeninfo
#: index.docbook:2065
#, no-c-format
msgid "<screeninfo>The General screen</screeninfo>"
msgstr "<screeninfo>Genel ekranı</screeninfo>"

#. Tag: phrase
#: index.docbook:2078
#, no-c-format
msgid "<phrase>The General screen</phrase>"
msgstr "<phrase>Genel ekranı</phrase>"

#. Tag: para
#: index.docbook:2087
#, no-c-format
msgid "Click here to display the <guilabel>General</guilabel> screen."
msgstr "<guilabel>Genel</guilabel> ekranını görüntülemek için buraya tıklayın."

#. Tag: para
#: index.docbook:2089
#, no-c-format
msgid "Click here to specify that you want to use a custom web browser."
msgstr ""
"Özel bir web tarayıcısı kullanmak istediğinizi belirtmek için buraya "
"tıklayın."

#. Tag: para
#: index.docbook:2091
#, no-c-format
msgid ""
"Enter the command to launch your desired web browser. When you click on a "
"&URL; <userinput><replaceable>%u</replaceable></userinput> will be replaced "
"with the &URL;."
msgstr ""
"İstediğiniz web tarayıcısını çalıştırmak için komutu girin. &URL;'ye "
"tıkladığınızda, <userinput><replaceable>%u</replaceable></userinput>, &URL; "
"ile değişecektir."

#. Tag: para
#: index.docbook:2097
#, no-c-format
msgid ""
"<emphasis>Note: </emphasis>The web browser setting does not apply to "
"<interface>mailto:</interface> &URL;s. <interface>mailto:</interface> &URL;s "
"always launch the default mailer."
msgstr ""
"<emphasis>Not: </emphasis>Web tarayıcısı ayarı, <interface>mailto:</"
"interface> içeren &URL; için uygulanmaz. <interface>mailto:</interface> "
"&URL;'si her zaman varsayılan postacıyı başlatır."

#. Tag: para
#: index.docbook:2102
#, no-c-format
msgid ""
"Click <guibutton>Apply</guibutton> to save your changes. You must reconnect "
"to each server and channel for the changes to take effect. The easiest way "
"to do this is to quit and restart &konversation;."
msgstr ""
"Değişikliklerinizi kaydetmek için <guibutton>Uygula</guibutton> düğmesine "
"tıklayın. Değişikliklerin etkili olması için her bir sunucuya ve kanala "
"yeniden bağlanmanız gerekir. Bunu yapmanın en kolay yolu &konversation; "
"uygulamasından çıkıp yeniden başlatmaktır."

#. Tag: title
#: index.docbook:2111
#, no-c-format
msgid "Marking Channel and Query Logs"
msgstr "Kanal ve Sorgu Günlüklerini İşaretleme"

#. Tag: para
#: index.docbook:2113
#, no-c-format
msgid ""
"You can insert a marker into <link linkend=\"channel-screen-tour\">channel</"
"link> and <link linkend=\"query\">query</link> screens to help you quickly "
"locate information. To do this, choose <menuchoice> <guisubmenu>Insert</"
"guisubmenu> <guisubmenu>Marker Line</guisubmenu> </menuchoice> on the main "
"menu, or press <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></"
"keycombo>. <action>A line will appear at the bottom of the text on the "
"screen. The line will scroll with the rest of the text in the screen.</"
"action>"
msgstr ""
"<link linkend=\"channel-screen-tour\">kanal</link> ve <link linkend=\"query"
"\">sorgu</link> ekranların işaretleme yapmak, bilgiye çabuk ulaşmanızı "
"sağlayacaktır. Bunu yapmak için ana menüden, <menuchoice> <guisubmenu>Ekle</"
"guisubmenu> <guisubmenu>İşaretçi Satırı</guisubmenu> </menuchoice> ögesini "
"seçin veya <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> "
"tuşlarına basın. <action>Ekrandaki metnin alt kısmında bir çizgi görünür. "
"Satır, ekrandaki metnin geri kalanıyla birlikte ilerleyecektir.</action>"

# u#, no-c-format
#. Tag: para
#: index.docbook:2125
#, no-c-format
msgid ""
"To make the <interface>Maker Line</interface> be inserted in all channels "
"and queries at once, choose <menuchoice> <guisubmenu>Settings</guisubmenu> "
"<guisubmenu>Configure Konversation</guisubmenu> </menuchoice> from the main "
"menu, expand <guilabel>Behavior</guilabel>, click on <guilabel>Chat Window</"
"guilabel>, and check the <guilabel>Show manually inserted lines in all chat "
"windows</guilabel> box."
msgstr ""
"<interface>İşaretçi Satırı</interface> ögesini, kanallara ve sorgulara bir "
"kere eklemek için, ana menüden <guisubmenu>Ayarlar</guisubmenu> "
"<guisubmenu>Konversation Yapılandır</guisubmenu> </menuchoice> ögesini "
"seçin, <guilabel>Davranış</guilabel> ögesini genişletin, <guilabel>Sohbet "
"Penceresi</guilabel>ne tıklayın ve <guilabel>Tüm sohbet pencerelerinde elle "
"eklenmiş satırları göster</guilabel> kutusunu işaretleyin."

#. Tag: para
#: index.docbook:2135
#, no-c-format
msgid ""
"To make &konversation; automatically insert a <interface>Marker Line</"
"interface> whenever you do an <userinput><command>/away</command> "
"<replaceable>msg</replaceable></userinput> command, see <link linkend="
"\"identity-away\">Setting your identity</link>."
msgstr ""
"&konversation;'ın <userinput><command>/away</command> <replaceable>ileti</"
"replaceable></userinput> komutunu her çalıştırdığınızda, otomatik olarak "
"<interface>İşaretçi Satırı</interface> ögesini eklemesi için, <link linkend="
"\"identity-away\">Kimiliğiniz ayarlayın</link> bölümüne gözatın."

#. Tag: title
#: index.docbook:2146
#, no-c-format
msgid "Logging"
msgstr "Günlükleme"

#. Tag: para
#: index.docbook:2148
#, no-c-format
msgid ""
"If logging is enabled, &konversation; keeps a log of each <interface>Server</"
"interface>, <link linkend=\"channel-screen-tour\">Channel</link>, and <link "
"linkend=\"query\">Private conversation (query)</link> session. Each session "
"is stored in a log file on disk. When you open the same session again, "
"&konversation; appends to the log."
msgstr ""
"Günlükleme etkinse, her bir <interface>Sunucu</interface>, <link linkend="
"\"channel-screen-tour\">Kanal</link>, ve <link linkend=\"query\">Özel sohbet "
"(sorgu)</link> oturmunun günlüğü, &konversation; tarafından tutulacaktır. "
"Her oturum diskteki bir günlük dosyasında saklanır. Aynı oturumu tekrar "
"açtığınızda, &konversasyon; günlüğe ekleyecektir."

#. Tag: para
#: index.docbook:2155
#, no-c-format
msgid ""
"Whenever you open a session again, approximately the last 1024 characters of "
"the previous session are read from the tail of the log and shown on the "
"screen."
msgstr ""
"Bir oturumu tekrar açtığınızda, önceki oturumun yaklaşık 1024 karakteri "
"günlük dosyasının sonundan okunur ve ekranda gösterilir."

#. Tag: para
#: index.docbook:2159
#, no-c-format
msgid ""
"As your session continues, messages scroll off the top of the display. You "
"can scroll backwards to view these messages. Eventually, in order to "
"conserve memory, the oldest messages are discarded from the scroll. This is "
"called the <guilabel>Scrollback limit</guilabel>. Messages that disappear "
"from the display because of the <guilabel>Scrollback limit</guilabel> are "
"still available in the log file, if logging is enabled."
msgstr ""
"Oturumunuz devam ederken, iletiler ekranın üst kısmından çıkar. Bu iletileri "
"görüntülemek için geriye doğru ilerletebilirsiniz. Sonunda, hafızayı korumak "
"için, en eski iletiler kaydırmadan atılır. Buna <guilabel>Geçimiş sınırı</"
"guilabel> denir. Günlüğe kaydetme özelliği etkinleştirilmişse, "
"<guilabel>Geçimiş sınırı</guilabel> nedeniyle ekrandan kaybolan iletiler "
"günlüğe kaydedilir."

#. Tag: para
#: index.docbook:2166
#, no-c-format
msgid ""
"To view the logfile for a session, click the tab for the session to make it "
"the current session and choose <menuchoice> <guisubmenu>Window</guisubmenu> "
"<guisubmenu>Open Logfile</guisubmenu> </menuchoice> from the main menu. "
"<action>A new tab appears</action> displaying the log file."
msgstr ""
"Bir oturumun günlük dosyasını görüntülemek, oturumun sekmesini geçerli "
"oturum haline getirmek için tıklayın ve ana menüden <menuchoice> "
"<guisubmenu>Pencere</guisubmenu> <guisubmenu>Günlük Dosyasını Aç</"
"guisubmenu> </menuchoice> ögesini seçin. Günlük dosyasını gösteren "
"<action>Yeni bir sekme görünecektir</action>."

#. Tag: screeninfo
#: index.docbook:2177
#, no-c-format
msgid "<screeninfo>Logfile</screeninfo>"
msgstr "<screeninfo>Günlük Dosyası</screeninfo>"

#. Tag: phrase
#: index.docbook:2192
#, no-c-format
msgid "<phrase>Logfile</phrase>"
msgstr "<phrase>Günlük Dosyası</phrase>"

#. Tag: para
#: index.docbook:2200
#, no-c-format
msgid ""
"The messages in the log file are displayed here. The oldest messages are at "
"the top and the most recent are at the bottom."
msgstr ""
"Günlük dosyasındaki iletiler burada gösterilir. En eski iletiler en üsteyken "
"en güncel iletiler aşağıdadır."

#. Tag: para
#: index.docbook:2202
#, no-c-format
msgid "Click this button to save the log file to another file."
msgstr "Günlük dosyasını başka bir dosyaya kaydetmek için bu düğmeye tıklayın."

#. Tag: para
#: index.docbook:2203
#, no-c-format
msgid ""
"Click to refresh the log file display. While you are viewing a log file, "
"newer messages in the corresponding session are <emphasis>not</emphasis> "
"automatically added to the log file display. Use this button to view the "
"most recent messages."
msgstr ""
"Günlük dosyası görüntüsünü yenilemek için tıklayın. Bir günlük dosyasını "
"görüntülerken, karşılık gelen oturumdaki yeni iletiler günlük dosyası "
"ekranına otomatik olarak <emphasis>eklenmez</emphasis>. En son iletileri "
"görüntülemek için bu düğmeyi kullanın."

#. Tag: para
#: index.docbook:2207
#, no-c-format
msgid "Click to erase the log file display and the log file on disk."
msgstr ""
"Günlük dosyası görüntüsünü ve günlük dosyasını diskten silmek için tıklayın."

#. Tag: para
#: index.docbook:2209
#, no-c-format
msgid ""
"Use this box to set the maximum size of the scroll. This setting does take "
"effect only for newly opened log tabs. The last changed value of the scroll "
"size will be used on &konversation;'s next start. Each log file may have a "
"separate setting."
msgstr ""
"Kaydırma işleminin azami boyutunu ayarlamak için bu kutuyu kullanın. Bu ayar "
"yalnızca yeni açılan günlük sekmeleri için geçerli olacaktır. Kaydırma "
"boyutunun son değiştirilen değeri, &konversation;'ın bir sonraki "
"başlatılışında kullanılacaktır. Her günlük dosyası ayrı bir ayara sahip "
"olabilir."

# u#, no-c-format
#. Tag: para
#: index.docbook:2216
#, no-c-format
msgid ""
"The <guilabel>Scrollback limit</guilabel> can be changed by choosing "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"&konversation;</guisubmenu> </menuchoice> on the main menu, then expand "
"<guilabel>Behavior</guilabel> and click on <guilabel>Chat Window</guilabel>. "
"The <guilabel>Scrollback limit</guilabel> box appears on this screen. If you "
"set it to <guilabel>Unlimited</guilabel> (&ie; zero), messages are not "
"discarded from the scroll."
msgstr ""
"<guilabel>Geçmiş sınırı</guilabel>, ana menüden <guisubmenu>Ayarlar</"
"guisubmenu> <guisubmenu>&konversation; Yapılandır</guisubmenu> </menuchoice> "
"ögesini seçip, ardından <guilabel>Davranış</guilabel> ögesini genişletip, "
"<guilabel>Sohbet Penceresi</guilabel> ögesine tıklanarak değiştirilebilir. "
"<guilabel>Geçmiş sınırı</guilabel> kutusu ekranda görünecektir. "
"<guilabel>Sınırsız</guilabel> (&ie; sıfır), olarak ayarlarsanız, iletiler "
"geçmişten kaldırılmazlar."

# u#, no-c-format
#. Tag: para
#: index.docbook:2226
#, no-c-format
msgid ""
"You can enable or disable logging and set other logging options, by choosing "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"&konversation;</guisubmenu> </menuchoice> on the main menu, then expand "
"<guilabel>Behavior</guilabel> and click on <guilabel>Logging</guilabel>."
msgstr ""
"Günlüğü etkinleştirebilir, devre dışı bırakabilir ve diğer günlüğe kaydetme "
"seçeneklerini ayarlayabilirsiniz. Bunun için ana menüden "
"<guisubmenu>Ayarlar</guisubmenu> <guisubmenu>&konversation; Yapılandır</"
"guisubmenu> </menuchoice> ögesini seçin, ardından <guilabel>Davranış</"
"guilabel> ögesini genişletin ve <guilabel>Günlükleme</guilabel> ögesine "
"tıklayın."

#. Tag: title
#: index.docbook:2239
#, no-c-format
msgid "&konversation; commands"
msgstr "&konversation; komutları"

#. Tag: para
#: index.docbook:2241
#, no-c-format
msgid ""
"The following commands are interpreted by &konversation; and may differ from "
"standard &irc; commands. Items inside square brackets are optional. Items "
"separated by bar (|) are alternate forms of the command. Commands not listed "
"here are sent to the server as entered."
msgstr ""
"Aşağıdaki komutlar, &konversation; ile yorumlanır ve standart &irc; "
"komutlarından farklı olabilir. Köşeli parantez içerisindeki öğeler isteğe "
"bağlıdır. Boru (|) ile ayrılmış ögeler, komutun alternatif formlarıdır. "
"Burada listelenmeyen komutlar, girilen sunucuya gönderilir."

#. Tag: userinput
#: index.docbook:2250
#, no-c-format
msgid "<command>/me</command> <replaceable>msg</replaceable>"
msgstr "<command>/me</command> <replaceable>ileti</replaceable>"

#. Tag: userinput
#: index.docbook:2256
#, no-c-format
msgid "<command>/ame</command> <replaceable>msg</replaceable>"
msgstr "<command>/ame</command> <replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:2257
#, no-c-format
msgid ""
"Like the <userinput><command>/me</command></userinput> command above except "
"that the message is sent to all the channels and queries you have open on "
"all the servers you have connected in &konversation;."
msgstr ""
"Yukarıdaki <userinput><command>/me</command></userinput> komutu gibidir, "
"iletinin &konversation; ile bağlanılan tüm sunucularda açık olan tüm "
"kanallara ve sorgulara gönderilmesini sağlar."

#. Tag: userinput
#: index.docbook:2262
#, no-c-format
msgid ""
"<command>/join</command> <replaceable>channel</replaceable> "
"<replaceable>[pwd]</replaceable>"
msgstr ""
"<command>/join</command> <replaceable>kanal</replaceable> "
"<replaceable>[pwd]</replaceable>"

#. Tag: para
#: index.docbook:2263
#, no-c-format
msgid ""
"Joins <userinput><replaceable>channel</replaceable></userinput>. If the "
"server permits it, and if the channel does not already exist, it is created "
"and you are the channel operator. If the channel requires a password in "
"order to join, specify as <userinput><replaceable>pwd</replaceable></"
"userinput>. Most channel names begin with <userinput><replaceable>#</"
"replaceable></userinput>."
msgstr ""
"<userinput><replaceable>kanala</replaceable></userinput> girer. Sunucu izin "
"veriyorsa, kanal zaten mevcut değilse oluşturulur ve kanal operatörü "
"yapılırsınız. Kanal katılmak için parola gerektiriyorsa, "
"<userinput><replaceable>pwd</replaceable></userinput> olarak belirtilir. Bir "
"çok kanal ismi <userinput><replaceable>#</replaceable></userinput> ile "
"başlar."

#. Tag: userinput
#: index.docbook:2268
#, no-c-format
msgid ""
"<command>/j</command> <replaceable>channel</replaceable> <replaceable>[pwd]</"
"replaceable>"
msgstr ""
"<command>/j</command> <replaceable>kanal</replaceable> <replaceable>[pwd]</"
"replaceable>"

#. Tag: para
#: index.docbook:2269
#, no-c-format
msgid "Same as <userinput><command>/join</command></userinput> above."
msgstr "Üstteki <userinput><command>/join</command></userinput> ile aynıdır."

#. Tag: userinput
#: index.docbook:2273
#, no-c-format
msgid ""
"<command>/part</command> <replaceable>[channel]</replaceable> "
"<replaceable>[reason]</replaceable>"
msgstr ""
"<command>/part</command> <replaceable>[kanal]</replaceable> "
"<replaceable>[sebep]</replaceable>"

#. Tag: para
#: index.docbook:2274
#, no-c-format
msgid ""
"Leaves <userinput><replaceable>channel</replaceable></userinput> with "
"<userinput><replaceable>reason</replaceable></userinput> and closes the "
"corresponding <interface>channel</interface> tab. Within a &konversation; "
"channel or query tab, you can just enter <userinput><command>/part</"
"command></userinput> which closes that channel or query with your default "
"reason as given in the <link linkend=\"identity\">Settings</link>."
msgstr ""
"<userinput><replaceable>sebep</replaceable></userinput> göstererek, "
"<userinput><replaceable>kanalı</replaceable></userinput> ve ilgili tüm "
"<userinput><replaceable>kanal</replaceable></userinput> sekmelerini kapatır. "
"Bir &konversation; kanalı veya sorgu sekmesinde, varsayılan olarak <link "
"linkend=\"identity\">ayarlarda</link> verilen şekilde bu kanalı veya sorguyu "
"kapatan <userinput><command>/part</command> </userinput> değerini "
"girebilirsiniz"

#. Tag: userinput
#: index.docbook:2279
#, no-c-format
msgid ""
"<command>/leave</command> <replaceable>[channel]</replaceable> "
"<replaceable>[reason]</replaceable>"
msgstr ""
"<command>/leave</command> <replaceable>[kanal]</replaceable> "
"<replaceable>[sebep]</replaceable>"

#. Tag: para
#: index.docbook:2280
#, no-c-format
msgid "Same as <userinput><command>/part</command></userinput> above."
msgstr "Üstteki <userinput><command>/part</command></userinput> ile aynıdır."

#. Tag: para
#: index.docbook:2284
#, no-c-format
msgid ""
"When entered in any channel, query, or DCC tab, disconnects from the "
"corresponding server and closes all channel, query, or DCC tabs open on that "
"server."
msgstr ""
"Herhangi bir kanalda, sorguda veya DCC sekmesine girildiğinde ilgili "
"sunucudan bağlantı kopar ve o sunucuda açılan tüm kanal, sorgu veya DCC "
"sekmeleri kapatılır."

#. Tag: userinput
#: index.docbook:2288
#, no-c-format
msgid ""
"<command>/notice</command> <replaceable>nick|channel</replaceable> "
"<replaceable>msg</replaceable>"
msgstr ""
"<command>/notice</command> <replaceable>rumuz|kanal</replaceable> "
"<replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:2289
#, no-c-format
msgid ""
"Sends <userinput><replaceable>msg</replaceable></userinput> to the user with "
"&i18n-nickname; <userinput><replaceable>nick</replaceable></userinput> or to "
"everyone in <userinput><replaceable>channel</replaceable></userinput>. The "
"following is an example of what appears to you in the channel tab"
msgstr ""
"&i18n-nickname; <userinput><replaceable>rumuzlu</replaceable></userinput> "
"kullanıcıya veya <userinput><replaceable>kanaldaki</replaceable></userinput> "
"herkese <userinput><replaceable>ileti</replaceable></userinput> gönderir. "
"Aşağıda, kanal sekmesinde görünenlerin bir örneği verilmiştir."

#. Tag: computeroutput
#: index.docbook:2292
#, no-c-format
msgid ""
"[17:14] [Notice] Sending notice \"I think I understand\" to #konversation"
msgstr ""
"[17:14] [Notice] Sending notice \"I think I understand\" to #konversation"

#. Tag: para
#: index.docbook:2294
#, no-c-format
msgid "And this is what the recipients see"
msgstr "Ve alıcıların gördükleri de budur"

#. Tag: computeroutput
#: index.docbook:2296
#, no-c-format
msgid "[17:15] [Notice] -Eisfuchs- I think I understand"
msgstr "[17:15] [Notice] -Eisfuchs- I think I understand"

#. Tag: para
#: index.docbook:2302
#, no-c-format
msgid ""
"Creates a new tab with the user's <userinput><replaceable>nick</"
"replaceable></userinput> for private conversation, commonly known on &irc; "
"as a <link linkend=\"query\">Query</link>. Everything written here is only "
"visible to you and your query partner. You may enter more than one &i18n-"
"nickname; separated by spaces and a query tab will be opened for each &i18n-"
"nickname;. Each such query tab will be private between you and the query "
"partner."
msgstr ""
"&irc; içinde <link linkend=\"query\">Sorgu</link> olarak bilinen, özel "
"sohbetler için <userinput> kullanıcının <replaceable>rumuzunu</replaceable></"
"userinput> kullanarak bir sekme oluşturur. Burada yazılan her şey yalnızca "
"siz ve sorgu eşiniz tarafından görülebilir. Birden fazla &i18n-nickname; "
"boşluklarla ayrılmış olarak girebilir ve her &i18n-nickname; için bir sorgu "
"sekmesi açılacaktır. Bu tür her sorgu sekmesi sizinle sorgu eşiniz arasında "
"gizli olacaktır."

#. Tag: term
#: index.docbook:2306
#, no-c-format
msgid ""
"<userinput><command>/msg </command><replaceable>nick|channel</replaceable></"
"userinput> <userinput><replaceable>message</replaceable></userinput>"
msgstr ""
"<userinput><command>/msg </command><replaceable>rumuz|kanal</replaceable></"
"userinput> <userinput><replaceable>ileti</replaceable></userinput>"

#. Tag: para
#: index.docbook:2308
#, no-c-format
msgid ""
"Sends a private message to the user with &i18n-nickname; "
"<userinput><replaceable>nick</replaceable></userinput> or to all users in "
"<userinput><replaceable>channel</replaceable></userinput>. Unlike "
"<userinput><command>/query</command></userinput>, does not open a new tab. "
"If <userinput><replaceable>message</replaceable></userinput> begins with "
"<userinput><command>/me </command></userinput>, the message is formatted in "
"the same manner as a <userinput><command>/me</command></userinput> command."
msgstr ""
"&i18n-nickname; <userinput><replaceable>rumuzlu</replaceable></userinput> "
"kullanıcıya veya <userinput><replaceable>kanaldaki</replaceable></userinput> "
"tüm kullancılara, özel bir ileti gönderir. <userinput><replaceable>/query</"
"replaceable></userinput> gibi yeni bir sekmek açmak. eğer "
"<userinput><replaceable>ileti</replaceable></userinput>, "
"<userinput><replaceable>/me</replaceable></userinput> ile başlıyorsa, ileti "
"<userinput><replaceable>/me</replaceable></userinput> komutunda olduğu gibi "
"biçimlendirilir."

#. Tag: para
#: index.docbook:2312
#, no-c-format
msgid "Examples"
msgstr "Örnekler"

#. Tag: replaceable
#: index.docbook:2314
#, no-c-format
msgid "/msg Eisfuchs I need some help with the msg command"
msgstr "/msg Öööf msg komutu hakkında biraz yardıma ihtiyacım var"

#. Tag: replaceable
#: index.docbook:2316
#, no-c-format
msgid "/msg #konversation New version of Konvi is online!"
msgstr "/msg #konversation Yeni sürümü Konvi artık çevrim içi!"

#. Tag: replaceable
#: index.docbook:2318
#, no-c-format
msgid "/msg Eisfuchs /me is compiling the Handbook right now."
msgstr "/msg Öööf /me şuanda yeni El Kitabını derliyor."

#. Tag: term
#: index.docbook:2324
#, no-c-format
msgid ""
"<userinput><command>/smsg </command><replaceable>nick|channel</replaceable></"
"userinput> <userinput><replaceable>message</replaceable></userinput>"
msgstr ""
"<userinput><command>/smsg </command><replaceable>rumuz|kanal</replaceable></"
"userinput> <userinput><replaceable>ileti</replaceable></userinput>"

#. Tag: para
#: index.docbook:2326
#, no-c-format
msgid ""
"Same as <userinput><command>/msg</command></userinput> except the message is "
"not displayed on your screen. This is useful for preventing passwords and "
"other sensitive information from remaining exposed on your screen or being "
"logged."
msgstr ""
"<userinput><command>/msg</command></userinput> ile aynıdır, ancak ileti "
"ekranınızda gözükmez. Bu, parolaların ve diğer hassas bilgilerin ekranınızda "
"kalmasına veya günlüğe kaydedilmesine engel olmak için kullanışlıdır."

#. Tag: term
#: index.docbook:2331
#, no-c-format
msgid ""
"<userinput><command>/amsg </command><replaceable>nick|channel</replaceable></"
"userinput> <userinput><replaceable>message</replaceable></userinput>"
msgstr ""
"<userinput><command>/amsg </command><replaceable>rumuz|kanal</replaceable></"
"userinput> <userinput><replaceable>ileti</replaceable></userinput>"

#. Tag: para
#: index.docbook:2333
#, no-c-format
msgid ""
"Like the <userinput><command>/msg</command></userinput> command above except "
"that the message is sent to all the channels and queries you have open on "
"all the servers you have connected in &konversation;."
msgstr ""
"Yukarıdaki <userinput><command>/msg</command></userinput> komutu gibidir, "
"ancak ileti &konversation; içinde bağlandığınız sunuculardaki  tüm açık "
"kanallar ve sorgulara gönderilir."

#. Tag: userinput
#: index.docbook:2338
#, no-c-format
msgid "<command>/op </command> <replaceable>nick</replaceable>"
msgstr "<command>/op </command> <replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:2339
#, no-c-format
msgid ""
"When entered into a channel tab, attempts to give "
"<userinput><replaceable>nick</replaceable></userinput> operator privilege "
"for the channel. May not work if you lack sufficient privilege in the "
"channel (you must be a channel operator yourself). You may enter more than "
"one &i18n-nickname; separated by spaces."
msgstr ""
"Kanal sekmesine girildiğinde, kanal için <userinput><replaceable>rumuz</"
"replaceable></userinput> operatör ayrıcalığı verilmeye çalışılır. Kanalda "
"yeterli hak yoksa çalışmayabilir (kendiniz bir kanal operatörünüz "
"olmalısınız). Birden fazla boşluklarla ayrılmış &i18n-nickname; "
"girebilirsiniz."

#. Tag: userinput
#: index.docbook:2346
#, no-c-format
msgid "<command>/deop </command><replaceable>nick</replaceable>"
msgstr "<command>/deop </command><replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:2347
#, no-c-format
msgid ""
"When entered into a channel tab, takes away channel operator privilege from "
"<userinput><replaceable>nick</replaceable></userinput>. You may enter more "
"than one &i18n-nickname; separated by spaces."
msgstr ""
"Bir kanal sekmesine girildiğinde, kanal operatörü ayrıcalığını "
"<userinput><replaceable>rumuzdan</replaceable></userinput> alır. Birden "
"fazla boşluklarla ayrılmış &i18n-nickname; girebilirsiniz."

#. Tag: userinput
#: index.docbook:2352
#, no-c-format
msgid "<command>/oper </command><replaceable>[nick]</replaceable>"
msgstr "<command>/oper </command><replaceable>[rumuz]</replaceable>"

#. Tag: para
#: index.docbook:2353
#, no-c-format
msgid ""
"Grants the user with &i18n-nickname; <userinput><replaceable>nick</"
"replaceable></userinput> &irc;-Op (Administrator) privilege. This only works "
"if the &i18n-nickname; is listed in the server's O: line. &irc;-Ops have the "
"privilege to <userinput><command>/kill</command></userinput> &i18n-nickname;"
"s, <userinput><command>/connect</command></userinput> servers to the &irc; "
"network, and more. If <userinput><replaceable>nick</replaceable></userinput> "
"is not entered, attempts to grant yourself &irc;-Op privilege. You will be "
"prompted for your &irc;-Op user name and password in either case."
msgstr ""
"&i18n-nickname; <userinput><replaceable>takma ada</replaceable></userinput> "
"sahip kullanıcıya &irc;-Op (Yönetici) hakları verir. Bu yalnızca &i18n-"
"nickname; sunucunun O: satırında listelenmişse çalışır. &irc;-Ops &i18n-"
"nickname;leri <userinput><command>/kill</command></userinput> etme, "
"sunucuları &irc;  ağına <userinput><command>/connect</command></userinput> "
"etme vs. haklarına sahiptir. <userinput><replaceable>takma ad</replaceable></"
"userinput> girilmemişse, kendinize &irc;-Op hakları vermeye çalışır. İki "
"durumda da &irc;-Op kullanıcı adı ve parolanız sorulur."

#. Tag: userinput
#: index.docbook:2361
#, no-c-format
msgid "<command>/voice </command> <replaceable>nick</replaceable>"
msgstr "<command>/voice </command> <replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:2362
#, no-c-format
msgid ""
"In certain channels (with +m flag), users cannot send messages unless they "
"have voice privilege. This command attempts to give "
"<userinput><replaceable>nick</replaceable></userinput> voice privilege. You "
"must have channel operator privilege to execute this command. This command "
"is mostly used when you are an operator for a moderated channel."
msgstr ""
"Bazı kanallarda (+m bayrağı ile) kullanıcılar, ses hakkı olmadan ileti "
"gönderemezler. Bu komut, <userinput><replaceable>rumuza</replaceable></"
"userinput> ses hakkı vermeye çalışır. Bu komutu yürütmek için kanal "
"operatörü hakkınız olmalıdır. Bu komut, çoğunlukla, yönetilen bir kanalın "
"operatörü olduğunuzda kullanılır."

#. Tag: userinput
#: index.docbook:2369
#, no-c-format
msgid "<command>/unvoice </command> <replaceable>nick</replaceable>"
msgstr "<command>/unvoice </command> <replaceable>rumuz</replaceable>"

#. Tag: para
#: index.docbook:2370
#, no-c-format
msgid ""
"Takes away voice privilege from <userinput><replaceable>nick</replaceable></"
"userinput> in the channel."
msgstr ""
"Kanaldaki <userinput><replaceable>Rumuz</replaceable></userinput> üstünde "
"ses hakkını alır."

#. Tag: userinput
#: index.docbook:2374
#, no-c-format
msgid ""
"<command>/topic </command><replaceable>[channel]</replaceable> "
"<replaceable>[message]</replaceable>"
msgstr ""
"<command>/topic </command><replaceable>[kanal]</replaceable> "
"<replaceable>[ileti]</replaceable>"

#. Tag: para
#: index.docbook:2375
#, no-c-format
msgid ""
"Attempts to set the topic of <userinput><replaceable>channel</replaceable></"
"userinput> to <userinput><replaceable>message</replaceable></userinput>. "
"When entered in a channel tab, <userinput><replaceable>channel</"
"replaceable></userinput> may be omitted and defaults to the channel active "
"in the tab. If <userinput><replaceable>message</replaceable></userinput> is "
"omitted, displays the current topic of the channel. Changing a channel topic "
"may fail if you lack sufficient privilege."
msgstr ""
"<userinput><replaceable>Kanal konusunu</replaceable></userinput> "
"<userinput><replaceable>iletiye</replaceable></userinput> vermeye çalışır. "
"Kanal sekmesine girildiğinde, <userinput><replaceable>kanal</replaceable></"
"userinput> atlanabilir ve sekmedeki kanala varsayılanlar ayarlanır. "
"<userinput><replaceable>ielti</replaceable></userinput> yoksa, kanalın "
"geçerli konusu görüntülenir. Yeterli hakkınız yoksa bir kanal konusunun "
"değiştirilmesi başarısız olabilir."

#. Tag: userinput
#: index.docbook:2381
#, no-c-format
msgid "<command>/away </command> <replaceable>reason</replaceable>"
msgstr "<command>/away </command> <replaceable>sebep</replaceable>"

#. Tag: para
#: index.docbook:2382
#, no-c-format
msgid ""
"If anyone tries to send you a private message or invite you to a channel, "
"they will be told that you are away from your workstation for "
"<userinput><replaceable>reason</replaceable></userinput>. To change your "
"state back to normal, enter <userinput><command>/away</command></userinput> "
"without a <userinput><replaceable>reason</replaceable></userinput>."
msgstr ""
"Herkes sizi özel bir ileti göndermeye ya da bir kanala davet etmeye "
"çalışırsa, iş istasyonunuzdan uzak durduğunuz <userinput><replaceable>sebep</"
"replaceable></userinput> olarak yazılır. Durumunu normale geri döndürmek "
"için, bir <userinput><command>sebep</command></userinput> olmadan "
"<userinput><command>/away</command></userinput> komutunu girin."

#. Tag: userinput
#: index.docbook:2387
#, no-c-format
msgid "<command>/aaway </command><replaceable>reason</replaceable>"
msgstr "<command>/aaway </command><replaceable>sebep</replaceable>"

#. Tag: para
#: index.docbook:2388
#, no-c-format
msgid ""
"Like the <userinput><command>/away</command></userinput> command above "
"except that the command is sent to all the servers you have connected in "
"&konversation;."
msgstr ""
"Üstteki <userinput><command>/away</command></userinput> komutu gibidir, "
"ancak &konversation; içinde bağlı olduğunuz tüm sunuculara gönderilir."

#. Tag: userinput
#: index.docbook:2393
#, no-c-format
msgid ""
"<command>/invite </command><replaceable>nick</replaceable> "
"<replaceable>[channel]</replaceable>"
msgstr ""
"<command>/invite </command><replaceable>rumuz</replaceable> "
"<replaceable>[kanal]</replaceable>"

#. Tag: para
#: index.docbook:2394
#, no-c-format
msgid ""
"Invites the user with &i18n-nickname; <userinput><replaceable>nick</"
"replaceable></userinput> to join <userinput><replaceable>channel</"
"replaceable></userinput>. This command is especially useful if the channel "
"is invite-only. When entered in a channel tab, "
"<userinput><replaceable>channel</replaceable></userinput> may be omitted."
msgstr ""
"&i18n-nickname;<userinput><replaceable>rumuzlu</replaceable></userinput> "
"kullanıcıyı, <userinput><replaceable>kanala</replaceable></userinput> davet "
"eder. Bu komut özellikle kanal davetiye ile kabul ediyorsa kullanışlıdır. "
"Bir kanal sekmesine girildiğinde, <userinput><replaceable>kanal</"
"replaceable></userinput> olmayabilir."

#. Tag: userinput
#: index.docbook:2398
#, no-c-format
msgid ""
"<command>/exec </command><replaceable>script</replaceable> "
"<replaceable>[parameters]</replaceable>"
msgstr ""
"<command>/exec </command><replaceable>betik</replaceable> "
"<replaceable>[parametreler]</replaceable>"

#. Tag: para
#: index.docbook:2399
#, no-c-format
msgid ""
"Executes the &konversation;-compatible shell script named "
"<userinput><replaceable>script</replaceable></userinput>, passing it "
"<userinput><replaceable>parameters</replaceable></userinput>. See <link "
"linkend=\"scripting\">Scripting</link> for more information on using and "
"writing scripts."
msgstr ""
"&konversation; uyumlu olan, <userinput><replaceable>betikleri</replaceable></"
"userinput> çalıştırır, <userinput><replaceable>parametreleri</replaceable></"
"userinput> de gönderebilir. Betik yazma ve kullanma hakkında daha fazla "
"bilgi için <link linkend=\"scripting\">Betik Yazma</link> bölümüne gözatın."

#. Tag: para
#: index.docbook:2404
#, no-c-format
msgid "Examples:"
msgstr "Örnekler:"

#. Tag: replaceable
#: index.docbook:2406 index.docbook:2560
#, no-c-format
msgid "/sayversion"
msgstr "/sayversion"

#. Tag: para
#: index.docbook:2408
#, fuzzy, no-c-format
#| msgid ""
#| "Sends your system's &konversation;, &Qt;, &kf5; and &plasma; version "
#| "numbers to the channel."
msgid ""
"Sends your system's &konversation;, &Qt;, &kde-frameworks; and &plasma; "
"version numbers to the channel."
msgstr ""
"Sistemdeki &konversation;, &Qt;, &kf5; ve &plasma; uygulamalarının sürüm "
"numaralarını, kanala gönderir."

#. Tag: replaceable
#: index.docbook:2410 index.docbook:2564
#, no-c-format
msgid "/exec cmd uname -a"
msgstr "/exec cmd uname -a"

#. Tag: para
#: index.docbook:2412
#, no-c-format
msgid ""
"Sends your &Linux; version string (the output of <quote>uname -a</quote>) to "
"the channel."
msgstr ""
"&Linux; sürüm dizgesini (<quote>uname -a</quote> komutunun çıktısı), kanala "
"gönderir."

#. Tag: userinput
#: index.docbook:2418
#, no-c-format
msgid "<command>/notify </command><replaceable>[nick]</replaceable>"
msgstr "<command>/notify </command><replaceable>[rumuz]</replaceable>"

#. Tag: para
#: index.docbook:2419
#, no-c-format
msgid ""
"Adds or removes <userinput><replaceable>nick</replaceable></userinput> from "
"your <link linkend=\"nicksonline\">Watched Nicks</link> list. If the &i18n-"
"nickname; is already in the list, it is removed. If it is not in the list, "
"it is added. If <userinput><replaceable>nick</replaceable></userinput> is "
"omitted, displays the current list of watched &i18n-nickname;s."
msgstr ""
"<userinput><replaceable>rumuzu</replaceable></userinput>, <link linkend="
"\"nicksonline\">İzlenen Rumuzlar</link> listesinden çıkarır veya ekler. "
"Listede yoksa, ekler. <userinput><replaceable>rumuz</replaceable></"
"userinput> yoksa, izlenen &i18n-nickname;'leri gösterir."

#. Tag: userinput
#: index.docbook:2427
#, no-c-format
msgid ""
"<command>/kick </command><replaceable>nick</replaceable> "
"<replaceable>reason</replaceable>"
msgstr ""
"<command>/kick </command><replaceable>rumuz</replaceable> "
"<replaceable>sebep</replaceable>"

#. Tag: para
#: index.docbook:2428
#, no-c-format
msgid ""
"When entered in a channel tab, attempts to kick the user with &i18n-"
"nickname; <userinput><replaceable>nick</replaceable></userinput> from the "
"channel with <userinput><replaceable>reason</replaceable></userinput>. If "
"<userinput><replaceable>reason</replaceable></userinput> is not entered, "
"defaults to the reason in the <link linkend=\"identity\">Settings</link>. "
"This command may only be used in a channel tab."
msgstr ""
"Kanal sekmesine girildiğinde, &i18n-nickname;  "
"<userinput><replaceable>rumuzlu</replaceable></userinput> kullanıcıyı, "
"<userinput><replaceable>sebep</replaceable></userinput> gösterek atmaya "
"çalışır. Eğer <userinput><replaceable>sebep</replaceable></userinput> "
"girilmediyse, <link linkend=\"identity\">Ayarlar</link> içindeki varsayılan "
"sebep gösterilir. Bu komut, sadece kanal sekmesinde kullanılabilir."

#. Tag: userinput
#: index.docbook:2436
#, no-c-format
msgid ""
"<command>/ban </command> [<command>-host</command>|<command>-domain</"
"command>| <command>-userhost</command>|<command>-userdomain</command>] "
"<replaceable>[channel]</replaceable> <replaceable>user</replaceable>|"
"<replaceable>mask</replaceable>"
msgstr ""
"<command>/ban </command> [<command>-host</command>|<command>-domain</"
"command>| <command>-userhost</command>|<command>-userdomain</command>] "
"<replaceable>[kanal]</replaceable> <replaceable>kullanıcı</replaceable>|"
"<replaceable>maske</replaceable>"

#. Tag: para
#: index.docbook:2438
#, fuzzy, no-c-format
#| msgid ""
#| "Attempts to ban the <userinput><replaceable>user</replaceable></"
#| "userinput> or <userinput><replaceable>mask</replaceable></userinput> from "
#| "<userinput><replaceable>channel</replaceable></userinput>. When entered "
#| "in a channel tab, <userinput><replaceable>channel</replaceable></"
#| "userinput> may be omitted. For more information on hosts, domains, and "
#| "masks, see the documents at <ulink url=\"http://www.irchelp.org/"
#| "\">irchelp.org</ulink>. To get the current ban list for a channel, enter "
#| "<userinput><command>/mode </command><replaceable>channel</replaceable> "
#| "<command>b</command></userinput>."
msgid ""
"Attempts to ban the <userinput><replaceable>user</replaceable></userinput> "
"or <userinput><replaceable>mask</replaceable></userinput> from "
"<userinput><replaceable>channel</replaceable></userinput>. When entered in a "
"channel tab, <userinput><replaceable>channel</replaceable></userinput> may "
"be omitted. For more information on hosts, domains, and masks, see the "
"documents at <ulink url=\"https://www.irchelp.org/\">irchelp.org</ulink>. To "
"get the current ban list for a channel, enter <userinput><command>/mode </"
"command><replaceable>channel</replaceable> <command>b</command></userinput>."
msgstr ""
"<userinput><replaceable>Kullanıcıyı</replaceable></userinput> veya "
"<userinput><replaceable>maskeyi</replaceable></userinput> "
"<userinput><replaceable>kanaldan</replaceable></userinput> atmaya çalışır. "
"Kanal sekmesine girildiğinde, <userinput><replaceable>kanal</replaceable></"
"userinput> yok olabilir. Makineler, alan adları ve maskeler hakkında daha "
"fazla bilgi için <ulink url=\"http://www.irchelp.org/\">irchelp.org</ulink> "
"belgesine gözatın. Kanaldaki mevcut yasaklama listesini almak için "
"<userinput><command>/mode </command><replaceable>channel</replaceable> "
"<command>b</command></userinput> komutunu kullanın."

#. Tag: userinput
#: index.docbook:2447
#, no-c-format
msgid ""
"<command>/unban </command> <replaceable>[channel]</replaceable> "
"<replaceable>pattern</replaceable>"
msgstr ""
"<command>/unban </command> <replaceable>[kanal]</replaceable> "
"<replaceable>desen</replaceable>"

#. Tag: para
#: index.docbook:2448
#, no-c-format
msgid ""
"Reverts a previous banning from a channel. When entered in a channel tab, "
"<userinput><replaceable>channel</replaceable></userinput> may be omitted."
msgstr ""
"Kanalda önceden yapılmış bir yasağı geri döndürür. Bir kanal sekmesine "
"girildiğinde, <userinput><replaceable>kanal</replaceable></userinput> "
"olmayabilir."

#. Tag: userinput
#: index.docbook:2454
#, no-c-format
msgid ""
"<command>/ignore </command> [<command>-all</command>] <replaceable>nick</"
"replaceable>"
msgstr ""
"<command>/ignore </command> [<command>-all</command>] <replaceable>rumuz</"
"replaceable>"

#. Tag: para
#: index.docbook:2455
#, no-c-format
msgid ""
"Adds <userinput><replaceable>nick</replaceable></userinput> to your Ignore "
"list. You may specify more than one &i18n-nickname; separated by spaces. "
"Channel messages from users on your Ignore list are not displayed. In "
"addition, if you enter <userinput><command>-all</command></userinput>, all "
"message types (queries, notices, &CTCP;, DCC, and Exceptions) from the user "
"are ignored as well as channel messages."
msgstr ""
"<userinput><replaceable>rumuzu</replaceable></userinput> Yoksayma listenize "
"ekler. Boşluklarla ayrılmış birden fazla &i18n-nickname; belirtebilirsiniz. "
"Yoksayma listenizdeki kullanıcılardan gelen kanal iletileri görüntülenemez. "
"Ek olarak, <userinput><command>-all</command></userinput> girerseniz, tüm "
"ileti türleri (sorgular, bildirimler, &CTCP;, DCC ve istisnalar) "
"yoksayılacaktır."

#. Tag: userinput
#: index.docbook:2463
#, no-c-format
msgid "<command>/quote </command> <replaceable>cmd</replaceable>"
msgstr "<command>/quote </command> <replaceable>komut</replaceable>"

#. Tag: para
#: index.docbook:2464
#, no-c-format
msgid ""
"Sends <userinput><replaceable>cmd</replaceable></userinput> to the server."
msgstr ""
"<userinput><replaceable>komutu</replaceable></userinput> sunucuya gönderir."

#. Tag: userinput
#: index.docbook:2469
#, no-c-format
msgid "<command>/say </command> <replaceable>msg</replaceable>"
msgstr "<command>/say </command> <replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:2470
#, no-c-format
msgid ""
"When entered in a channel tab, sends <userinput><replaceable>msg</"
"replaceable></userinput> to the channel. This is the same as entering "
"<userinput><replaceable>msg</replaceable></userinput> in the channel "
"<interface>Input Line</interface>. Useful for sending &irc; commands when "
"you don't want to execute the command. Two command characters (//) in a row "
"does the same thing as <userinput><command>/say</command></userinput>. Also "
"used by <link linkend=\"scripting\">scripts</link> to send messages."
msgstr ""
"Kanal sekmesine girildiğinde <userinput><replaceable>iletiyi</replaceable></"
"userinput> kanala gönderir. Kanaldaki <interface>Giriş Satırı</interface> "
"içine <userinput><replaceable>ileti</replaceable></userinput> yazmakla "
"aynıdır. Komutu çalıştırmak istemediğinizde &irc; komutlarını göndermek için "
"kullanışlıdır. Bir satırdaki iki komut karakteri (//) <userinput><command>/"
"say</command></userinput> ile aynı işi yapar. Ayrıca ileti göndermek için "
"<link linkend=\"scripting\">betik</link> te kullanabilirsiniz."

#. Tag: userinput
#: index.docbook:2478
#, no-c-format
msgid ""
"<command>/raw </command> [<command>open</command>|<command>close</command>]"
msgstr ""
"<command>/raw </command> [<command>open</command>|<command>close</command>]"

#. Tag: para
#: index.docbook:2479
#, no-c-format
msgid ""
"Places the server log in raw mode (<command>open</command>) or stops raw "
"mode (<command>close</command>). If neither <command>open</command> or "
"<command>close</command> is entered, defaults to <command>open</command>. In "
"raw mode, the log displays every message received from the server in native "
"&irc; format."
msgstr ""
"Sunucu günlüklerini işlem görmeden konumlandırır (<command>open</command>) "
"veya kipi durdurur (<command>close</command>). (<command>open</command>) ya "
"da (<command>close</command>) girilmemişse, varsayılan (<command>open</"
"command>) komutudur. İşlem görmemiş kipte, sunucudan gelen tüm iletilerin "
"günlükleri, doğal &irc; biçiminde gösterilir."

#. Tag: para
#: index.docbook:2485
#, no-c-format
msgid "Opens a new tab running a &konsole;."
msgstr "&konsole; çalıştıran bir sekme açar."

#. Tag: userinput
#: index.docbook:2490
#, no-c-format
msgid ""
"<command>/server </command> <replaceable>[url]</replaceable> "
"<replaceable>[pwd]</replaceable>"
msgstr ""
"<command>/server </command> <replaceable>[url]</replaceable> "
"<replaceable>[pwd]</replaceable>"

#. Tag: para
#: index.docbook:2491
#, no-c-format
msgid ""
"Connects to the server at address <userinput><replaceable>url</replaceable></"
"userinput>. If <userinput><replaceable>url</replaceable></userinput> is "
"omitted, connects to the server associated with the tab where you enter the "
"command. This is useful for re-connecting to a server when disconnected. If "
"the server requires a password in order to connect to it, enter it for "
"<userinput><replaceable>pwd</replaceable></userinput>. If the server "
"requires a port number other than the default (6667), enter the "
"<userinput><replaceable>url</replaceable></userinput> like this: "
"<replaceable>irc.kde.org:6665</replaceable>."
msgstr ""
"<userinput><replaceable>url</replaceable></userinput> adresindeki sunucuya "
"bağlanır. <userinput><replaceable>url</replaceable></userinput> yoksa, "
"komutu girdiğiniz sekme ile ilişkili sunucuya bağlanılır. Bu, bağlantı "
"kesildiğinde bir sunucuya yeniden bağlanmak için kullanışlıdır. Sunucu, ona "
"bağlanmak için bir parola isterse, <userinput><replaceable>pwd</"
"replaceable></userinput> girin. Sunucu varsayılan port numarası (6667) "
"dışında bir port numarası istiyorsa, <replaceable>irc.kde.org:6665</"
"replaceable> benzeri bir <userinput><replaceable>url</replaceable></"
"userinput> girin."

#. Tag: userinput
#: index.docbook:2501
#, no-c-format
msgid ""
"<command>/dcc </command> <command>SEND </command><replaceable>nick</"
"replaceable> <replaceable>[filename]</replaceable>"
msgstr ""
"<command>/dcc </command> <command>SEND </command><replaceable>rumuz</"
"replaceable> <replaceable>[dosyaadı]</replaceable>"

#. Tag: para
#: index.docbook:2503
#, no-c-format
msgid ""
"Sends <userinput><replaceable>filename</replaceable></userinput> to the user "
"with &i18n-nickname; <userinput><replaceable>nick</replaceable></userinput>. "
"If <userinput><replaceable>filename</replaceable></userinput> is omitted, a "
"dialog appears for you to select a file."
msgstr ""
"&i18n-nickname; <userinput><replaceable>rumuzlu</replaceable></userinput> "
"kullanıcıya, <userinput><replaceable>dosya adı</replaceable></userinput> "
"gönderir."

#. Tag: para
#: index.docbook:2512
#, no-c-format
msgid "Opens the <guilabel>DCC Status</guilabel> tab."
msgstr "<guilabel>DCC Durum</guilabel> sekmesini açar."

#. Tag: userinput
#: index.docbook:2517
#, no-c-format
msgid ""
"<command>/ctcp </command><replaceable>nick|channel</replaceable> "
"<command>ping</command>"
msgstr ""
"<command>/ctcp </command><replaceable>rumuz|kanal</replaceable> "
"<command>ping</command>"

#. Tag: para
#: index.docbook:2518
#, no-c-format
msgid ""
"Sends a PING message to <userinput><replaceable>nick</replaceable></"
"userinput> or <userinput><replaceable>channel</replaceable></userinput>. "
"This is useful for determining if someone you are talking with has a high "
"network lag, or (when sent to a channel) if your system has a high lag."
msgstr ""
"<userinput><replaceable>rumuz</replaceable></userinput> veya "
"<userinput><replaceable>kanal</replaceable></userinput> üzerine PING "
"gönderir. Bu, konuştuğunuz kişinin yüksek bir ağ gecikmesine mi, yoksa "
"sisteminizde yüksek bir gecikme olup olmadığına (bir kanala gönderildiğinde) "
"karar vermede yararlıdır."

#. Tag: userinput
#: index.docbook:2526
#, no-c-format
msgid ""
"<command>/ctcp </command><replaceable>nick|channel</replaceable> "
"<replaceable>msg</replaceable>"
msgstr ""
"<command>/ctcp </command><replaceable>rumuz|kanal</replaceable> "
"<replaceable>ileti</replaceable>"

#. Tag: para
#: index.docbook:2527
#, no-c-format
msgid ""
"Sends a message to <userinput><replaceable>nick</replaceable></userinput> or "
"all users in <userinput><replaceable>channel</replaceable></userinput>. This "
"is similar to the <userinput><command>/msg</command></userinput> command "
"above, except that the message is sent using the &CTCP; protocol. The "
"response on the other end depends on the &irc; client program the user is "
"running. For example, when conversing with another &konversation; user, "
"<userinput><replaceable>/ctcp Eisfuchs TIME</replaceable></userinput> will "
"return the system time on Eisfuch's computer. <userinput><replaceable>/ctcp "
"Eisfuchs VERSION</replaceable></userinput> will return the &konversation; "
"version number from Eisfuch's computer."
msgstr ""
"Bir <userinput><replaceable>rumuz</replaceable></userinput> veya "
"<userinput><replaceable>kanal</replaceable></userinput> üzerindeki tüm "
"kullanılara bir ileti gönderir. Yukarıdaki <userinput><command>/msg</"
"command></userinput> komutuna benzerdir, ancak &CTCP; protokolü kullanılarak "
"gönderilir. Karşı taraftaki yanıt, kullanıcının çalıştırdığı &irc; istemci "
"programına bağlıdır. Örneğin, sohbet bir diğer &konversation; kullancısyla "
"ise, <userinput><replaceable>/ctcp Ahmet TIME</replaceable></userinput> "
"komutu Ahmet’in bilgisayarındaki zamanı döndürür. <userinput><replaceable>/"
"ctcp Ahmet VERSION</replaceable></userinput> ise, Ahmet’in bilgisayarında "
"kurulu olan &konversation; için sürüm numarasını döndürür."

#. Tag: title
#: index.docbook:2547
#, no-c-format
msgid "Scripting"
msgstr "Betik Yazma"

#. Tag: para
#: index.docbook:2549
#, no-c-format
msgid ""
"&konversation; comes with some handy scripts you can run from the program. "
"To run a script, in a channel, query, DCC, or server tab, type a command of "
"the form"
msgstr ""
"&onversation; programdan çalıştırabileceğiniz kullanışlı betik dosyaları ile "
"birlikte gelir. Bir betik dosyasını çalıştırmak için, bir kanal, sorgu, DCC "
"veya sunucu sekmesinde, formun komutunu yazın"

#. Tag: userinput
#: index.docbook:2552
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>script</replaceable> "
"[<replaceable>parameters</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>betik</replaceable> "
"[<replaceable>parametreler</replaceable>]"

#. Tag: para
#: index.docbook:2555
#, no-c-format
msgid ""
"which executes the script named <userinput><replaceable>script</"
"replaceable></userinput> passing it (optional) "
"<userinput><replaceable>parameters</replaceable></userinput>."
msgstr ""
"<userinput><replaceable>betik</replaceable></userinput> isimli betiği "
"çalıştırır ve <userinput><replaceable>parametreleri</replaceable></"
"userinput> (isteğe bağlı) iletir."

#. Tag: para
#: index.docbook:2558
#, no-c-format
msgid "For example, type the following command in a channel tab"
msgstr "Örneğin, aşağıdaki komutu bir kanal sekmesine yazın"

#. Tag: para
#: index.docbook:2562
#, fuzzy, no-c-format
#| msgid ""
#| "to send your &konversation;, &Qt;, &kf5; and &plasma; version numbers to "
#| "the channel."
msgid ""
"to send your &konversation;, &Qt;, &kde-frameworks; and &plasma; version "
"numbers to the channel."
msgstr ""
"&konversation; &Qt;, &kf5; ve &plasma; sürüm numaralarını kanala göndermek "
"için."

#. Tag: para
#: index.docbook:2566
#, no-c-format
msgid ""
"executes the <userinput><replaceable>cmd</replaceable></userinput> script, "
"passing it <userinput><replaceable>uname -a</replaceable></userinput>. This "
"sends your &Linux; version string to the channel."
msgstr ""
"<userinput><replaceable>komut</replaceable></userinput> betik çalıştırır, "
"<userinput><replaceable>uname -a</replaceable></userinput> iletir. Bu "
"kullandığınız &Linux; sürümü dizgesini kanala gönderir."

#. Tag: para
#: index.docbook:2570
#, no-c-format
msgid ""
"To learn more about the scripts installed with &konversation; please see the "
"<link linkend=\"scripts_ref\">Script Reference Guide</link>"
msgstr ""
"&konversation; üzerinde kurulu betikler hakkında daha fazla bilgi almak için "
"<link linkend=\"scripts_ref\">Betik Başvuru Kılavuzu</link> bölüme gözatın."

#. Tag: para
#: index.docbook:2573
#, no-c-format
msgid ""
"To get a list of all available scripts, type the following command in a "
"&konversation; screen."
msgstr ""
"Kullanılabilir tüm betik dosyalarının listesini almak için, aşağıdaki komutu "
"&konversation; ekranına girin."

#. Tag: userinput
#: index.docbook:2576
#, no-c-format
msgid "/exec --showpath media"
msgstr "/exec --showpath media"

#. Tag: para
#: index.docbook:2578
#, no-c-format
msgid "Then browse to folder from the output to see the list."
msgstr "Sonra listeyi görmek için çıktıdan klasöre gidin."

#. Tag: para
#: index.docbook:2580
#, no-c-format
msgid ""
"You can write your own scripts. Scripts are shell scripts and can be written "
"in any shell language, such as bash, perl, or python. When &konversation; "
"runs a script, the first two parameters sent to the script are:"
msgstr ""
"Kendi betiklerinizi yazabilirsiniz. Betikler, kabuk komut dosyalarıdır ve "
"bash, perl veya python gibi herhangi bir kabuk dilinde yazılabilir. "
"&konversation; bir betik çalıştırdığında, betiğe gönderilen ilk iki "
"parametre şöyledir:"

#. Tag: para
#: index.docbook:2586
#, no-c-format
msgid "The address of the server."
msgstr "Sunucunun adresi."

#. Tag: para
#: index.docbook:2588
#, no-c-format
msgid "The channel name."
msgstr "Kanal adı."

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid "Here is a sample shell script (cmd)."
msgstr "Örnek bir kabuk betiği (cmd)."

#. Tag: programlisting
#: index.docbook:2595
#, no-c-format
msgid ""
"#!/bin/sh\n"
"\n"
"# Executes a command and prints the output into Konversation.\n"
"\n"
"SERVER=$1;\n"
"TARGET=$2;\n"
"shift;shift;\n"
"\n"
"$@ | while read line; do qdbus org.kde.konversation /irc say $SERVER "
"\"$TARGET\" \"$@: $line\"; done"
msgstr ""
"#!/bin/sh\n"
"\n"
"# Bir komutu çalıştırır ve çıktıyı Konversation’a yazdırır.\n"
"\n"
"SERVER=$1;\n"
"TARGET=$2;\n"
"shift;shift;\n"
"\n"
"$@ | while read line; do qdbus org.kde.konversation /irc say $SERVER "
"\"$TARGET\" \"$@: $line\"; done"

#. Tag: para
#: index.docbook:2598
#, no-c-format
msgid ""
"Notice that the script uses qdbus to communicate with &konversation;. The "
"<computeroutput>say</computeroutput> command causes the output to be sent to "
"the channel as a normal message. To display something in the tab without "
"sending it to other users, use <computeroutput>info</computeroutput> "
"instead. Look at the existing script files for more examples of writing "
"scripts."
msgstr ""
"Betiğin &konversation; ile iletişim kurmak için qdbus kullandığına dikkat "
"edin. <computeroutput>say</computeroutput> komutu, çıktıyı bir iletiymiş "
"gibi kanala göndermenize sebep olabilir. Sekmeye diğer kullanıcılara "
"göndermeden bir şeyler görüntülemek için, <computeroutput>info</"
"computeroutput> kullanın. Betikleri yazmaya ilişkin daha fazla örnek için "
"mevcut betik dosyalarına bakabilirsiniz."

#. Tag: para
#: index.docbook:2603
#, no-c-format
msgid ""
"To be able to run a script you have written, you must install it by copying "
"it to <filename class=\"directory\">$(qtpaths --paths GenericDataLocation)/"
"konversation/scripts</filename>. You must also give the file execute "
"privilege, for example <userinput><replaceable>chmod a+x myscript</"
"replaceable></userinput>."
msgstr ""
"Yazdığınız bir betiği çalıştırabilmek için <filename class=\"directory\">"
"$(qtpaths --paths GenelVeriKonumu)/konversation/scripts</filename> altına "
"kopyalayarak yüklemelisiniz. Ayrıca dosyaya yürütme ayrıcalığı vermelisiniz, "
"örneğin <userinput><replaceable>chmod a+x myscript</replaceable></userinput>."

#. Tag: title
#: index.docbook:2610
#, no-c-format
msgid "Script Reference Guide"
msgstr "Betik Başvuru Kılavuzu"

#. Tag: para
#: index.docbook:2612
#, no-c-format
msgid ""
"&konversation; comes with several scripts installed by default, please refer "
"to this guide to learn how to use them."
msgstr ""
"&konversation;, varsayılan olarak birkaç betik dosyası yüklü olarak gelir, "
"bunları nasıl kullanacağınızı öğrenmek için lütfen bu kılavuza bakın."

#. Tag: userinput
#: index.docbook:2616
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>bug</replaceable> [<replaceable>Bug "
"Number|Search String</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>bug</replaceable> [<replaceable>Hata "
"Numarası|Arama Dizgesi</replaceable>]"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"This script is used to open your browser to search for the given string or "
"bug number on <ulink url=\"https://bugs.kde.org/\">&kde;'s Bugzilla</ulink>."
msgstr ""
"Bu komut, <ulink url=\"https://bugs.kde.org/\">&kde; Bugzilla</ulink> "
"üzerinde verilen dizgeyi veya hata numarasını aramak için tarayıcınızı açmak "
"için kullanılır."

#. Tag: para
#: index.docbook:2619
#, no-c-format
msgid "Example: To open your browser to search for bug 123456"
msgstr "Örnek: Tarayıcınızı hata 123456 aramak üzere açmak için"

#. Tag: userinput
#: index.docbook:2620
#, no-c-format
msgid "<command>/exec </command> <replaceable>bug 123456</replaceable>"
msgstr "<command>/exec </command> <replaceable>bug 123456</replaceable>"

#. Tag: para
#: index.docbook:2621
#, fuzzy, no-c-format
#| msgid ""
#| "Sample action: The default browser in your &systemsettings; should open "
#| "to <replaceable>http://bugs.kde.org/show_bug.cgi?id=123456</replaceable>"
msgid ""
"Sample action: The default browser in your &systemsettings; should open to "
"<replaceable>https://bugs.kde.org/show_bug.cgi?id=123456</replaceable>"
msgstr ""
"Örnek eylem: &systemsettings; içindeki varsayılan tarayıcı, "
"<replaceable>http://bugs.kde.org/show_bug.cgi?id=123456</replaceable> "
"adresini açmalıdır."

#. Tag: userinput
#: index.docbook:2626
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>cmd</replaceable> "
"[<replaceable>command line arguments</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>cmd</replaceable> [<replaceable>komut "
"satırı değişkenleri</replaceable>]"

#. Tag: para
#: index.docbook:2629
#, no-c-format
msgid ""
"This script is used to have the output of the command line arguments to be "
"written to your current channel."
msgstr ""
"Bu betik, mevcut kanalınıza yazılabilecek betik değişkenlerinin çıktısını "
"elde etmek için kullanılır."

#. Tag: para
#: index.docbook:2630
#, no-c-format
msgid ""
"Example: To show everyone in your current channel what version of "
"&konversation; you have installed."
msgstr ""
"Örnek: Geçerli kanalınızdaki herkese yüklemiş olduğunuz &konversation; "
"sürümünü göstermek."

#. Tag: userinput
#: index.docbook:2631
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>cmd konversation --version</"
"replaceable>"
msgstr ""
"<command>/exec </command> <replaceable>cmd konversation --version</"
"replaceable>"

#. Tag: para
#: index.docbook:2632
#, no-c-format
msgid "Sample output: <replaceable>Konversation: 1.6</replaceable>"
msgstr "Örnek çıktı: <replaceable>Konversation: 1.6</replaceable>"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"WARNING! The output of the entire command is posted to everyone in the "
"current channel tab! Please use with care."
msgstr ""
"UYARI! Komutun tamamı geçerli kanal sekmesindeki herkese gönderilir! Lütfen "
"dikkatle kullanın."

#. Tag: userinput
#: index.docbook:2638 index.docbook:2643
#, no-c-format
msgid "<command>/exec </command> <replaceable>fortune</replaceable>"
msgstr "<command>/exec </command> <replaceable>fortune</replaceable>"

#. Tag: para
#: index.docbook:2641
#, no-c-format
msgid "This script when run will output a Random Fortune."
msgstr "Bu betik çalıştırıldığında Rastgele Fal çıktısı verir."

#. Tag: para
#: index.docbook:2642
#, no-c-format
msgid "Example: To output a random fortune to your current channel tab."
msgstr "Örnek: Mevcut kanal sekmesine rastgele fal için."

#. Tag: para
#: index.docbook:2644
#, no-c-format
msgid ""
"Sample output: <replaceable>Random Fortune: Never make any mistaeks. -- "
"Anonymous, in a mail discussion about to a kernel bug report</replaceable>"
msgstr ""
"Örnek çıktı: <replaceable>Rastgele Fal: Asla hta yapma. -- Anonim, bir "
"çekirdek hata raporu hakkındaki bir eposta tartışması</replaceable>"

#. Tag: userinput
#: index.docbook:2650
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>gauge</replaceable> "
"[<replaceable>percentage</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>ölçü</replaceable> "
"[<replaceable>yüzde</replaceable>]"

#. Tag: para
#: index.docbook:2653
#, no-c-format
msgid ""
"This script shows a simple text based progress bar for the given percentage."
msgstr ""
"Bu betik, verilen yüzde için basit bir metin tabanlı ilerleme çubuğu "
"gösterir."

#. Tag: para
#: index.docbook:2654
#, no-c-format
msgid ""
"Example: To output a progress bar with 50% completion to the current channel "
"tab."
msgstr ""
"Örnek: Mevcut kanal sekmesine % 50 tamamlama ile bir ilerleme çubuğu çıktısı "
"vermek için."

#. Tag: userinput
#: index.docbook:2655
#, no-c-format
msgid "<command>/exec </command> <replaceable>gauge 50</replaceable>"
msgstr "<command>/exec </command> <replaceable>ölçü 50</replaceable>"

#. Tag: para
#: index.docbook:2656
#, no-c-format
msgid "Sample output: <replaceable>Beer load [ | ] 50%</replaceable>"
msgstr "Örnek çıktı: <replaceable>Su yükleniyor [ | ] 50%</replaceable>"

#. Tag: userinput
#: index.docbook:2660
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>media</replaceable> "
"[<replaceable>audio|video|{player}</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>media</replaceable> "
"[<replaceable>müzik|video|{oynatısıcıs}</replaceable>]"

#. Tag: para
#: index.docbook:2663
#, no-c-format
msgid ""
"This is a Now Playing script for various media players. It also features a "
"method to show Now Playing information for only audio players, or only video "
"players via the optional command arguments <replaceable>audio</replaceable> "
"and <replaceable>video</replaceable>. Additionally, it's possible to specify "
"the media player you wish to query."
msgstr ""
"Bu, çeşitli ortam oynatıcıları için Şimdi Çalınan için bir betik. Ayrıca, "
"yalnızca müzik çalarlar için Şimdi Çalınan bilgileri veya isteğe bağlı komut "
"argümanlarını <replaceable>ses</replaceable> ve <replaceable>video</"
"replaceable> yoluyla yalnızca video oynatıcıları göstermek için bir yöntem "
"de içerir."

#. Tag: para
#: index.docbook:2666
#, no-c-format
msgid ""
"The following media players are supported: Amarok (audio), JuK (audio), "
"Kaffeine (video, audio), KMPlayer (video, audio), KPlayer (video, audio), "
"kdetv (video), Yammi (audio), Audacious (audio), MPD (audio)."
msgstr ""
"Aşağıdaki ortam oynatıcıları desteklenir: Amarok (ses), JuK (ses), Kafein "
"(video, ses), KMPlayer (video, ses), KPlayer (video, ses), kdetv (video), "
"Yammi (ses), Audacious ses), MPD (ses)."

#. Tag: para
#: index.docbook:2669
#, no-c-format
msgid "Example: To output your currently playing song in Amarok."
msgstr "Örnek: Amarak’ta çalınan şarkının çıktısını için."

#. Tag: userinput
#: index.docbook:2670
#, no-c-format
msgid "<command>/exec </command> <replaceable>media amarok</replaceable>"
msgstr "<command>/exec </command> <replaceable>media amarok</replaceable>"

#. Tag: para
#: index.docbook:2671
#, no-c-format
msgid ""
"Sample output: <replaceable>* user is listening to You Give Love A Bad Name "
"by Bon Jovi on Slippery When Wet [Amarok]</replaceable>"
msgstr ""
"Örnek çıktı: <replaceable>* kullanıcısı, Neşet Ertaş - Yalan Dünya - Ayaş "
"Yolları dinliyor [Amarok]</replaceable>"

#. Tag: userinput
#: index.docbook:2688 index.docbook:2694
#, no-c-format
msgid "<command>/exec </command> <replaceable>sysinfo</replaceable>"
msgstr "<command>/exec </command> <replaceable>sysinfo</replaceable>"

#. Tag: para
#: index.docbook:2691
#, no-c-format
msgid ""
"This script outputs some detailed information about your system by combining "
"the outputs of several commands and formatting them appropriately."
msgstr ""
"Bu betik, birkaç komutun çıktılarını birleştirip bunları uygun biçime "
"getirerej sisteminizle ilgili ayrıntılı bilgi verir."

#. Tag: para
#: index.docbook:2693
#, no-c-format
msgid ""
"Example: To output some information about your system to the current channel "
"tab."
msgstr ""
"Örnek: Sisteminizle ilgili bazı bilgileri mevcut kanal sekmesine göndermek "
"için."

#. Tag: para
#: index.docbook:2695
#, no-c-format
msgid ""
"Sample output: <replaceable>Sysinfo for 'user-desktop': Running inside KDE "
"Plasma 5.6.5 on Ubuntu 16.04.1 LTS (Xenial Xerus) powered by Linux 4.4.0-47-"
"generic, CPU: Intel(R) Core(TM) i7-4910MQ CPU @ 2.90GHz at 2996-3338/3900 "
"MHz, RAM: 15795/15967 MB, Storage: 1591/2281 GB, 406 procs, 47.59h up</"
"replaceable>"
msgstr ""
"Örnek çıktı: <replaceable>Sysinfo for 'user-desktop': Running inside KDE "
"Plasma 5.6.5 on Ubuntu 16.04.1 LTS (Xenial Xerus) powered by Linux 4.4.0-47-"
"generic, CPU: Intel(R) Core(TM) i7-4910MQ CPU @ 2.90GHz at 2996-3338/3900 "
"MHz, RAM: 15795/15967 MB, Storage: 1591/2281 GB, 406 procs, 47.59h up</"
"replaceable>"

#. Tag: userinput
#: index.docbook:2700
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>tinyurl</replaceable> "
"[<replaceable>Link Address</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>tinyurl</replaceable> "
"[<replaceable>Bağlantı Adresi</replaceable>]"

#. Tag: para
#: index.docbook:2703
#, no-c-format
msgid ""
"This script uses Tinyurl's api to turn the given link into a tinyurl that is "
"then sent to the current channel tab."
msgstr ""
"Bu betik, Tinyurl api kullanarak, verilen bağlantıyı daha sonra geçerli "
"kanal sekmesine gönderilen bir tinyurl haline getiriyor."

#. Tag: para
#: index.docbook:2704
#, fuzzy, no-c-format
#| msgid "Example: To give someone a short link to http://konversation.kde.org"
msgid "Example: To give someone a short link to https://konversation.kde.org"
msgstr ""
"Örnek: Birine http://konversation.kde.org adresine kısa bir bağlantı vermek "
"için"

#. Tag: userinput
#: index.docbook:2705
#, fuzzy, no-c-format
#| msgid ""
#| "<command>/exec </command> <replaceable>tinyurl http://konversation.kde."
#| "org</replaceable>"
msgid ""
"<command>/exec </command> <replaceable>tinyurl https://konversation.kde.org</"
"replaceable>"
msgstr ""
"<command>/exec </command> <replaceable>tinyurl http://konversation.kde.org</"
"replaceable>"

#. Tag: para
#: index.docbook:2706
#, fuzzy, no-c-format
#| msgid "Sample output: <replaceable>http://tinyurl.com/n3pdum</replaceable>"
msgid "Sample output: <replaceable>https://tinyurl.com/y4rk8wa3</replaceable>"
msgstr "Örnek çıktı: <replaceable>http://tinyurl.com/n3pdum</replaceable>"

#. Tag: userinput
#: index.docbook:2711 index.docbook:2716
#, no-c-format
msgid "<command>/exec </command> <replaceable>uptime</replaceable>"
msgstr "<command>/exec </command> <replaceable>uptime</replaceable>"

#. Tag: para
#: index.docbook:2714
#, no-c-format
msgid ""
"This script outputs the result of the command \"uptime\" and formats it "
"appropriately."
msgstr ""
"Bu betik, \"uptime\" komutu sonucunu alır ve uygun biçimde biçimlendirir."

#. Tag: para
#: index.docbook:2715
#, no-c-format
msgid "Example: To show off your rock solid 98 day uptime."
msgstr "Örnek: Uptime 98 günlük çalışma sürenizi göstermek için."

#. Tag: para
#: index.docbook:2717
#, no-c-format
msgid ""
"Sample output: <replaceable>Uptime: 98 days, 15 hours and 2 minutes</"
"replaceable>"
msgstr ""
"Örnek çıktı: <replaceable>Uptime: 98 days, 15 hours and 2 minutes</"
"replaceable>"

#. Tag: para
#: index.docbook:2723
#, no-c-format
msgid ""
"All these scripts have predefined command aliases. In &konversation;'s "
"settings dialog select <menuchoice><guimenu>Behavior</guimenu> "
"<guimenuitem>Command Aliases</guimenuitem></menuchoice> to view, add, remove "
"or edit command aliases."
msgstr ""
"Tüm bu betikler, önceden tanımlanmış komut rumuzlarıdır. &konversation; "
"ayarlar penceresinden <menuchoice><guimenu>Davranış</guimenu> "
"<guimenuitem>Komut Rumuzları</guimenuitem></menuchoice> ögesi ile "
"görüntüleme, ekleme, kaldırma ve düzenleme yapılabilir."

#. Tag: para
#: index.docbook:2728
#, no-c-format
msgid ""
"For more information about scripting please read the <ulink url=\"https://"
"userbase.kde.org/Konversation/Scripts/Scripting_guide\">Userbase Scripting "
"guide</ulink>"
msgstr ""
"Betikler hakkında daha fazla bilgi almak için <ulink url=\"https://userbase."
"kde.org/Konversation/Scripts/Scripting_guide\">Userbase Betik kılavuzuna</"
"ulink> gözatın."

#. Tag: title
#: index.docbook:2739
#, no-c-format
msgid "Command Reference"
msgstr "Komut Bilgileri"

#. Tag: title
#: index.docbook:2750
#, no-c-format
msgid "The main &konversation; window"
msgstr "Ana &konversation; penceresi"

#. Tag: title
#: index.docbook:2753
#, no-c-format
msgid "The File Menu"
msgstr "Dosya Menüsü"

#. Tag: menuchoice
#: index.docbook:2757
#, no-c-format
msgid ""
"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Server List</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>Dosya</guimenu> "
"<guimenuitem>Sunucu Listesi</guimenuitem>"

#. Tag: action
#: index.docbook:2764
#, no-c-format
msgid ""
"Displays the <link linkend=\"irc-basics\">list of servers and channels</"
"link>."
msgstr ""
"<link linkend=\"irc-basics\">sunucu ve kanalların listesini</link> gösterir."

#. Tag: menuchoice
#: index.docbook:2768
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Quick Connect</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>Dosya</guimenu> "
"<guimenuitem>Hızlı Bağlantı</guimenuitem>"

#. Tag: action
#: index.docbook:2775
#, no-c-format
msgid ""
"Displays the <link linkend=\"quickconnect\">Quick Connect</link> screen for "
"connecting to a server."
msgstr ""
"Bir sunucuya bağlanmak için <link linkend=\"quickconnect\">Hızlı Bağlantı</"
"link> ekranını gösterir."

#. Tag: menuchoice
#: index.docbook:2779
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Disconnect</guimenuitem>"
msgstr "<guimenu>Dosya</guimenu> <guimenuitem>Bağlantıyı Kes</guimenuitem>"

#. Tag: action
#: index.docbook:2783
#, no-c-format
msgid "Disconnects from all servers."
msgstr "Tüm sunucuların bağlantısını keser."

#. Tag: menuchoice
#: index.docbook:2787
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Reconnect</guimenuitem>"
msgstr "<guimenu>Dosya</guimenu> <guimenuitem>Yeniden Bağlan</guimenuitem>"

#. Tag: action
#: index.docbook:2791
#, no-c-format
msgid ""
"Reconnects to all servers that were disconnected by a network error or other "
"problem."
msgstr ""
"Bir ağ hatası veya başka bir sorunla bağlantısı kesilen tüm sunuculara "
"yeniden bağlanır."

#. Tag: menuchoice
#: index.docbook:2796
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Join Channel</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Dosya</guimenu> <guimenuitem>Kanala Gir</guimenuitem>"

#. Tag: action
#: index.docbook:2803
#, no-c-format
msgid ""
"Displays a dialog for you to enter the name of a channel to join. Does the "
"same thing as entering <command>/join <userinput>#channelname</userinput></"
"command> in a channel or server tab."
msgstr ""
"Katılmak için bir kanalın adını girebileceğiniz bir pencere görüntüler. Aynı "
"işlemi bir kanal veya sunucu sekmesinde <command>/join<userinput>#kanaladı</"
"userinput></command> girerek te yapılabilir."

#. Tag: menuchoice
#: index.docbook:2809
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Global Away</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Dosya</guimenu> <guimenuitem>Genel Uzakta</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2816
#, no-c-format
msgid "Changes your &i18n-nickname; status to away in all channels."
msgstr "&i18n-nickname; durmunu, tüm kanallarda uzakta yapar."

#. Tag: menuchoice
#: index.docbook:2820
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Dosya</guimenu> <guimenuitem>Çık</guimenuitem>"

#. Tag: para
#: index.docbook:2827
#, no-c-format
msgid "<action>Quits</action> &konversation;."
msgstr "&konversation;'dan <action>Çıkar</action>."

#. Tag: title
#: index.docbook:2834
#, no-c-format
msgid "The Edit Menu"
msgstr "Düzenle Menüsü"

#. Tag: menuchoice
#: index.docbook:2838
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find Text...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Düzenle</guimenu> <guimenuitem>Metin Bul...</guimenuitem>"

#. Tag: action
#: index.docbook:2846
#, no-c-format
msgid "Searches for text strings in the current screen."
msgstr "Geçerli ekrandaki metin dizgelerini arar."

#. Tag: menuchoice
#: index.docbook:2850
#, no-c-format
msgid ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Find Next</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>Düzenle</guimenu> "
"<guimenuitem>Sonrakini Bul</guimenuitem>"

#. Tag: action
#: index.docbook:2858
#, no-c-format
msgid ""
"Searches again for text strings in the current screen using the previous "
"search string."
msgstr ""
"Geçerli ekrandaki metin dizgelerini bir önceki arama dizgesini kullanarak "
"tekrar arar."

#. Tag: menuchoice
#: index.docbook:2870
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Clear Window</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>Düzenle</guimenu> <guimenuitem>Pencereyi Temizle</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2878
#, no-c-format
msgid "Clears the current screen."
msgstr "Geçerli ekranı temizler."

#. Tag: menuchoice
#: index.docbook:2882
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Shift;<keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Clear All "
"Windows</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Shift;<keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Düzenle</guimenu> <guimenuitem>Tüm "
"Pencereleri Temizle</guimenuitem>"

#. Tag: action
#: index.docbook:2890
#, no-c-format
msgid "Clears all screens."
msgstr "Tüm ekranları temizler."

#. Tag: title
#: index.docbook:2898
#, no-c-format
msgid "The Insert Menu"
msgstr "Ekle Menüsü"

#. Tag: menuchoice
#: index.docbook:2902
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>K</keycap></keycombo> </"
"shortcut> <guimenu>Insert</guimenu> <guimenuitem>&irc; Color...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>K</keycap></keycombo> </"
"shortcut> <guimenu>Ekle</guimenu> <guimenuitem>&irc; Rengi...</guimenuitem>"

#. Tag: action
#: index.docbook:2910
#, no-c-format
msgid "See <link linkend=\"color-msgs\">Sending colorful messages</link>."
msgstr ""
"<link linkend=\"color-msgs\">Renkli iletiler göndermek</link> bölümüne "
"gözatın."

#. Tag: menuchoice
#: index.docbook:2914
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Insert</guimenu> <guimenuitem>Marker Line</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Ekle</guimenu> <guimenuitem>İşaretleyici Satırı</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2922
#, no-c-format
msgid ""
"See <link linkend=\"rememberlines\">Marking Channel and Query Logs</link>."
msgstr ""
"<link linkend=\"rememberlines\">Kanal ve Sorgu Günlüklerini İşaretleme</"
"link> bölümüne gözatın."

#. Tag: menuchoice
#: index.docbook:2926
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Shift;<keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Insert</guimenu> <guimenuitem>Special "
"Character...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Shift;<keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Ekle</guimenu> <guimenuitem>Özel Karakter...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2934
#, no-c-format
msgid "Used to enter special characters, such as foreign characters."
msgstr "Yabancı karakterler gibi özel karakterleri girmek için kullanılır."

#. Tag: title
#: index.docbook:2943
#, no-c-format
msgid "The Bookmarks Menu"
msgstr "Yer İmleri Menüsü"

#. Tag: menuchoice
#: index.docbook:2947
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Bookmarks</guimenu> <guimenuitem>Add Bookmark</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Yer İmleri</guimenu> <guimenuitem>Yer İmi Ekle</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2955
#, no-c-format
msgid "Bookmarks current network &amp; channel."
msgstr "Geçerli ağ &amp; kanalı yer imi yapar."

#. Tag: menuchoice
#: index.docbook:2959
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>Bookmark Tabs as Folder...</"
"guimenuitem>"
msgstr ""
"<guimenu>Yer İmleri</guimenu> <guimenuitem>Klasör olarak Yer İmi Sekmeleri..."
"</guimenuitem>"

#. Tag: para
#: index.docbook:2963
#, no-c-format
msgid ""
"<action>Adds</action> all channels to a new menu item at the end of the "
"bookmarks menu."
msgstr ""
"Tüm kanalları, yer imleri menüsünün sonundaki yeni bir menü öğesine "
"<action>ekler</action>."

#. Tag: menuchoice
#: index.docbook:2968
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>New Bookmark Folder...</"
"guimenuitem>"
msgstr ""
"<guimenu>Yer İmleri</guimenu><guimenuitem>Yeni Yer İmi Klasörü...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2973
#, no-c-format
msgid "Creates a new bookmark folder."
msgstr "Yeni bir yer imi klasörü oluşturur."

#. Tag: menuchoice
#: index.docbook:2977
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>Edit Bookmarks...</guimenuitem>"
msgstr ""
"<guimenu>Yer İmleri</guimenu> <guimenuitem>Yer İmlerini Düzenle...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2982
#, no-c-format
msgid "Opens bookmark editor."
msgstr "Yer imi düzenleyicisini açar."

#. Tag: title
#: index.docbook:2990
#, no-c-format
msgid "The Settings Menu"
msgstr "Ayarlar Menüsü"

#. Tag: menuchoice
#: index.docbook:2994
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Show Nicklist</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Ayarlar</guimenu> <guimenuitem>Rumuz Listesini Göster</"
"guimenuitem>"

#. Tag: action
#: index.docbook:3002
#, no-c-format
msgid "Hides (or displays) the panel of &i18n-nickname;s in channel tabs."
msgstr ""
"Kanal sekmelerindeki &l18n-nickname; panelini gizler (veya görüntüler)."

#. Tag: menuchoice
#: index.docbook:3007
#, no-c-format
msgid ""
"<shortcut><keycap>F8</keycap></shortcut> <guimenu>Settings</guimenu> "
"<guimenuitem>Identities...</guimenuitem>"
msgstr ""
"<shortcut><keycap>F8</keycap></shortcut> <guimenu>Ayarlar</guimenu> "
"<guimenuitem>Kimlikler...</guimenuitem>"

#. Tag: action
#: index.docbook:3012
#, no-c-format
msgid ""
"Displays the <link linkend=\"identity\">Identities</link> screen for setting "
"your identification information."
msgstr ""
"Kimlik bilgilerinizi ayarlayabilmeniz için <link linkend=\"identity"
"\">Kimlikler</link> ekranını gösterir."

#. Tag: title
#: index.docbook:3021
#, no-c-format
msgid "The Window Menu"
msgstr "Pencere Menüsü"

#. Tag: menuchoice
#: index.docbook:3025
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Previous Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>Pencere</guimenu> <guimenuitem>Önceki Sekme</guimenuitem>"

#. Tag: action
#: index.docbook:3033
#, no-c-format
msgid "Displays the screen corresponding to the previous tab."
msgstr "Önceki sekmeye karşılık gelen ekranı görüntüler."

#. Tag: menuchoice
#: index.docbook:3037
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Next Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Pencere</guimenu> <guimenuitem>Sonraki Sekme</guimenuitem>"

#. Tag: action
#: index.docbook:3045
#, no-c-format
msgid "Displays the screen corresponding to the next tab."
msgstr "Bir sonraki sekmeye karşılık gelen ekranı görüntüler."

#. Tag: menuchoice
#: index.docbook:3054
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Close Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Pencere</guimenu> <guimenuitem>Sekmeyi Kapat</guimenuitem>"

#. Tag: action
#: index.docbook:3062
#, no-c-format
msgid ""
"Closes the current screen. If closing a channel, leaves the channel. If "
"closing a <interface>Server Messages</interface> tab, closes all open "
"channels on that server and disconnects from the server."
msgstr ""
"Geçerli ekranı kapatır. Eğer bir kanalı kapatırsanız kanaldan çıkar. Bir "
"<interface>Sunucu İletileri</interface> sekmesini kapatırsanız, o sunucudaki "
"tüm açık kanalları kapatır ve sunucu bağlantısını keser."

#. Tag: menuchoice
#: index.docbook:3069
#, no-c-format
msgid ""
"<shortcut> <keycap>F11</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Close All Open Queries</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F11</keycap> </shortcut> <guimenu>Pencere</guimenu> "
"<guimenuitem>Tüm Açık Sorguları Kapat</guimenuitem>"

#. Tag: action
#: index.docbook:3077
#, no-c-format
msgid ""
"Closes all <link linkend=\"query\">Private conversations (queries)</link>."
msgstr ""
"Tüm <link linkend=\"query\">Özel sohbetleri (sorgular)</link>) kapatır."

#. Tag: menuchoice
#: index.docbook:3086
#, no-c-format
msgid ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Watched Nicks</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>Pencere</guimenu> "
"<guimenuitem>İzlenen Rumuzlar</guimenuitem>"

#. Tag: action
#: index.docbook:3094
#, no-c-format
msgid ""
"Displays the <guilabel>Watched Nicks</guilabel> screen. See <link linkend="
"\"nicksonline\">Monitoring who is online</link>."
msgstr ""
"<guilabel>İzlenen Rumuzlar</guilabel> ekranını gösterir. <link linkend="
"\"nicksonline\">Kimin çevrim içi olduğunu izleme</link> bölümüne gözatın."

#. Tag: menuchoice
#: index.docbook:3098
#, no-c-format
msgid ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>&URL; Catcher</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>Pencere</guimenu> "
"<guimenuitem>&URL; Yakalayıcı</guimenuitem>"

#. Tag: action
#: index.docbook:3106
#, no-c-format
msgid "Displays the <link linkend=\"urlcatcher\">&URL; Catcher</link> screen."
msgstr ""
"<link linkend=\"urlcatcher\">&URL; Yakalayıcı</link> ekranını gösterir."

#. Tag: menuchoice
#: index.docbook:3110
#, no-c-format
msgid ""
"<shortcut> <keycap>F9</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>DCC Status</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F9</keycap> </shortcut> <guimenu>Pencere</guimenu> "
"<guimenuitem>DCC Durumu</guimenuitem>"

#. Tag: action
#: index.docbook:3118
#, no-c-format
msgid ""
"Displays the <link linkend=\"dcc\">DCC Status</link> tab with information "
"about file transfers."
msgstr ""
"<link linkend=\"dcc\">DCC Durumu</link> sekmesini, dosya aktarımı bilgisiyle "
"birlikte gösterir."

#. Tag: menuchoice
#: index.docbook:3122
#, no-c-format
msgid "<guimenu>Window</guimenu> <guimenuitem>New Konsole</guimenuitem>"
msgstr "<guimenu>Pencere</guimenu> <guimenuitem>Yeni Konsole</guimenuitem>"

#. Tag: action
#: index.docbook:3127
#, no-c-format
msgid ""
"Displays a terminal screen. You may open as many <guilabel>Konsole</"
"guilabel> tabs as you like."
msgstr ""
"Bir terminal ekranı görüntüler. <guilabel>Konsole </guilabel> sekmelerini "
"istediğiniz sayıda açabilirsiniz."

#. Tag: menuchoice
#: index.docbook:3131
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Channel List for</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Pencere</guimenu> "
"<guimenuitem>Kanal Listesi</guimenuitem>"

#. Tag: action
#: index.docbook:3139
#, no-c-format
msgid ""
"Displays a <link linkend=\"list-channels\">list of channels</link> available "
"on the server."
msgstr ""
"Sunucuda kullanılabilir olan <link linkend=\"list-channels\">kanalların "
"listesini</link> gösterir."

#. Tag: menuchoice
#: index.docbook:3143
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Open Logfile for</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Pencere</guimenu> <guimenuitem>Günlük Dosyasını Aç</"
"guimenuitem>"

#. Tag: action
#: index.docbook:3151
#, no-c-format
msgid ""
"Displays a screen with the log of messages from the current tab. Only works "
"for <interface>Channel</interface>, <interface>Server Messages</interface>, "
"and <interface>Query</interface> tabs. Logging must be enabled in "
"<menuchoice> <guisubmenu>Settings</guisubmenu> <guisubmenu>Configure "
"Konversation</guisubmenu> <guisubmenu>Behavior</guisubmenu> "
"<guisubmenu>Logging</guisubmenu> </menuchoice> on the main menu."
msgstr ""
"Geçerli sekmedeki iletilerin günlüğünü içeren bir ekran görüntüler. Sadece "
"<interface>Kanal</interface>, <interface>Sunucu İletileri</interface>, ve "
"<interface>Sorgu</interface> sekmeleri için çalışır. Ana menüdeki "
"<menuchoice> <guisubmenu>Ayarlar</guisubmenu> <guisubmenu>Konversation "
"Yapılandır</guisubmenu> <guisubmenu>Davranış</guisubmenu> "
"<guisubmenu>Günlükleme</guisubmenu> </menuchoice> ögesi etkinleştirilmelidir."

#. Tag: title
#: index.docbook:3169
#, no-c-format
msgid "The Help Menu"
msgstr "Yardım Menüsü"

#. Tag: para
#: index.docbook:3171
#, fuzzy, no-c-format
#| msgid ""
#| "&konversation; has the common &kde; <guimenu>Help</guimenu> menu item, "
#| "for more information read the section about the <ulink url=\"help:/"
#| "fundamentals/ui.html#menus-help\">Help Menu</ulink> of the &kde; "
#| "Fundamentals."
msgid ""
"&konversation; has the common &kde; <guimenu>Help</guimenu> menu item, for "
"more information read the section about the <ulink url=\"help:/fundamentals/"
"menus.html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"&konversation;, yaygın &kde; <guimenu>Yardım</guimenu> menü ögesine "
"sahiptir, &kde; Temellerinin <ulink url=\"help:/fundamentals/ui.html#menus-"
"help\">Yardım Menüsü</ulink> hakkında daha fazla bilgi için o bölüme gözatın."

#. Tag: title
#: index.docbook:3184
#, no-c-format
msgid "Questions and Answers"
msgstr "Sorular ve Cevaplar"

#. Tag: para
#: index.docbook:3200
#, no-c-format
msgid ""
"When I start &konversation;, I'd like to connect to a server without joining "
"any channels. How do I do that?"
msgstr ""
"&Konversasyon;'a başladığımda herhangi bir kanala katılmadan bir sunucuya "
"bağlanmak istiyorum. Bunu nasıl yaparım?"

#. Tag: para
#: index.docbook:3203
#, no-c-format
msgid ""
"In the <link linkend=\"serverlist-addnetwork\">Edit Server</link> screen, "
"leave the <guilabel>Channels</guilabel> frame empty."
msgstr ""
"<link linkend=\"serverlist-addnetwork\">Sunucu Düzenle</link> ekranında, "
"<guilabel>Kanallar</guilabel> çerçevesi boş olmalıdır."

#. Tag: para
#: index.docbook:3209
#, no-c-format
msgid "&konversation; won't connect to any servers. What is wrong?"
msgstr "&konversation; hiç bir sunucuya bağlanmıyor. Sorun nedir?"

#. Tag: para
#: index.docbook:3212
#, no-c-format
msgid "There are several things that could be wrong."
msgstr "Yanlış olabilecek bir çok şey vardır."

#. Tag: para
#: index.docbook:3215
#, no-c-format
msgid ""
"Make sure that you have entered the correct <guilabel>Server name</guilabel> "
"and the correct <guilabel>Port</guilabel> in the <link linkend=\"serverlist-"
"addserver\">Add Server</link> screen."
msgstr ""
"<link linkend=\"serverlist-addserver\">Sunucu Ekle</link> ekranına doğru "
"<guilabel>Sunucu adı</guilabel> ve <guilabel>Port</guilabel> numarası "
"girdiğinizden emin olun."

#. Tag: para
#: index.docbook:3220
#, no-c-format
msgid ""
"Check the output in the <link linkend=\"channel-screen-tour\">Server "
"Messages</link> screen for any error messages. Did the server reject the "
"connection because of a bad password? Did the server reject the connection "
"because it requires <acronym>IDENTD</acronym> and your computer did not "
"respond to the <acronym>IDENT</acronym> request? Did you check the SSL "
"protocol box but the server does not support SSL?"
msgstr ""
"Herhangi bir hata iletisi için <link linkend=\"channel-screen-tour\">Sunucu "
"İletileri</link> ekranındaki çıktıyı kontrol edin. Sunucu, hatalı bir parola "
"nedeniyle bağlantıyı reddetmiş mi? <acronym>IDENTD</acronym> "
"gerektirdiğinden ve bilgisayarınız <acronym>IDENT</acronym> isteğine yanıt "
"vermediğinden sunucu bağlantıyı reddetti mi? SSL protokol kutusu kontrol "
"ettiniz mi, sunucu SSL’yi desteklemiyor mu?"

#. Tag: para
#: index.docbook:3227
#, no-c-format
msgid ""
"If you are behind a firewall, make sure the correct ports are enabled. "
"&konversation; needs the following ports enabled:"
msgstr ""
"Güvenlik duvarının arkasındaysanız, doğru portların etkinleştirildiğinden "
"emin olun. &konversation;'nın kullandığı portlar aşağıdadır:"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid "Outgoing TCP 6667 (or the port of the server you connect to)"
msgstr "Giden TCP 6667 (veya bağladığınız sunucunun bağlantı noktası)"

#. Tag: para
#: index.docbook:3234
#, no-c-format
msgid "Incoming TCP 113 (if the server requires IDENTD)"
msgstr "Gelen TCP 113 (sunucu IDENTD gerektiriyorsa)"

#. Tag: para
#: index.docbook:3239
#, no-c-format
msgid ""
"For more information on &irc; connection problems, see <ulink url=\"https://"
"github.com/irchelp/wio/blob/gh-pages/networks/connectprob.md\">irchelp.org</"
"ulink>."
msgstr ""
"&irc; bağlantı problemleri hakkında daha fazla bilgi için <ulink url="
"\"https://github.com/irchelp/wio/blob/gh-pages/networks/connectprob.md"
"\">irchelp.org</ulink> bölümüne gözatın."

# u#, no-c-format
#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"When I go to <menuchoice> <guimenu>Window</guimenu> <guisubmenu>Channel "
"List</guisubmenu> </menuchoice>, I cannot select it. Why is that?"
msgstr ""
"<menuchoice> <guimenu>Pencere</guimenu> <guisubmenu>Kanal Listesi</"
"guisubmenu> </menuchoice> menüsüne gittiğimde birşey seçemiyorum. Neden?"

# u#, no-c-format
#. Tag: para
#: index.docbook:3257
#, no-c-format
msgid ""
"The <menuchoice> <guimenu>Window</guimenu> <guisubmenu>Channel List</"
"guisubmenu> </menuchoice> menu entry will be grayed-out if a non-channel "
"tab, &eg; <guilabel>Watched Nicks</guilabel>, is currently being viewed. To "
"make it selectable again go back to a channel tab or the server tab."
msgstr ""
"<menuchoice> <guimenu>Pencere</guimenu> <guisubmenu>Kanal Listesi</"
"guisubmenu> </menuchoice> menüsü, kanal sekmesi seçilebilir değilse, gri "
"olarak gözükecektir. &eg; <guilabel>İzlenen Rumuzlar</guilabel>, şuan da "
"görüntüleniyor. Seçilebilir hale getirmek için tekrar bir kanal sekmesine "
"veya sunucu sekmesine gidin."

#. Tag: para
#: index.docbook:3269
#, no-c-format
msgid ""
"How do I have &konversation; automatically mark me as away after a period of "
"inactivity?"
msgstr ""
"&konversation; beni belli bir eylemsizlik süresinin ardından, otomatik "
"olarak uzakta nasıl gösterir?"

#. Tag: para
#: index.docbook:3273
#, no-c-format
msgid ""
"Auto-away messages are configured on a per-identity basis. To enable auto-"
"away select <menuchoice><guimenu>Settings</guimenu><guimenuitem>Identities</"
"guimenuitem></menuchoice>. Choose the identity for which you want to enable "
"auto-away from the drop down list at the top of the dialog and go to the "
"<guilabel>Away</guilabel> tab. Check the <guilabel>Automatic Away</guilabel> "
"option."
msgstr ""
"Otomatik olarak uzakta iletileri, her bir kimlik için ayarlanabilir. "
"Otomatik olarak uzakta özelliğini etkinleştirmek için <guimenu>Ayarlar</"
"guimenu><guimenuitem>Kimlikler</guimenuitem></menuchoice> ögesini seçin. "
"İletişim kutusunun üst kısmındaki açılır listeden otomatik uzaktan erişim "
"özelliğini etkinleştirmek istediğiniz kimliğinizi seçin ve <guilabel>Uzakta</"
"guilabel> sekmesine gidin. <guilabel>Otomatik Uzakta</guilabel> seçeneğini "
"işaretleyin."

#. Tag: para
#: index.docbook:3283
#, no-c-format
msgid ""
"How to avoid the <guilabel>Auto Replace</guilabel> feature of the "
"<interface>Input Line</interface>?"
msgstr ""
"<interface>Girdi Satırı</interface> ögesinin, <guilabel>Otomatik Değiştir</"
"guilabel> özelliğini nasıl kapatırım."

#. Tag: para
#: index.docbook:3285
#, no-c-format
msgid ""
"Use <keycombo action=\"simul\">&Ctrl;&Enter;</keycombo> instead of just "
"&Enter; to avoid parsing and automatically replacing the text in the "
"<interface>Input Line</interface> according to the options in the settings "
"dialog page <menuchoice><guimenu>Behavior</guimenu> <guimenuitem>Auto "
"Replace</guimenuitem></menuchoice>."
msgstr ""
"<menuchoice><guimenu>Davranış</guimenu> <guimenuitem>Otomatik Değiştirme</"
"guimenuitem></menuchoice> ayarlar iletişim penceresi sayfasındaki "
"seçeneklere göre <interface>Girdi Satırı</interface> içindeki metni "
"ayrıştırmadan otomatik olarak değiştirmek için yalnızca &Enter; yerine "
"<keycombo action=\"simul\">&Ctrl;&Enter;</keycombo> kullanın."

#. Tag: para
#: index.docbook:3293
#, no-c-format
msgid "Where can I find the scripts included with &konversation;?"
msgstr "&konversation; ile birlikte verilen betikleri nereden bulabilirim?"

#. Tag: para
#: index.docbook:3296
#, no-c-format
msgid ""
"Run this command in &konversation;'s input line (using the media script as "
"an example, since it comes with any &konversation; installation):"
msgstr ""
"&konversation;'ın giriş satırında bu komutu çalıştırın (ortam betiğini örnek "
"olarak kullanın, çünkü herhangi bir &konversation; kurulumu ile birlikte "
"gelmektedir):"

#. Tag: userinput
#: index.docbook:3298
#, no-c-format
msgid "<command>/exec </command> <replaceable>--showpath media</replaceable>"
msgstr "<command>/exec </command> <replaceable>--showpath media</replaceable>"

#. Tag: para
#: index.docbook:3299
#, no-c-format
msgid ""
"Sample output: <replaceable>The script file 'media' was found at: /usr/share/"
"konversation/scripts/media</replaceable>"
msgstr ""
"Örnek çıktı: <replaceable>'media' betik dosyası, /usr/share/konversation/"
"scripts/media içinde mevcut</replaceable>"

#. Tag: para
#: index.docbook:3305
#, no-c-format
msgid "How do I make my text bold/italicized/underlined?"
msgstr "Metini nasıl kalın/yatık/altı çizgili yapabilirim?"

#. Tag: para
#: index.docbook:3308
#, no-c-format
msgid "Example: <userinput>This is my %Bbold%B text.</userinput>"
msgstr "Örnek: <userinput> Bu metin %Bkalın%B.</userinput>"

#. Tag: para
