#. Tag: title
#: index.docbook:10
#, no-c-format
msgid "File Management"
msgstr "Dosya Yönetimi"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Mike.McBride; &Mike.McBride.mail;"
msgstr "&Mike.McBride; &Mike.McBride.mail;"

