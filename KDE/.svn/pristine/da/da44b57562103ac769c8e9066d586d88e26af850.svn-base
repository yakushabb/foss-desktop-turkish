#, no-c-format
msgid "<refname>dragon</refname>"
msgstr "<refname>dragon</refname>"

#. Tag: refpurpose
#: man-dragon.1.docbook:24
#, no-c-format
msgid "a video player that has a usability focus"
msgstr "Kullanılabilirliğe odaklanmış bir video oynatıcı"

#. Tag: cmdsynopsis
#: man-dragon.1.docbook:28
#, no-c-format
msgid ""
"<command>dragon</command> <arg choice=\"opt\"><replaceable>URL</"
"replaceable></arg>"
msgstr ""
"<command>dragon</command> <arg choice=\"opt\"><replaceable>URL</"
"replaceable></arg>"

#. Tag: title
#: man-dragon.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "Açıklama"

#. Tag: para
#: man-dragon.1.docbook:36
#, no-c-format
msgid ""
"<command>dragon</command> player plays audio and video in different formats."
msgstr ""
"<command>dragon</command>, çeşitli biçimlerdeki video ve ses dosyalarını "
"çalar/oynatır."

#. Tag: title
#: man-dragon.1.docbook:41
#, no-c-format
msgid "Options"
msgstr "Seçenekler"

#. Tag: option
#: man-dragon.1.docbook:44
#, no-c-format
msgid "--play-dvd"
msgstr "--play-dvd"

#. Tag: para
#: man-dragon.1.docbook:46
#, no-c-format
msgid "Play DVD Video."
msgstr "DVD Video Oynat."

#. Tag: title
#: man-dragon.1.docbook:53
#, no-c-format
msgid "See Also"
msgstr "Ayrıca Bakınız"

#. Tag: member
#: man-dragon.1.docbook:55
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"dragonplayer\">help:/dragonplayer</ulink> (either enter this <acronym>URL</"
"acronym> into &konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/dragonplayer</parameter></userinput>)."
msgstr ""
"Ayrıntılı kullanıcı belgelendirmesi <ulink url=\"help:/dragonplayer\">help:/"
"dragonplayer</ulink>adresinde bulunabilir (bu <acronym>URL</acronym>'yi "
"ister &konqueror;'a girin veya <userinput><command>khelpcenter</command> "
"<parameter>help:/dragonplayer</parameter></userinput> komutunu çalıştırın)."

